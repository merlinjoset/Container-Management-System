@using ContainerManagement.Application.Dtos.Voyages
@model List<VoyageListItemDto>
@{
    ViewData["Title"] = "Voyages";
    ViewData["ShowNew"] = false;
    ViewData["ShowExport"] = false;
    ViewData["ShowImport"] = false;
}

@section Styles{
    <link rel="stylesheet" href="~/css/ui-common.css" asp-append-version="true" />
    <style>
        .voy-list-wrap { border: 1px solid #e5e7eb; border-radius: .5rem; overflow: hidden; background: #fff; margin-bottom: .75rem; }
        .voy-list-header {
            background: #1e3a8a; color: #fff; padding: .4rem .75rem; font-size: .8rem; font-weight: 600;
            display: flex; align-items: center; justify-content: space-between;
        }
        .voy-list-wrap table { width: 100%; border-collapse: collapse; font-size: .75rem; }
        .voy-list-wrap thead th {
            background: #312e81; color: #fff; padding: .4rem .5rem; font-weight: 600;
            white-space: nowrap; position: sticky; top: 0; z-index: 2; font-size: .72rem;
        }
        .voy-list-wrap tbody td { padding: .3rem .5rem; border-bottom: 1px solid #f1f5f9; cursor: pointer; }
        .voy-list-wrap tbody tr:hover { background: #eff6ff; }
        .voy-list-wrap tbody tr.selected { background: #dbeafe; border-left: 3px solid #1e3a8a; }

        /* Port detail panel */
        .voy-detail-wrap { border: 1px solid #e5e7eb; border-radius: .5rem; overflow: hidden; background: #fff; }
        .voy-detail-header {
            background: linear-gradient(135deg, #312e81, #4338ca); color: #fff; padding: .4rem .75rem; font-size: .8rem; font-weight: 600;
            display: flex; align-items: center; justify-content: space-between;
        }
        .voy-detail-info { background: #f8fafc; padding: .6rem .85rem; border-bottom: 1px solid #e5e7eb; display: flex; flex-wrap: wrap; gap: 1.5rem; }
        .voy-detail-info .info-item { font-size: .75rem; }
        .voy-detail-info .info-label { font-weight: 600; color: #1e3a8a; margin-right: .3rem; }
        .voy-detail-info .info-value { color: #374151; }

        .voy-detail-wrap table { width: 100%; border-collapse: collapse; font-size: .75rem; }
        .voy-detail-wrap thead th {
            background: #312e81; color: #fff; padding: .4rem .5rem; font-weight: 600;
            white-space: nowrap; font-size: .72rem; text-align: center;
        }
        .voy-detail-wrap tbody td { padding: .3rem .5rem; border-bottom: 1px solid #f1f5f9; text-align: center; font-size: .73rem; }
        .voy-detail-wrap tbody tr:hover { background: #eff6ff; }

        .voy-detail-empty { padding: 2rem; text-align: center; color: #9ca3af; font-size: .82rem; }

        .voy-action-bar { display: flex; gap: .4rem; align-items: center; }
        .voy-action-bar .btn { font-size: .72rem; padding: .2rem .55rem; }

        /* Actual date highlighting */
        .actual-green { background: #dcfce7 !important; color: #15803d !important; font-weight: 600; }
        .actual-brown { background: #fde8d8 !important; color: #7c2d12 !important; font-weight: 600; }

        /* Inline report buttons */
        .port-report-btns { display: flex; gap: .25rem; }
        .port-report-btns .btn {
            font-size: .62rem; padding: .12rem .35rem; border-radius: .25rem;
            white-space: nowrap; display: inline-flex; align-items: center; gap: .2rem;
        }
        .btn-arr { background: #eff6ff; color: #1e40af; border: 1px solid #bfdbfe; }
        .btn-arr:hover { background: #dbeafe; color: #1e3a8a; }
        .btn-arr.filled { background: #dcfce7; color: #15803d; border-color: #86efac; }
        .btn-dep { background: #fffbeb; color: #92400e; border: 1px solid #fde68a; }
        .btn-dep:hover { background: #fef3c7; color: #78350f; }
        .btn-dep.filled { background: #dcfce7; color: #15803d; border-color: #86efac; }
        .btn-xls { background: #f0fdf4; color: #065f46; border: 1px solid #a7f3d0; font-size: .58rem !important; padding: .1rem .3rem !important; }
        .btn-xls:hover { background: #d1fae5; color: #064e3b; }

        /* Export button */
        .btn-export { font-size: .72rem; padding: .25rem .6rem; background: #065f46; color: #fff; border: none; border-radius: .3rem; }
        .btn-export:hover { background: #047857; color: #fff; }

        /* Filter input placeholder */
        .voy-filter::placeholder { color: rgba(255,255,255,.4); }
        .voy-filter:focus { background: rgba(255,255,255,.15) !important; color: #fff !important; border-color: rgba(255,255,255,.4) !important; box-shadow: none; }

        /* Pagination */
        .voy-pagination {
            display: flex; align-items: center; justify-content: space-between;
            padding: .35rem .75rem; background: #f8fafc; border-top: 1px solid #e5e7eb; font-size: .72rem;
        }
        .voy-pagination .page-info { color: #6b7280; }
        .voy-pagination .page-btns { display: flex; gap: .2rem; }
        .voy-pagination .page-btn {
            padding: .15rem .45rem; border: 1px solid #d1d5db; border-radius: .25rem;
            background: #fff; color: #374151; cursor: pointer; font-size: .7rem; min-width: 26px; text-align: center;
        }
        .voy-pagination .page-btn:hover { background: #eff6ff; border-color: #93c5fd; }
        .voy-pagination .page-btn.active { background: #1e3a8a; color: #fff; border-color: #1e3a8a; }
        .voy-pagination .page-btn.disabled { opacity: .4; pointer-events: none; }
    </style>
}

<div class="operator-page">
    <div class="page-header d-flex align-items-center justify-content-between">
        <span>Voyages</span>
        <a asp-action="Create" class="btn btn-sm btn-primary" style="font-size:.78rem;"><i class="bi bi-plus-lg"></i> New Voyage</a>
    </div>

    <div class="content" style="flex-direction: column; max-width: 100%;">
        <div style="width: 100%;">

            @* ── Voyage List ── *@
            <div class="voy-list-wrap">
                <div class="voy-list-header">
                    <span><i class="bi bi-ship me-1"></i> Voyage List</span>
                    <div class="d-flex align-items-center gap-2">
                        <span id="voy-count" style="font-size:.7rem; opacity:.7;">@(Model?.Count ?? 0) voyage(s)</span>
                        <span style="font-size:.7rem; opacity:.7;">| Click a row to view port rotation</span>
                    </div>
                </div>
                <div>
                    <table>
                        <thead>
                            <tr>
                                <th>Vessel</th>
                                <th>Service Code</th>
                                <th>Service Name</th>
                                <th>Operator</th>
                                <th>Slot</th>
                                <th>Created</th>
                                <th>Actions</th>
                            </tr>
                            <tr style="background:#1e2940;">
                                <th style="padding:.25rem .4rem;"><input type="text" class="form-control form-control-sm voy-filter" id="vf-vessel" placeholder="Search..." style="font-size:.68rem; padding:.15rem .35rem; background:rgba(255,255,255,.1); color:#fff; border:1px solid rgba(255,255,255,.2);" /></th>
                                <th style="padding:.25rem .4rem;"><input type="text" class="form-control form-control-sm voy-filter" id="vf-scode" placeholder="Search..." style="font-size:.68rem; padding:.15rem .35rem; background:rgba(255,255,255,.1); color:#fff; border:1px solid rgba(255,255,255,.2);" /></th>
                                <th style="padding:.25rem .4rem;"><input type="text" class="form-control form-control-sm voy-filter" id="vf-sname" placeholder="Search..." style="font-size:.68rem; padding:.15rem .35rem; background:rgba(255,255,255,.1); color:#fff; border:1px solid rgba(255,255,255,.2);" /></th>
                                <th style="padding:.25rem .4rem;"><input type="text" class="form-control form-control-sm voy-filter" id="vf-operator" placeholder="Search..." style="font-size:.68rem; padding:.15rem .35rem; background:rgba(255,255,255,.1); color:#fff; border:1px solid rgba(255,255,255,.2);" /></th>
                                <th></th>
                                <th></th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody id="voy-list-body">
                            @if (Model != null && Model.Any())
                            {
                                foreach (var v in Model.OrderByDescending(x => x.CreatedOn))
                                {
                                    <tr data-id="@v.Id"
                                        data-vessel="@v.VesselName"
                                        data-service-code="@v.ServiceCode"
                                        data-service-name="@v.ServiceName"
                                        data-operator="@v.OperatorName"
                                        data-slot="@v.VoyageType"
                                        data-created="@v.CreatedOn.ToString("yyyy-MM-dd")">
                                        <td>@v.VesselName</td>
                                        <td>@v.ServiceCode</td>
                                        <td>@v.ServiceName</td>
                                        <td>@v.OperatorName</td>
                                        <td>@v.VoyageType</td>
                                        <td>@v.CreatedOn.ToString("dd/MM/yyyy")</td>
                                        <td>
                                            <div class="voy-action-bar">
                                                <a asp-action="Edit" asp-route-id="@v.Id" class="btn btn-sm btn-outline-primary" onclick="event.stopPropagation();">
                                                    <i class="bi bi-pencil"></i> Edit
                                                </a>
                                                <form asp-action="Delete" asp-route-id="@v.Id" method="post" style="display:inline;" onsubmit="event.stopPropagation(); return confirm('Delete this voyage?');">
                                                    @Html.AntiForgeryToken()
                                                    <button type="submit" class="btn btn-sm btn-outline-danger" onclick="event.stopPropagation();">
                                                        <i class="bi bi-trash"></i>
                                                    </button>
                                                </form>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr id="no-data-row"><td colspan="7" class="text-center text-muted" style="padding:2rem;">No voyages found. Click "New Voyage" to create one.</td></tr>
                            }
                        </tbody>
                    </table>
                </div>
                <!-- Pagination bar -->
                <div class="voy-pagination" id="voy-pagination"></div>
            </div>

            @* ── Port Rotation Detail Panel ── *@
            <div class="voy-detail-wrap" id="voy-detail-panel" style="display:none;">
                <div class="voy-detail-header">
                    <span><i class="bi bi-geo-alt me-1"></i> Port Rotation — <span id="detail-title"></span></span>
                    <div class="d-flex align-items-center gap-2">
                        <span id="detail-port-count" style="font-size:.7rem; opacity:.7;"></span>
                        <button class="btn btn-export" id="btnExport" onclick="exportReport()" title="Export to Excel">
                            <i class="bi bi-file-earmark-spreadsheet me-1"></i>Export
                        </button>
                    </div>
                </div>
                <div class="voy-detail-info" id="detail-info">
                    <div class="info-item"><span class="info-label">Vessel:</span><span class="info-value" id="info-vessel"></span></div>
                    <div class="info-item"><span class="info-label">Service:</span><span class="info-value" id="info-service"></span></div>
                    <div class="info-item"><span class="info-label">Operator:</span><span class="info-value" id="info-operator"></span></div>
                    <div class="info-item"><span class="info-label">Slot:</span><span class="info-value" id="info-slot"></span></div>
                </div>
                <div style="max-height: 45vh; overflow: auto;">
                    <table>
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Voy No</th>
                                <th>Bound</th>
                                <th>Port</th>
                                <th>Terminal</th>
                                <th>ETA</th>
                                <th>ETB</th>
                                <th>ETD</th>
                                <th style="background:#1e3a8a;">Act. ETA</th>
                                <th style="background:#1e3a8a;">Act. ETB</th>
                                <th>Act. ETD</th>
                                <th>Port Stay</th>
                                <th>Speed</th>
                                <th>Distance</th>
                                <th>Sea Day</th>
                                <th>Reports</th>
                            </tr>
                        </thead>
                        <tbody id="detail-port-body">
                        </tbody>
                    </table>
                </div>
            </div>

            @* ── Placeholder when no voyage selected ── *@
            <div class="voy-detail-wrap" id="voy-detail-placeholder">
                <div class="voy-detail-empty">
                    <i class="bi bi-cursor" style="font-size:1.5rem; display:block; margin-bottom:.5rem;"></i>
                    Select a voyage from the list above to view its port rotation
                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts{
    <script>
        (function() {
            var listBody = document.getElementById('voy-list-body');
            var detailPanel = document.getElementById('voy-detail-panel');
            var placeholder = document.getElementById('voy-detail-placeholder');
            var portBody = document.getElementById('detail-port-body');
            var selectedId = null;

            function formatDate(val) {
                if (!val) return '';
                var d = new Date(val);
                if (isNaN(d.getTime())) return '';
                var dd = ('0' + d.getDate()).slice(-2);
                var mm = ('0' + (d.getMonth() + 1)).slice(-2);
                var yyyy = d.getFullYear();
                var hh = ('0' + d.getHours()).slice(-2);
                var mi = ('0' + d.getMinutes()).slice(-2);
                return dd + '/' + mm + '/' + yyyy + ' ' + hh + ':' + mi;
            }

            // Expose selectedId for export
            window.getSelectedVoyageId = function() { return selectedId; };

            // ── Filter + Pagination logic ──
            var PAGE_SIZE = 5;
            var allRows = Array.prototype.slice.call(listBody.querySelectorAll('tr[data-id]'));
            var voyCount = document.getElementById('voy-count');
            var paginationBar = document.getElementById('voy-pagination');
            var filters = document.querySelectorAll('.voy-filter');
            var filteredRows = allRows.slice();
            var currentPage = 1;

            function getFilteredRows() {
                var fVessel = (document.getElementById('vf-vessel').value || '').toLowerCase();
                var fScode = (document.getElementById('vf-scode').value || '').toLowerCase();
                var fSname = (document.getElementById('vf-sname').value || '').toLowerCase();
                var fOp = (document.getElementById('vf-operator').value || '').toLowerCase();
                var result = [];
                for (var k = 0; k < allRows.length; k++) {
                    var r = allRows[k];
                    var vessel = (r.getAttribute('data-vessel') || '').toLowerCase();
                    var scode = (r.getAttribute('data-service-code') || '').toLowerCase();
                    var sname = (r.getAttribute('data-service-name') || '').toLowerCase();
                    var op = (r.getAttribute('data-operator') || '').toLowerCase();
                    if ((!fVessel || vessel.indexOf(fVessel) !== -1) &&
                        (!fScode || scode.indexOf(fScode) !== -1) &&
                        (!fSname || sname.indexOf(fSname) !== -1) &&
                        (!fOp || op.indexOf(fOp) !== -1)) {
                        result.push(r);
                    }
                }
                return result;
            }

            function renderPage() {
                filteredRows = getFilteredRows();
                var totalPages = Math.max(1, Math.ceil(filteredRows.length / PAGE_SIZE));
                if (currentPage > totalPages) currentPage = totalPages;

                // Hide all rows, then show only current page
                for (var k = 0; k < allRows.length; k++) allRows[k].style.display = 'none';
                var start = (currentPage - 1) * PAGE_SIZE;
                var end = Math.min(start + PAGE_SIZE, filteredRows.length);
                for (var k = start; k < end; k++) filteredRows[k].style.display = '';

                // Update count
                if (voyCount) voyCount.textContent = filteredRows.length + ' voyage(s)';

                // Render pagination bar
                renderPagination(totalPages);
            }

            function renderPagination(totalPages) {
                if (filteredRows.length <= PAGE_SIZE) {
                    paginationBar.innerHTML = '<span class="page-info">Showing ' + filteredRows.length + ' of ' + filteredRows.length + ' voyage(s)</span>';
                    return;
                }
                var start = (currentPage - 1) * PAGE_SIZE + 1;
                var end = Math.min(currentPage * PAGE_SIZE, filteredRows.length);
                var html = '<span class="page-info">Showing ' + start + '–' + end + ' of ' + filteredRows.length + ' voyage(s)</span>';
                html += '<div class="page-btns">';
                html += '<span class="page-btn' + (currentPage <= 1 ? ' disabled' : '') + '" data-page="' + (currentPage - 1) + '">‹</span>';
                for (var p = 1; p <= totalPages; p++) {
                    html += '<span class="page-btn' + (p === currentPage ? ' active' : '') + '" data-page="' + p + '">' + p + '</span>';
                }
                html += '<span class="page-btn' + (currentPage >= totalPages ? ' disabled' : '') + '" data-page="' + (currentPage + 1) + '">›</span>';
                html += '</div>';
                paginationBar.innerHTML = html;

                // Wire page clicks
                var btns = paginationBar.querySelectorAll('.page-btn:not(.disabled)');
                for (var b = 0; b < btns.length; b++) {
                    btns[b].addEventListener('click', function() {
                        currentPage = parseInt(this.getAttribute('data-page'));
                        renderPage();
                    });
                }
            }

            for (var fi = 0; fi < filters.length; fi++) {
                filters[fi].addEventListener('input', function() {
                    currentPage = 1;
                    renderPage();
                });
            }

            // Initial render
            renderPage();

            // Attach click to voyage rows
            for (var i = 0; i < allRows.length; i++) {
                (function(row) {
                    row.addEventListener('click', function() {
                        var id = row.getAttribute('data-id');
                        if (selectedId === id) return;
                        selectedId = id;

                        // Highlight selected row
                        for (var j = 0; j < allRows.length; j++) allRows[j].classList.remove('selected');
                        row.classList.add('selected');

                        // Update detail info
                        document.getElementById('info-vessel').textContent = row.getAttribute('data-vessel') || '';
                        document.getElementById('info-service').textContent = (row.getAttribute('data-service-code') || '') + (row.getAttribute('data-service-name') ? ' — ' + row.getAttribute('data-service-name') : '');
                        document.getElementById('info-operator').textContent = row.getAttribute('data-operator') || '';
                        document.getElementById('info-slot').textContent = row.getAttribute('data-slot') || '';
                        document.getElementById('detail-title').textContent = (row.getAttribute('data-vessel') || 'Voyage');

                        // Load ports
                        loadPorts(id);
                    });
                })(allRows[i]);
            }

            function loadPorts(voyageId) {
                portBody.innerHTML = '<tr><td colspan="16" class="text-center py-3"><i class="bi bi-hourglass-split"></i> Loading…</td></tr>';
                placeholder.style.display = 'none';
                detailPanel.style.display = '';

                fetch('@Url.Action("GetPorts", "Voyages")?id=' + voyageId)
                    .then(function(resp) {
                        var ct = resp.headers.get('content-type') || '';
                        if (!resp.ok) throw new Error('HTTP ' + resp.status);
                        if (ct.indexOf('json') === -1) throw new Error('Auth redirect – please re-login');
                        return resp.json();
                    })
                    .then(function(data) {
                        portBody.innerHTML = '';
                        if (!data || !data.length) {
                            portBody.innerHTML = '<tr><td colspan="16" class="text-center text-muted py-3">No port rotation data</td></tr>';
                            document.getElementById('detail-port-count').textContent = '0 ports';
                            return;
                        }

                        document.getElementById('detail-port-count').textContent = data.length + ' port' + (data.length !== 1 ? 's' : '');

                        for (var i = 0; i < data.length; i++) {
                            var p = data[i];
                            var tr = document.createElement('tr');

                            // Determine highlight classes
                            var etaCls = p.hasArrival ? ' class="actual-green"' : '';
                            var etbCls = p.hasArrival ? ' class="actual-green"' : '';
                            var etdCls = p.hasDeparture ? ' class="actual-brown"' : '';

                            // Arrival button style
                            var arrBtnCls = p.hasArrival ? 'btn btn-arr filled' : 'btn btn-arr';
                            var arrIcon = p.hasArrival ? '<i class="bi bi-check-circle-fill"></i>' : '<i class="bi bi-clipboard-data"></i>';
                            var arrLabel = p.hasArrival ? 'Arrival' : 'Arrival';

                            // Departure button style
                            var depBtnCls = p.hasDeparture ? 'btn btn-dep filled' : 'btn btn-dep';
                            var depIcon = p.hasDeparture ? '<i class="bi bi-check-circle-fill"></i>' : '<i class="bi bi-box-arrow-right"></i>';
                            var depLabel = p.hasDeparture ? 'Departure' : 'Departure';

                            tr.innerHTML =
                                '<td style="font-weight:700;color:#1e3a8a;">' + (i + 1) + '</td>' +
                                '<td>' + (p.voyNo || '') + '</td>' +
                                '<td>' + (p.bound || '') + '</td>' +
                                '<td style="font-weight:600;">' + (p.portCode || '') + '</td>' +
                                '<td>' + (p.terminalCode || '') + '</td>' +
                                '<td>' + formatDate(p.eta) + '</td>' +
                                '<td>' + formatDate(p.etb) + '</td>' +
                                '<td>' + formatDate(p.etd) + '</td>' +
                                '<td' + etaCls + '>' + formatDate(p.actualETA) + '</td>' +
                                '<td' + etbCls + '>' + formatDate(p.actualETB) + '</td>' +
                                '<td' + etdCls + '>' + formatDate(p.actualETD) + '</td>' +
                                '<td>' + (p.portStay != null ? p.portStay : '') + '</td>' +
                                '<td>' + (p.speed != null ? parseFloat(p.speed).toFixed(1) : '') + '</td>' +
                                '<td>' + (p.distance != null ? parseFloat(p.distance).toFixed(0) : '') + '</td>' +
                                '<td>' + (p.seaDay != null ? parseFloat(p.seaDay).toFixed(2) : '') + '</td>' +
                                '<td>' +
                                    '<div class="port-report-btns">' +
                                        '<a href="/voyages/arrival/' + p.id + '" class="' + arrBtnCls + '" onclick="event.stopPropagation();">' + arrIcon + arrLabel + '</a>' +
                                        (p.hasArrival ? '<a href="/voyages/exportarrival/' + p.id + '" class="btn btn-xls" onclick="event.stopPropagation();" title="Export Arrival"><i class="bi bi-file-earmark-spreadsheet"></i></a>' : '') +
                                        '<a href="/voyages/departure/' + p.id + '" class="' + depBtnCls + '" onclick="event.stopPropagation();">' + depIcon + depLabel + '</a>' +
                                        (p.hasDeparture ? '<a href="/voyages/exportdeparture/' + p.id + '" class="btn btn-xls" onclick="event.stopPropagation();" title="Export Departure"><i class="bi bi-file-earmark-spreadsheet"></i></a>' : '') +
                                    '</div>' +
                                '</td>';
                            portBody.appendChild(tr);
                        }
                    })
                    .catch(function(err) {
                        portBody.innerHTML = '<tr><td colspan="16" class="text-center text-danger py-3">' + err.message + '</td></tr>';
                    });
            }

            // Auto-select first visible voyage if available
            if (filteredRows.length > 0) {
                filteredRows[0].click();
            }
        })();

        function exportReport() {
            var voyageId = window.getSelectedVoyageId();
            if (!voyageId) { alert('Please select a voyage first.'); return; }
            window.location.href = '@Url.Action("ExportPorts", "Voyages")?id=' + voyageId;
        }
    </script>
}
