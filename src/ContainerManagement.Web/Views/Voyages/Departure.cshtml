@using ContainerManagement.Application.Dtos.Voyages
@model VoyagePortDepartureDto
@{
    ViewData["Title"] = "Vessel Departure Report";
    var port = ViewBag.VoyagePort as VoyagePortListItemDto;
    var voyage = ViewBag.ParentVoyage as VoyageListItemDto;
    var isEdit = Model.Id != Guid.Empty;
    var ports = ViewBag.Ports as List<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem> ?? new();
}

@section Styles {
<style>
    .departure-page { max-width: 960px; }
    .departure-header {
        background: linear-gradient(135deg, #7c2d12, #9a3412);
        color: #fff; border-radius: .5rem; padding: 1rem 1.25rem; margin-bottom: 1rem;
    }
    .departure-header h5 { margin: 0; font-weight: 700; font-size: 1rem; }
    .departure-header .subtitle { font-size: .75rem; opacity: .8; margin-top: .2rem; }
    .departure-context { background: #f8fafc; border: 1px solid #e5e7eb; border-radius: .5rem; padding: .75rem 1rem; margin-bottom: 1rem; display: flex; flex-wrap: wrap; gap: 1.5rem; }
    .departure-context .ctx-item { font-size: .78rem; }
    .departure-context .ctx-label { font-weight: 600; color: #9a3412; margin-right: .25rem; }
    .departure-context .ctx-value { color: #374151; }
    .dep-section {
        background: #fff; border: 1px solid #e5e7eb; border-radius: .5rem; margin-bottom: 1rem; overflow: hidden;
    }
    .dep-section-header {
        background: #fff7ed; padding: .5rem .85rem; font-size: .78rem; font-weight: 600; color: #9a3412;
        border-bottom: 1px solid #e5e7eb; display: flex; align-items: center; gap: .4rem;
    }
    .dep-section-body { padding: .75rem 1rem; }
    .dep-section .form-label { font-size: .72rem; font-weight: 600; color: #475569; margin-bottom: .15rem; }
    .dep-section .form-control, .dep-section .form-select { font-size: .78rem; }
    .dep-footer { display: flex; gap: .5rem; justify-content: flex-end; margin-top: 1rem; }
</style>
}

<div class="operator-page departure-page">

    <!-- Header -->
    <div class="departure-header">
        <div class="d-flex align-items-center justify-content-between">
            <div>
                <h5><i class="bi bi-box-arrow-right me-2"></i>Vessel Departure Report</h5>
                <div class="subtitle">@(isEdit ? "Edit departure data" : "Record new departure data") for port rotation</div>
            </div>
            <a asp-action="Index" class="btn btn-sm btn-outline-light"><i class="bi bi-arrow-left me-1"></i>Back to Voyages</a>
        </div>
    </div>

    <!-- Context Info -->
    <div class="departure-context">
        <div class="ctx-item"><span class="ctx-label">Vessel:</span><span class="ctx-value">@(voyage?.VesselName ?? "—")</span></div>
        <div class="ctx-item"><span class="ctx-label">Service:</span><span class="ctx-value">@(voyage?.ServiceCode ?? "—")</span></div>
        <div class="ctx-item"><span class="ctx-label">Port:</span><span class="ctx-value">@(port?.PortCode ?? "—")</span></div>
        <div class="ctx-item"><span class="ctx-label">Terminal:</span><span class="ctx-value">@(port?.TerminalCode ?? "—")</span></div>
        <div class="ctx-item"><span class="ctx-label">Planned ETA:</span><span class="ctx-value">@(port?.ETA?.ToString("dd/MM/yyyy HH:mm") ?? "—")</span></div>
        <div class="ctx-item"><span class="ctx-label">Planned ETB:</span><span class="ctx-value">@(port?.ETB?.ToString("dd/MM/yyyy HH:mm") ?? "—")</span></div>
        <div class="ctx-item"><span class="ctx-label">Planned ETD:</span><span class="ctx-value">@(port?.ETD?.ToString("dd/MM/yyyy HH:mm") ?? "—")</span></div>
    </div>

    <input type="hidden" id="voyagePortId" value="@Model.VoyagePortId" />
    <input type="hidden" id="departureId" value="@Model.Id" />

    <!-- Voyage Info -->
    <div class="dep-section">
        <div class="dep-section-header"><i class="bi bi-compass"></i> Voyage Information</div>
        <div class="dep-section-body">
            <div class="row g-3">
                <div class="col-md-3">
                    <label class="form-label">Inbound Voyage</label>
                    <input type="text" class="form-control form-control-sm" id="inboundVoyage" value="@(Model.InboundVoyage ?? port?.VoyNo)" placeholder="@port?.VoyNo" maxlength="50" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Outbound Voyage</label>
                    <input type="text" class="form-control form-control-sm" id="outboundVoyage" value="@(Model.OutboundVoyage ?? port?.VoyNo)" placeholder="@port?.VoyNo" maxlength="50" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Next Port</label>
                    <select class="form-select form-select-sm" id="nextPortId">
                        <option value="">-- Select --</option>
                        @foreach (var p in ports)
                        {
                            var sel = p.Value == Model.NextPortId?.ToString();
                            if (sel)
                            {
                                <option value="@p.Value" selected>@p.Text</option>
                            }
                            else
                            {
                                <option value="@p.Value">@p.Text</option>
                            }
                        }
                    </select>
                </div>
            </div>
        </div>
    </div>

    <!-- Departure Times -->
    <div class="dep-section">
        <div class="dep-section-header"><i class="bi bi-clock-history"></i> Departure Times</div>
        <div class="dep-section-body">
            <div class="row g-3">
                <div class="col-md-4">
                    <label class="form-label">Completed Cargo Ops</label>
                    <div class="d-flex gap-2">
                        <input type="text" class="form-control form-control-sm date-dmy" id="compCargoOp_date" value="@(Model.CompleteCargoOperation?.ToString("dd/MM/yyyy"))" placeholder="dd/mm/yyyy" maxlength="10" />
                        <input type="text" class="form-control form-control-sm time-24" id="compCargoOp_time" value="@(Model.CompleteCargoOperation?.ToString("HH:mm"))" placeholder="hh:mm" maxlength="5" style="max-width:80px; text-align:center;" />
                    </div>
                </div>
                <div class="col-md-4">
                    <label class="form-label">Unberth (FAOP)</label>
                    <div class="d-flex gap-2">
                        <input type="text" class="form-control form-control-sm date-dmy" id="unberthFAOP_date" value="@(Model.UnberthFAOP?.ToString("dd/MM/yyyy"))" placeholder="dd/mm/yyyy" maxlength="10" />
                        <input type="text" class="form-control form-control-sm time-24" id="unberthFAOP_time" value="@(Model.UnberthFAOP?.ToString("HH:mm"))" placeholder="hh:mm" maxlength="5" style="max-width:80px; text-align:center;" />
                    </div>
                </div>
                <div class="col-md-4">
                    <label class="form-label">Pilot On Board</label>
                    <div class="d-flex gap-2">
                        <input type="text" class="form-control form-control-sm date-dmy" id="pilotOnBoard_date" value="@(Model.PilotOnBoard?.ToString("dd/MM/yyyy"))" placeholder="dd/mm/yyyy" maxlength="10" />
                        <input type="text" class="form-control form-control-sm time-24" id="pilotOnBoard_time" value="@(Model.PilotOnBoard?.ToString("HH:mm"))" placeholder="hh:mm" maxlength="5" style="max-width:80px; text-align:center;" />
                    </div>
                </div>
                <div class="col-md-4">
                    <label class="form-label">Departure (BOSP)</label>
                    <div class="d-flex gap-2">
                        <input type="text" class="form-control form-control-sm date-dmy" id="actualETD_date" value="@(Model.ActualETD?.ToString("dd/MM/yyyy"))" placeholder="dd/mm/yyyy" maxlength="10" />
                        <input type="text" class="form-control form-control-sm time-24" id="actualETD_time" value="@(Model.ActualETD?.ToString("HH:mm"))" placeholder="hh:mm" maxlength="5" style="max-width:80px; text-align:center;" />
                    </div>
                </div>
                <div class="col-md-4">
                    <label class="form-label">ETA Next Port</label>
                    <div class="d-flex gap-2">
                        <input type="text" class="form-control form-control-sm date-dmy" id="etaNextPort_date" value="@(Model.ETANextPort?.ToString("dd/MM/yyyy"))" placeholder="dd/mm/yyyy" maxlength="10" />
                        <input type="text" class="form-control form-control-sm time-24" id="etaNextPort_time" value="@(Model.ETANextPort?.ToString("HH:mm"))" placeholder="hh:mm" maxlength="5" style="max-width:80px; text-align:center;" />
                    </div>
                </div>
            </div>
            <div id="timeValidationError" class="text-danger mt-2" style="font-size:.75rem; display:none;"></div>
        </div>
    </div>

    <!-- Draft & Tugs -->
    <div class="dep-section">
        <div class="dep-section-header"><i class="bi bi-rulers"></i> Draft & Tugs</div>
        <div class="dep-section-body">
            <div class="row g-3">
                <div class="col-md-2">
                    <label class="form-label">Tugs Out</label>
                    <input type="number" min="0" max="5" step="1" class="form-control form-control-sm" id="tugsOut" value="@Model.TugsOut" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Draft Fwd (m)</label>
                    <input type="number" step="0.01" class="form-control form-control-sm" id="draftFwd" value="@Model.DepDraftFwdMtr" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Draft Aft (m)</label>
                    <input type="number" step="0.01" class="form-control form-control-sm" id="draftAft" value="@Model.DepDraftAftMtr" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Draft Mean (m)</label>
                    <input type="number" step="0.01" class="form-control form-control-sm" id="draftMean" value="@Model.DepDraftMeanMtr" />
                </div>
            </div>
            <!-- Tug Usage (dynamic rows based on Tugs Out count) -->
            <div id="tugOutUsageSection" class="mt-3" style="display:none;">
                <label class="form-label fw-bold" style="font-size:.78rem;"><i class="bi bi-clock-history me-1"></i>Tug Usage (hrs)</label>
                <div class="row g-2" id="tugOutUsageRow"></div>
            </div>
        </div>
    </div>

    <!-- Bunkers On Departure -->
    <div class="dep-section">
        <div class="dep-section-header"><i class="bi bi-fuel-pump"></i> Bunkers On Departure</div>
        <div class="dep-section-body">
            <!-- Bunker Supply -->
            <label class="form-label fw-bold mb-2" style="font-size:.78rem;"><i class="bi bi-box-arrow-in-down me-1"></i>Bunker Supply</label>
            <table class="table table-sm table-bordered mb-3" style="font-size:.8rem; max-width:400px;">
                <thead class="table-light">
                    <tr>
                        <th></th>
                        <th class="text-center">Qty</th>
                        <th class="text-center">Rate/Mts</th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        var supplyFuels = new[] { "VLSFO", "MGO", "HFO" };
                        var supplyLabels = new[] { "VLSFO (mts)", "MGO mts", "HFO mts" };
                    }
                    @for (var sf = 0; sf < supplyFuels.Length; sf++)
                    {
                        var ft = supplyFuels[sf];
                        var existingSupply = Model.BunkerSupplies.FirstOrDefault(s => s.FuelType == ft);
                        <tr>
                            <td class="fw-semibold" style="white-space:nowrap; color:#475569;">@supplyLabels[sf]</td>
                            <td><input type="number" step="0.01" min="0" class="form-control form-control-sm bunker-supply-input" data-fuel="@ft" data-field="qty" value="@existingSupply?.Qty" /></td>
                            <td><input type="number" step="0.01" min="0" class="form-control form-control-sm bunker-supply-input" data-fuel="@ft" data-field="rate" value="@existingSupply?.RateMts" /></td>
                        </tr>
                    }
                </tbody>
            </table>

            <!-- Bunker On Departure readings -->
            <label class="form-label fw-bold mb-2" style="font-size:.78rem;"><i class="bi bi-fuel-pump me-1"></i>Bunkers on Departure</label>
            <table class="table table-sm table-bordered mb-3" style="font-size:.8rem; max-width:500px;">
                <thead class="table-light">
                    <tr>
                        <th></th>
                        <th class="text-center">VLSFO (mts)</th>
                        <th class="text-center">MGO mts</th>
                        <th class="text-center">HFO mts</th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        var depBunkerPoints = new[] { "CompleteCargo", "PilotOnBoard", "Departure" };
                        var depBunkerLabels = new[] { "Complete Cargo Operation", "Pilot On Board", "Departure" };
                    }
                    @for (var dp = 0; dp < depBunkerPoints.Length; dp++)
                    {
                        var pt = depBunkerPoints[dp];
                        var existingDep = Model.Bunkers.FirstOrDefault(b => b.ReadingPoint == pt);
                        <tr>
                            <td class="fw-semibold" style="white-space:nowrap; color:#475569;">@depBunkerLabels[dp]</td>
                            <td><input type="number" step="0.01" min="0" class="form-control form-control-sm bunker-dep-input" data-point="@pt" data-fuel="vlsfo" value="@existingDep?.VlsfoMts" /></td>
                            <td><input type="number" step="0.01" min="0" class="form-control form-control-sm bunker-dep-input" data-point="@pt" data-fuel="mgo" value="@existingDep?.MgoMts" /></td>
                            <td><input type="number" step="0.01" min="0" class="form-control form-control-sm bunker-dep-input" data-point="@pt" data-fuel="hfo" value="@existingDep?.HfoMts" /></td>
                        </tr>
                    }
                </tbody>
            </table>
            <div id="bunkerDepError" class="alert alert-danger py-2 d-none" style="font-size:.8rem;"><i class="bi bi-exclamation-triangle-fill me-1"></i><span id="bunkerDepErrorMsg"></span></div>
            <div class="row g-3">
                <div class="col-md-3">
                    <label class="form-label">Fresh Water</label>
                    <input type="number" step="0.01" class="form-control form-control-sm" id="freshWater" value="@Model.FreshWater" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Ballast Water</label>
                    <input type="number" step="0.01" class="form-control form-control-sm" id="ballastWater" value="@Model.BallastWater" />
                </div>
            </div>
        </div>
    </div>

    <!-- Remarks -->
    <div class="dep-section">
        <div class="dep-section-header"><i class="bi bi-chat-left-text"></i> Remarks</div>
        <div class="dep-section-body">
            <textarea class="form-control form-control-sm" id="remarks" rows="3" maxlength="2000">@Model.Remarks</textarea>
        </div>
    </div>

    <!-- Footer Actions -->
    <div class="dep-footer">
        <a asp-action="Index" class="btn btn-light btn-sm">Cancel</a>
        @if (isEdit)
        {
            <button type="button" class="btn btn-sm" style="background:#065f46;color:#fff;" id="btnExport" data-export-url="@Url.Action("ExportDeparture", "Voyages", new { id = Model.VoyagePortId })">
                <span id="btnExportText"><i class="bi bi-file-earmark-spreadsheet me-1"></i>Export Excel</span>
                <span id="btnExportLoader" style="display:none;"><span class="spinner-border spinner-border-sm me-1"></span>Exporting...</span>
            </button>
        }
        <button class="btn btn-sm" style="background:#9a3412;color:#fff;" id="btnSave" onclick="saveDeparture()">
            <span id="btnSaveText"><i class="bi bi-check-lg me-1"></i>Save Departure Report</span>
            <span id="btnSaveLoader" style="display:none;"><span class="spinner-border spinner-border-sm me-1"></span>Saving...</span>
        </button>
    </div>
</div>

<!-- Toast -->
<div class="position-fixed bottom-0 end-0 p-3" style="z-index:1080">
    <div id="toast" class="toast align-items-center text-bg-success border-0" role="alert">
        <div class="d-flex">
            <div class="toast-body" id="toastMsg"></div>
            <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
        </div>
    </div>
</div>

@section Scripts {
<script>
    // Export button handler
    (function() {
        var btnExport = document.getElementById('btnExport');
        if (!btnExport) return;
        var exporting = false;
        btnExport.addEventListener('click', function() {
            if (exporting) return;
            exporting = true;
            var url = btnExport.getAttribute('data-export-url');
            btnExport.disabled = true;
            btnExport.style.opacity = '0.6';
            document.getElementById('btnExportText').style.display = 'none';
            document.getElementById('btnExportLoader').style.display = '';

            fetch(url, { credentials: 'same-origin' })
                .then(function(resp) {
                    if (!resp.ok) throw new Error('Export failed');
                    var cd = resp.headers.get('content-disposition') || '';
                    var m = cd.match(/filename[^;=\n]*=(["']?)([^"';\n]*)\1/);
                    var fname = m ? m[2] : 'DepartureReport.xlsx';
                    return resp.blob().then(function(b) { return { blob: b, name: fname }; });
                })
                .then(function(r) {
                    var a = document.createElement('a');
                    a.href = URL.createObjectURL(r.blob);
                    a.download = r.name;
                    document.body.appendChild(a);
                    a.click();
                    document.body.removeChild(a);
                    URL.revokeObjectURL(a.href);
                })
                .catch(function(err) { alert('Export failed: ' + err.message); })
                .finally(function() {
                    exporting = false;
                    btnExport.disabled = false;
                    btnExport.style.opacity = '';
                    document.getElementById('btnExportText').style.display = '';
                    document.getElementById('btnExportLoader').style.display = 'none';
                });
        });
    })();

    function val(id) { return document.getElementById(id)?.value?.trim() || null; }
    function numVal(id) { var v = document.getElementById(id)?.value; return v ? parseFloat(v) : null; }
    function intVal(id) { var v = document.getElementById(id)?.value; return v ? parseInt(v, 10) : null; }
    function guidVal(id) { var v = document.getElementById(id)?.value; return v || null; }

    function collectTugOutUsages() {
        var inputs = document.querySelectorAll('.tug-out-hours-input');
        var result = [];
        for (var i = 0; i < inputs.length; i++) {
            var tugNum = parseInt(inputs[i].getAttribute('data-tug'), 10);
            var hrs = inputs[i].value ? parseFloat(inputs[i].value) : null;
            result.push({ tugNumber: tugNum, hours: hrs });
        }
        return result;
    }

    function collectBunkerSupply() {
        var inputs = document.querySelectorAll('.bunker-supply-input');
        var map = {};
        for (var i = 0; i < inputs.length; i++) {
            var fuel = inputs[i].getAttribute('data-fuel');
            var field = inputs[i].getAttribute('data-field');
            if (!map[fuel]) map[fuel] = { fuelType: fuel, qty: null, rateMts: null };
            var v = inputs[i].value ? parseFloat(inputs[i].value) : null;
            if (field === 'qty') map[fuel].qty = v;
            else if (field === 'rate') map[fuel].rateMts = v;
        }
        return Object.values(map);
    }

    function collectBunkersOnDeparture() {
        var inputs = document.querySelectorAll('.bunker-dep-input');
        var map = {};
        for (var i = 0; i < inputs.length; i++) {
            var pt = inputs[i].getAttribute('data-point');
            var fuel = inputs[i].getAttribute('data-fuel');
            if (!map[pt]) map[pt] = { readingPoint: pt, vlsfoMts: null, mgoMts: null, hfoMts: null };
            var v = inputs[i].value ? parseFloat(inputs[i].value) : null;
            if (fuel === 'vlsfo') map[pt].vlsfoMts = v;
            else if (fuel === 'mgo') map[pt].mgoMts = v;
            else if (fuel === 'hfo') map[pt].hfoMts = v;
        }
        return Object.values(map);
    }

    // ── Tug Out Usage: dynamically create/remove tug hour inputs ──
    (function() {
        var tugsOutEl = document.getElementById('tugsOut');
        var tugSection = document.getElementById('tugOutUsageSection');
        var tugRow = document.getElementById('tugOutUsageRow');

        // Pre-load existing tug usage data from server
        var existingTugs = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.TugUsages ?? new List<ContainerManagement.Application.Dtos.Voyages.TugUsageDto>()));

        function getExistingHours(tugNum) {
            for (var i = 0; i < existingTugs.length; i++) {
                if (existingTugs[i].tugNumber === tugNum) return existingTugs[i].hours;
            }
            return '';
        }

        function updateTugOutRows() {
            var count = parseInt(tugsOutEl.value, 10) || 0;
            if (count < 0) { count = 0; tugsOutEl.value = 0; }
            if (count > 5) { count = 5; tugsOutEl.value = 5; }

            tugSection.style.display = count > 0 ? '' : 'none';
            tugRow.innerHTML = '';

            for (var i = 1; i <= count; i++) {
                var col = document.createElement('div');
                col.className = 'col-auto';
                var hrs = getExistingHours(i);
                col.innerHTML =
                    '<label class="form-label" style="font-size:.72rem;">Tug ' + i + '</label>' +
                    '<input type="number" step="0.01" min="0" class="form-control form-control-sm tug-out-hours-input" ' +
                    'data-tug="' + i + '" value="' + (hrs != null && hrs !== '' ? hrs : '') + '" style="max-width:90px;" />';
                tugRow.appendChild(col);
            }
        }

        tugsOutEl.addEventListener('input', updateTugOutRows);
        tugsOutEl.addEventListener('change', updateTugOutRows);
        updateTugOutRows();
    })();

    function dmyToIso(dmy) {
        if (!dmy) return null;
        var m = dmy.match(/^(\d{2})\/(\d{2})\/(\d{4})$/);
        if (!m) return null;
        return m[3] + '-' + m[2] + '-' + m[1];
    }

    function combineDT(dateId, timeId) {
        var d = dmyToIso(document.getElementById(dateId)?.value?.trim());
        var t = document.getElementById(timeId)?.value?.trim();
        if (!d) return null;
        return t ? d + 'T' + t : d + 'T00:00';
    }

    function parseDT(dateId, timeId) {
        var v = combineDT(dateId, timeId);
        if (!v) return null;
        var dt = new Date(v);
        return isNaN(dt.getTime()) ? null : dt;
    }

    function showValidationError(msg) {
        var el = document.getElementById('timeValidationError');
        el.textContent = msg;
        el.style.display = '';
    }

    function clearValidationError() {
        var el = document.getElementById('timeValidationError');
        el.textContent = '';
        el.style.display = 'none';
    }

    function validateDates() {
        clearValidationError();
        var cargo = parseDT('compCargoOp_date', 'compCargoOp_time');
        var pilot = parseDT('pilotOnBoard_date', 'pilotOnBoard_time');
        var unberth = parseDT('unberthFAOP_date', 'unberthFAOP_time');
        var etd = parseDT('actualETD_date', 'actualETD_time');
        var etaNext = parseDT('etaNextPort_date', 'etaNextPort_time');

        if (cargo && unberth && unberth < cargo) {
            showValidationError('Unberth (FAOP) must be on or after Completed Cargo Ops.');
            return false;
        }
        if (cargo && etd && etd < cargo) {
            showValidationError('Departure (BOSP) must be on or after Completed Cargo Ops.');
            return false;
        }
        if (unberth && etd && etd < unberth) {
            showValidationError('Departure (BOSP) must be on or after Unberth (FAOP).');
            return false;
        }
        if (etd && etaNext && etaNext <= etd) {
            showValidationError('ETA Next Port must be after Departure (BOSP).');
            return false;
        }
        return true;
    }

    document.querySelectorAll('.date-dmy, .time-24')
        .forEach(function(el) { el.addEventListener('blur', validateDates); });

    function setLoading(on) {
        var btn = document.getElementById('btnSave');
        document.getElementById('btnSaveText').style.display = on ? 'none' : '';
        document.getElementById('btnSaveLoader').style.display = on ? '' : 'none';
        btn.disabled = on;
    }

    function showBunkerDepError(msg) {
        var wrap = document.getElementById('bunkerDepError');
        var span = document.getElementById('bunkerDepErrorMsg');
        span.textContent = msg;
        wrap.classList.remove('d-none');
    }

    function clearBunkerDepError() {
        var wrap = document.getElementById('bunkerDepError');
        wrap.classList.add('d-none');
        document.getElementById('bunkerDepErrorMsg').textContent = '';
    }

    function validateBunkersOnDeparture() {
        clearBunkerDepError();
        // 1. Bunker departure readings must decrease sequentially: CompleteCargo >= PilotOnBoard >= Departure
        var depPoints = ['CompleteCargo', 'PilotOnBoard', 'Departure'];
        var fuels = ['vlsfo', 'mgo', 'hfo'];
        var fuelLabels = { vlsfo: 'VLSFO', mgo: 'MGO', hfo: 'HFO' };
        var depPointLabels = { CompleteCargo: 'Complete Cargo', PilotOnBoard: 'Pilot On Board', Departure: 'Departure' };

        for (var f = 0; f < fuels.length; f++) {
            var fuel = fuels[f];
            var prev = null;
            var prevPt = null;
            for (var p = 0; p < depPoints.length; p++) {
                var el = document.querySelector('.bunker-dep-input[data-point="' + depPoints[p] + '"][data-fuel="' + fuel + '"]');
                var v = el && el.value ? parseFloat(el.value) : null;
                if (v !== null && prev !== null && v > prev) {
                    showBunkerDepError(
                        fuelLabels[fuel] + ' at "' + depPointLabels[depPoints[p]] + '" is ' + v +
                        ' mts, but it was ' + prev + ' mts at "' + depPointLabels[prevPt] + '". ' +
                        'Fuel is consumed during operations, so the quantity should decrease or remain the same at each stage.'
                    );
                    el.focus();
                    return false;
                }
                if (v !== null) { prev = v; prevPt = depPoints[p]; }
            }
        }

        // 2. Max departure quantity = Complete Cargo reading + Supply Qty
        var fuelKeys = { vlsfo: 'VLSFO', mgo: 'MGO', hfo: 'HFO' };
        for (var f = 0; f < fuels.length; f++) {
            var fuel = fuels[f];
            var fuelKey = fuelKeys[fuel];

            var baseEl = document.querySelector('.bunker-dep-input[data-point="CompleteCargo"][data-fuel="' + fuel + '"]');
            var baseline = baseEl && baseEl.value ? parseFloat(baseEl.value) : null;

            var supplyEl = document.querySelector('.bunker-supply-input[data-fuel="' + fuelKey + '"][data-field="qty"]');
            var supplyQty = supplyEl && supplyEl.value ? parseFloat(supplyEl.value) : 0;

            if (baseline !== null) {
                var maxAllowed = baseline + supplyQty;

                var checkPoints = ['PilotOnBoard', 'Departure'];
                for (var cp = 0; cp < checkPoints.length; cp++) {
                    var chkEl = document.querySelector('.bunker-dep-input[data-point="' + checkPoints[cp] + '"][data-fuel="' + fuel + '"]');
                    var chkVal = chkEl && chkEl.value ? parseFloat(chkEl.value) : null;
                    if (chkVal !== null && chkVal > maxAllowed) {
                        var msg = fuelLabels[fuel] + ' at "' + depPointLabels[checkPoints[cp]] + '" is ' + chkVal + ' mts, ';
                        if (supplyQty > 0) {
                            msg += 'which exceeds the maximum allowed of ' + maxAllowed + ' mts. ' +
                                'Calculated as: Complete Cargo (' + baseline + ' mts) + Bunker Supply (' + supplyQty + ' mts) = ' + maxAllowed + ' mts. ' +
                                'The departure quantity cannot be more than what was available after bunkering.';
                        } else {
                            msg += 'which exceeds the Complete Cargo quantity of ' + baseline + ' mts. ' +
                                'No bunker supply was received, so the quantity should only decrease from the Complete Cargo reading.';
                        }
                        showBunkerDepError(msg);
                        chkEl.focus();
                        return false;
                    }
                }
            }
        }

        return true;
    }

    // Live validation on bunker and supply inputs
    document.querySelectorAll('.bunker-dep-input, .bunker-supply-input').forEach(function(el) {
        el.addEventListener('blur', validateBunkersOnDeparture);
    });

    async function saveDeparture() {
        if (!validateDates()) return;
        if (!validateBunkersOnDeparture()) return;
        setLoading(true);

        var payload = {
            voyagePortId: val('voyagePortId'),
            inboundVoyage: val('inboundVoyage'),
            outboundVoyage: val('outboundVoyage'),
            completeCargoOperation: combineDT('compCargoOp_date', 'compCargoOp_time'),
            pilotOnBoard: combineDT('pilotOnBoard_date', 'pilotOnBoard_time'),
            unberthFAOP: combineDT('unberthFAOP_date', 'unberthFAOP_time'),
            actualETD: combineDT('actualETD_date', 'actualETD_time'),
            nextPortId: guidVal('nextPortId'),
            etaNextPort: combineDT('etaNextPort_date', 'etaNextPort_time'),
            tugsOut: intVal('tugsOut'),
            tugUsages: collectTugOutUsages(),
            depDraftFwdMtr: numVal('draftFwd'),
            depDraftAftMtr: numVal('draftAft'),
            depDraftMeanMtr: numVal('draftMean'),
            bunkerSupplies: collectBunkerSupply(),
            bunkers: collectBunkersOnDeparture(),
            freshWater: numVal('freshWater'),
            ballastWater: numVal('ballastWater'),
            remarks: val('remarks')
        };

        try {
            var resp = await fetch('@Url.Action("Departure", "Voyages")', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payload)
            });
            var result = await resp.json();
            if (result.success) {
                showToast('Departure report saved', 'success');
                document.getElementById('departureId').value = result.id;
            } else {
                showToast(result.message || 'Error saving', 'danger');
            }
        } catch (err) {
            showToast('Network error', 'danger');
        } finally {
            setLoading(false);
        }
    }

    function showToast(msg, type) {
        var t = document.getElementById('toast');
        t.className = 'toast align-items-center text-bg-' + type + ' border-0';
        document.getElementById('toastMsg').textContent = msg;
        new bootstrap.Toast(t).show();
    }

    // Auto-calc mean draft
    document.getElementById('draftFwd')?.addEventListener('input', calcMean);
    document.getElementById('draftAft')?.addEventListener('input', calcMean);
    function calcMean() {
        var fwd = parseFloat(document.getElementById('draftFwd').value);
        var aft = parseFloat(document.getElementById('draftAft').value);
        if (!isNaN(fwd) && !isNaN(aft)) {
            document.getElementById('draftMean').value = ((fwd + aft) / 2).toFixed(2);
        }
    }

    // DD/MM/YYYY date mask
    document.querySelectorAll('.date-dmy').forEach(function(el) {
        el.addEventListener('input', function() {
            var v = el.value.replace(/[^\d]/g, '');
            if (v.length > 8) v = v.slice(0, 8);
            if (v.length >= 5) v = v.slice(0, 2) + '/' + v.slice(2, 4) + '/' + v.slice(4);
            else if (v.length >= 3) v = v.slice(0, 2) + '/' + v.slice(2);
            el.value = v;
        });
        el.addEventListener('blur', function() {
            var v = el.value.trim();
            if (!v) return;
            var m = v.match(/^(\d{2})\/(\d{2})\/(\d{4})$/);
            if (!m) { el.classList.add('is-invalid'); return; }
            var dd = parseInt(m[1],10), mm = parseInt(m[2],10), yyyy = parseInt(m[3],10);
            if (mm<1||mm>12||dd<1||dd>31||yyyy<2000||yyyy>2099) { el.classList.add('is-invalid'); return; }
            var test = new Date(yyyy, mm-1, dd);
            if (test.getDate()!==dd||test.getMonth()!==mm-1) { el.classList.add('is-invalid'); return; }
            el.classList.remove('is-invalid');
        });
        el.addEventListener('focus', function() { el.classList.remove('is-invalid'); });
    });

    // 24-hour time mask
    document.querySelectorAll('.time-24').forEach(function(el) {
        el.addEventListener('input', function() {
            var v = el.value.replace(/[^\d]/g, '');
            if (v.length > 4) v = v.slice(0, 4);
            if (v.length >= 3) v = v.slice(0, 2) + ':' + v.slice(2);
            el.value = v;
        });
        el.addEventListener('blur', function() {
            var v = el.value.trim();
            if (!v) return;
            var m = v.match(/^(\d{1,2}):(\d{2})$/);
            if (!m) { el.value = ''; el.classList.add('is-invalid'); return; }
            var hh = parseInt(m[1],10), mm = parseInt(m[2],10);
            if (hh>23||mm>59) { el.value = ''; el.classList.add('is-invalid'); return; }
            el.value = ('0'+hh).slice(-2)+':'+('0'+mm).slice(-2);
            el.classList.remove('is-invalid');
        });
        el.addEventListener('focus', function() { el.classList.remove('is-invalid'); });
    });
</script>
}
