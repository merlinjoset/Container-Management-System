@using Microsoft.AspNetCore.Mvc.Rendering
@{
    ViewData["Title"] = "Voyage";
    ViewData["ShowNew"] = false;
    ViewData["ShowExport"] = false;
    ViewData["ShowImport"] = false;
}

@section Styles{
    <link rel="stylesheet" href="~/css/ui-common.css" asp-append-version="true" />
    <style>
        /* ── Voyage header form ── */
        .voy-header { background: #fff; border: 1px solid #e5e7eb; border-radius: .5rem; padding: 1rem 1.25rem; margin-bottom: .75rem; }
        .voy-header .voy-row { display: flex; flex-wrap: wrap; gap: 1rem; align-items: center; }
        .voy-header .voy-field { display: flex; align-items: center; gap: .35rem; }
        .voy-header .voy-field label { font-size: .75rem; font-weight: 600; color: #1e3a8a; white-space: nowrap; min-width: 90px; }
        .voy-header .voy-field select,
        .voy-header .voy-field input { font-size: .75rem; padding: .3rem .5rem; border: 1px solid #cbd5e1; border-radius: .25rem; min-width: 180px; }
        .voy-header .voy-field select { background: #e0f2fe; }

        /* ── Port rotation grid ── */
        .voy-grid-wrap { border: 1px solid #e5e7eb; border-radius: .5rem; overflow: hidden; background: #fff; }
        .voy-grid-header { background: #1e3a8a; color: #fff; padding: .4rem .75rem; font-size: .8rem; font-weight: 600; display: flex; align-items: center; justify-content: space-between; }
        .voy-grid table { width: 100%; border-collapse: collapse; font-size: .75rem; }
        .voy-grid thead th {
            background: #312e81; color: #fff; padding: .4rem .5rem; font-weight: 600;
            white-space: nowrap; position: sticky; top: 0; z-index: 2; font-size: .72rem; text-align: center;
        }
        .voy-grid tbody td { padding: .25rem .3rem; border-bottom: 1px solid #f1f5f9; vertical-align: middle; }
        .voy-grid tbody tr:hover { background: #eff6ff; }
        .voy-grid tbody tr.first-row .voy-eta { background: #fff !important; }
        .voy-grid input, .voy-grid select {
            font-size: .73rem; padding: .2rem .35rem; border: 1px solid #cbd5e1;
            border-radius: .2rem; width: 100%; box-sizing: border-box;
        }
        .voy-grid select { background: #e0f2fe; }
        .voy-grid .voy-eta, .voy-grid .voy-etb, .voy-grid .voy-etd { min-width: 140px; }
        .voy-grid input[type="number"] { min-width: 65px; }
        .voy-grid .voy-port-select { min-width: 150px; }
        .voy-grid .voy-terminal-select { min-width: 130px; }
        .voy-grid .col-row-num { width: 32px; text-align: center; font-weight: 700; color: #1e3a8a; }
        .voy-grid .col-action { width: 32px; text-align: center; }
        .voy-grid .btn-remove-row { background: none; border: none; color: #ef4444; cursor: pointer; font-size: .85rem; padding: .1rem .25rem; }
        .voy-grid .btn-remove-row:hover { color: #dc2626; }
        .voy-grid .readonly-cell { background: #f1f5f9 !important; }
        .voy-grid .grid-scroll { max-height: 60vh; overflow: auto; }

        /* ── Action bar ── */
        .voy-actions { display: flex; gap: .5rem; padding: .75rem 0; }
        .voy-btn { padding: .4rem 1rem; border: none; border-radius: .25rem; font-size: .8rem; font-weight: 600; cursor: pointer; display: flex; align-items: center; gap: .3rem; }
        .voy-btn-save { background: #22c55e; color: #fff; }
        .voy-btn-save:hover { background: #16a34a; }
        .voy-btn-cancel { background: #6b7280; color: #fff; }
        .voy-btn-cancel:hover { background: #4b5563; }
    </style>
}

<div class="operator-page">
    <div class="page-header">Voyage</div>

    <div id="voy-message-container"></div>

    <div class="content" style="flex-direction: column; max-width: 100%;">
        <div style="width: 100%;">

            @* ── Header Form ── *@
            <div class="voy-header">
                <div class="voy-row">
                    <div class="voy-field">
                        <label>Vessel Name</label>
                        <select id="voy-vessel">
                            <option value="">-- Select Vessel --</option>
                            @if (ViewBag.Vessels is IEnumerable<SelectListItem> vesselItems)
                            { foreach (var v in vesselItems){ <option value="@v.Value">@v.Text</option> } }
                        </select>
                    </div>
                    <div class="voy-field">
                        <label>Service Code</label>
                        <select id="voy-service">
                            <option value="">-- Select Service --</option>
                            @if (ViewBag.Services is IEnumerable<SelectListItem> serviceItems)
                            { foreach (var s in serviceItems){ <option value="@s.Value">@s.Text</option> } }
                        </select>
                    </div>
                    <div class="voy-field">
                        <label>Service Name</label>
                        <input type="text" id="voy-service-name" readonly placeholder="(auto)" style="background:#f1f5f9;" />
                    </div>
                </div>
                <div class="voy-row" style="margin-top: .75rem;">
                    <div class="voy-field">
                        <label>OPR</label>
                        <select id="voy-operator">
                            <option value="">-- Select Operator --</option>
                            @if (ViewBag.Operators is IEnumerable<SelectListItem> operatorItems)
                            { foreach (var o in operatorItems){ <option value="@o.Value">@o.Text</option> } }
                        </select>
                    </div>
                    <div class="voy-field">
                        <label>Slot</label>
                        <select id="voy-type">
                            <option value="">-- Select --</option>
                            <option value="Own">Own</option>
                            <option value="Third Party">Third Party</option>
                            <option value="Dead Freight">Dead Freight</option>
                            <option value="Slot Swap">Slot Swap</option>
                            <option value="Vessel Swap">Vessel Swap</option>
                        </select>
                    </div>
                </div>
            </div>

            @* ── Port Rotation Grid ── *@
            <div class="voy-grid-wrap">
                <div class="voy-grid-header">
                    <span>Port Rotations</span>
                    <button class="btn btn-sm btn-warning fw-bold" id="btn-add-port" style="font-size:.72rem;"><i class="bi bi-plus-lg"></i> Add Row</button>
                </div>
                <div class="voy-grid">
                    <div class="grid-scroll">
                        <table>
                            <thead>
                                <tr>
                                    <th>#</th>
                                    <th>Voy No</th>
                                    <th>Bound</th>
                                    <th>Port</th>
                                    <th>Terminal</th>
                                    <th>ETA</th>
                                    <th>ETB</th>
                                    <th>ETD</th>
                                    <th>Port Stay</th>
                                    <th>Speed</th>
                                    <th>Distance</th>
                                    <th>Sea Day</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody id="voy-port-body">
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            @* ── Action Buttons ── *@
            <div class="voy-actions">
                <button class="voy-btn voy-btn-save" id="btn-save-voyage"><i class="bi bi-check-lg"></i> Save Voyage</button>
                <a class="voy-btn voy-btn-cancel" asp-action="Index"><i class="bi bi-x-lg"></i> Cancel</a>
            </div>

        </div>
    </div>
</div>

@section Scripts{
    <script>
        (function() {
            var portBody = document.getElementById('voy-port-body');
            var rowCounter = 0;

            // ── Inline message helper ──
            var msgContainer = document.getElementById('voy-message-container');
            function showMessage(type, text) {
                var isArray = Array.isArray(text);
                var content = '';
                if (isArray) {
                    content = '<ul class="mb-0 ps-3">';
                    for (var i = 0; i < text.length; i++) {
                        content += '<li>' + text[i] + '</li>';
                    }
                    content += '</ul>';
                } else {
                    content = '<span>' + text + '</span>';
                }
                msgContainer.innerHTML =
                    '<div class="alert alert-' + type + ' alert-dismissible fade show d-flex align-items-start" role="alert" style="font-size:.82rem;">' +
                    content +
                    '<button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close" style="font-size:.7rem;"></button>' +
                    '</div>';
                msgContainer.scrollIntoView({ behavior: 'smooth', block: 'start' });
                if (type === 'success') {
                    setTimeout(function() {
                        var al = msgContainer.querySelector('.alert');
                        if (al) al.remove();
                    }, 5000);
                }
            }

            // Build ports and terminals options HTML once
            var portsOptions = '<option value="">--</option>';
            @if (ViewBag.Ports is IEnumerable<SelectListItem> pItems) {
                foreach (var p in pItems) {
                    <text>portsOptions += '<option value="@p.Value">@Html.Raw(p.Text?.Replace("'", "\\'"))</option>';</text>
                }
            }

            var terminalsOptions = '<option value="">--</option>';
            @if (ViewBag.Terminals is IEnumerable<SelectListItem> tItems) {
                foreach (var t in tItems) {
                    <text>terminalsOptions += '<option value="@t.Value">@Html.Raw(t.Text?.Replace("'", "\\'"))</option>';</text>
                }
            }

            // Service name auto-fill
            var serviceData = {};
            @if (ViewBag.Services is IEnumerable<SelectListItem> svcItems) {
                foreach (var s in svcItems) {
                    <text>serviceData['@s.Value'] = '@Html.Raw(s.Text?.Replace("'", "\\'"))';</text>
                }
            }
            document.getElementById('voy-service').addEventListener('change', function() {
                var sn = serviceData[this.value] || '';
                document.getElementById('voy-service-name').value = sn;
            });

            // Distance lookup from Distance Master (FromPortId|ToPortId → distance)
            var distanceMap = {};
            @if (ViewBag.Distances is System.Collections.IEnumerable distItems) {
                foreach (var d in distItems)
                {
                    var dt = d.GetType();
                    var fromId = dt.GetProperty("FromPortId")?.GetValue(d)?.ToString() ?? "";
                    var toId = dt.GetProperty("ToPortId")?.GetValue(d)?.ToString() ?? "";
                    var dist = dt.GetProperty("Distance")?.GetValue(d)?.ToString() ?? "0";
                    <text>distanceMap['@fromId|@toId'] = @dist;</text>
                }
            }
            function lookupDistance(fromPortId, toPortId) {
                if (!fromPortId || !toPortId) return null;
                var key = fromPortId + '|' + toPortId;
                if (distanceMap[key] != null) return distanceMap[key];
                var rev = toPortId + '|' + fromPortId;
                if (distanceMap[rev] != null) return distanceMap[rev];
                return null;
            }
            function autoFillDistance(tr) {
                var allRows = Array.from(document.querySelectorAll('#port-body tr.port-row'));
                var idx = allRows.indexOf(tr);
                if (idx <= 0) return;
                var prevPortId = allRows[idx - 1].querySelector('.voy-port')?.value;
                var thisPortId = tr.querySelector('.voy-port')?.value;
                var dist = lookupDistance(prevPortId, thisPortId);
                if (dist != null) {
                    var distInput = tr.querySelector('.voy-distance');
                    distInput.value = dist;
                    distInput.dispatchEvent(new Event('change', { bubbles: true }));
                }
            }

            // ── Helpers for date ↔ display string (dd/MM/yyyy HH:mm) ──
            function toLocal(dt) {
                if (!dt) return '';
                var dd = ('0' + dt.getDate()).slice(-2);
                var mm = ('0' + (dt.getMonth() + 1)).slice(-2);
                var y = dt.getFullYear();
                var h = ('0' + dt.getHours()).slice(-2);
                var mi = ('0' + dt.getMinutes()).slice(-2);
                return dd + '/' + mm + '/' + y + ' ' + h + ':' + mi;
            }
            function parseLocal(s) {
                if (!s) return null;
                s = s.trim();
                // dd/MM/yyyy HH:mm
                var m = s.match(/^(\d{2})\/(\d{2})\/(\d{4})\s+(\d{2}):(\d{2})/);
                if (m) return new Date(parseInt(m[3]), parseInt(m[2]) - 1, parseInt(m[1]), parseInt(m[4]), parseInt(m[5]));
                // ISO fallback: yyyy-MM-ddTHH:mm
                var d = new Date(s);
                return isNaN(d.getTime()) ? null : d;
            }
            function toIso(s) {
                var d = parseLocal(s);
                if (!d) return null;
                var y = d.getFullYear();
                var mo = ('0' + (d.getMonth() + 1)).slice(-2);
                var dd = ('0' + d.getDate()).slice(-2);
                var h = ('0' + d.getHours()).slice(-2);
                var mi = ('0' + d.getMinutes()).slice(-2);
                return y + '-' + mo + '-' + dd + 'T' + h + ':' + mi;
            }

            // ── Auto-format datetime as user types (dd/MM/yyyy HH:mm) ──
            function wireDateMask(input) {
                input.addEventListener('input', function(e) {
                    if (e.inputType === 'deleteContentBackward' || e.inputType === 'deleteContentForward') return;
                    var raw = input.value.replace(/[^\d]/g, ''); // digits only
                    var out = '';
                    for (var i = 0; i < raw.length && i < 12; i++) {
                        if (i === 2 || i === 4) out += '/';
                        if (i === 8) out += ' ';
                        if (i === 10) out += ':';
                        out += raw[i];
                    }
                    if (out !== input.value) {
                        var pos = out.length;
                        input.value = out;
                        input.setSelectionRange(pos, pos);
                    }
                });
            }

            // ── Formula calculations (exact Excel formulas) ──
            // I = K/J/24           → Sea Day = Distance / Speed / 24
            // F = E + 2/24         → ETB = ETA + 2/24
            // G = F + H            → ETD = ETB + PortStay
            // E(next) = G + I      → Next ETA = current ETD + current SeaDay

            function calcRow(tr) {
                var speed = parseFloat(tr.querySelector('.voy-speed').value) || 0;
                var distance = parseFloat(tr.querySelector('.voy-distance').value) || 0;
                var seaDayEl = tr.querySelector('.voy-seaday');

                // I = K/J/24  →  Sea Day = Distance / Speed / 24
                if (speed > 0 && distance > 0) {
                    seaDayEl.value = (distance / speed / 24).toFixed(4);
                }

                var eta = parseLocal(tr.querySelector('.voy-eta').value);

                // F = E + 2/24  →  ETB = ETA + 2/24 days (2 hours)
                if (eta) {
                    var etb = new Date(eta.getTime() + (2 / 24) * 86400000);
                    tr.querySelector('.voy-etb').value = toLocal(etb);

                    // G = F + H  →  ETD = ETB + PortStay
                    var portStay = parseInt(tr.querySelector('.voy-portstay').value) || 0;
                    if (portStay > 0) {
                        var etd = new Date(etb.getTime() + portStay * 86400000);
                        tr.querySelector('.voy-etd').value = toLocal(etd);
                    }
                }

                // Propagate to next row
                calcNextRowEta(tr);
            }

            // E(next) = G + I  →  Next ETA = current ETD + current SeaDay
            function calcNextRowEta(tr) {
                var rows = Array.prototype.slice.call(portBody.querySelectorAll('tr.port-row'));
                var idx = rows.indexOf(tr);
                if (idx < 0 || idx >= rows.length - 1) return;

                var etd = parseLocal(tr.querySelector('.voy-etd').value);
                var seaDay = parseFloat(tr.querySelector('.voy-seaday').value) || 0;

                if (etd && seaDay > 0) {
                    var nextEta = new Date(etd.getTime() + seaDay * 86400000);
                    var nextTr = rows[idx + 1];
                    nextTr.querySelector('.voy-eta').value = toLocal(nextEta);
                    // cascade: recalc the next row too
                    calcRow(nextTr);
                }
            }

            // ── Paste support: convert ISO formats to dd/MM/yyyy HH:mm on paste ──
            function wirePaste(input, tr) {
                input.addEventListener('paste', function(e) {
                    var pasted = (e.clipboardData || window.clipboardData).getData('text');
                    if (!pasted) return;
                    pasted = pasted.trim();
                    // If pasted text is in ISO format, convert to display format
                    var d = parseLocal(pasted);
                    if (!d) {
                        d = new Date(pasted);
                        if (isNaN(d.getTime())) return; // let native paste handle it
                    }
                    e.preventDefault();
                    input.value = toLocal(d);
                    input.dispatchEvent(new Event('change', { bubbles: true }));
                });
            }

            function wireRowEvents(tr) {
                var fields = ['voy-eta', 'voy-portstay', 'voy-speed', 'voy-distance'];
                for (var i = 0; i < fields.length; i++) {
                    var el = tr.querySelector('.' + fields[i]);
                    if (el) {
                        el.addEventListener('change', function() { calcRow(tr); });
                    }
                }
                // Auto-fill Distance from Distance Master when this row's Port changes
                var portSel = tr.querySelector('.voy-port');
                if (portSel) {
                    portSel.addEventListener('change', function() { autoFillDistance(tr); });
                }
                // Paste support for ETA (only editable on first row, mask wired below)
                wirePaste(tr.querySelector('.voy-eta'), tr);
                wireDateMask(tr.querySelector('.voy-eta'));
                // Also recalc when ETB or ETD manually changed
                tr.querySelector('.voy-etb').addEventListener('change', function() {
                    var etb = parseLocal(this.value);
                    var portStay = parseInt(tr.querySelector('.voy-portstay').value) || 0;
                    if (etb && portStay > 0) {
                        var etd = new Date(etb.getTime() + portStay * 86400000);
                        tr.querySelector('.voy-etd').value = toLocal(etd);
                    }
                    calcNextRowEta(tr);
                });
                tr.querySelector('.voy-etd').addEventListener('change', function() {
                    calcNextRowEta(tr);
                });
            }

            // ── Add port row ──
            function addRow() {
                rowCounter++;
                var tr = document.createElement('tr');
                tr.className = 'port-row';
                tr.innerHTML =
                    '<td class="col-row-num">' + rowCounter + '</td>' +
                    '<td><input type="text" class="voy-no" placeholder="Voy No" /></td>' +
                    '<td><select class="voy-bound"><option value="">--</option><option value="West">West</option><option value="East">East</option></select></td>' +
                    '<td><select class="voy-port voy-port-select">' + portsOptions + '</select></td>' +
                    '<td><select class="voy-terminal voy-terminal-select">' + terminalsOptions + '</select></td>' +
                    '<td><input type="text" class="voy-eta" placeholder="dd/mm/yyyy hh:mm" /></td>' +
                    '<td><input type="text" class="voy-etb readonly-cell" placeholder="dd/mm/yyyy hh:mm" readonly /></td>' +
                    '<td><input type="text" class="voy-etd readonly-cell" placeholder="dd/mm/yyyy hh:mm" readonly /></td>' +
                    '<td><input type="number" class="voy-portstay" min="0" step="1" placeholder="0" /></td>' +
                    '<td><input type="number" class="voy-speed" min="0" step="0.1" value="14.5" /></td>' +
                    '<td><input type="number" class="voy-distance" min="0" step="0.01" placeholder="0" /></td>' +
                    '<td><input type="number" class="voy-seaday readonly-cell" min="0" step="any" placeholder="0" readonly /></td>' +
                    '<td class="col-action"><button class="btn-remove-row" title="Remove"><i class="bi bi-trash"></i></button></td>';

                tr.querySelector('.btn-remove-row').addEventListener('click', function() {
                    tr.remove();
                    renumberRows();
                });

                wireRowEvents(tr);
                portBody.appendChild(tr);

                // 2nd+ port: ETA is auto-calculated, so readonly
                updateEtaState();

                // If 2nd+ row, carry over Voy No & Bound, then calc ETA from previous
                var allRows = portBody.querySelectorAll('tr.port-row');
                if (allRows.length > 1) {
                    var prevRow = allRows[allRows.length - 2];

                    var prevVoyNo = prevRow.querySelector('.voy-no').value;
                    if (prevVoyNo) tr.querySelector('.voy-no').value = prevVoyNo;

                    var prevBound = prevRow.querySelector('.voy-bound').value;
                    if (prevBound) tr.querySelector('.voy-bound').value = prevBound;

                    var prevEtd = parseLocal(prevRow.querySelector('.voy-etd').value);
                    var prevSeaDay = parseFloat(prevRow.querySelector('.voy-seaday').value) || 0;
                    if (prevEtd && prevSeaDay > 0) {
                        var newEta = new Date(prevEtd.getTime() + prevSeaDay * 86400000);
                        tr.querySelector('.voy-eta').value = toLocal(newEta);
                        calcRow(tr);
                    }
                }
            }

            function updateEtaState() {
                var rows = portBody.querySelectorAll('tr.port-row');
                for (var i = 0; i < rows.length; i++) {
                    var etaEl = rows[i].querySelector('.voy-eta');
                    if (i === 0) {
                        etaEl.classList.remove('readonly-cell');
                        etaEl.readOnly = false;
                    } else {
                        etaEl.classList.add('readonly-cell');
                        etaEl.readOnly = true;
                    }
                }
            }

            function renumberRows() {
                var rows = portBody.querySelectorAll('tr.port-row');
                for (var i = 0; i < rows.length; i++) {
                    var numCell = rows[i].querySelector('.col-row-num');
                    if (numCell) numCell.textContent = (i + 1);
                }
                rowCounter = rows.length;
                updateEtaState();
            }

            document.getElementById('btn-add-port').addEventListener('click', addRow);

            // Start with 1 empty row
            addRow();

            // ── Anti-forgery token ──
            function token() {
                var el = document.querySelector('input[name="__RequestVerificationToken"]');
                return el ? el.value : '';
            }

            // ── Validation helpers ──
            function isValidDate(val) {
                if (!val || !val.trim()) return false;
                return parseLocal(val) !== null;
            }
            function highlightField(el, invalid) {
                el.style.border = invalid ? '2px solid #dc3545' : '';
            }
            function validateForm() {
                var errors = [];

                // ── Header validation ──
                var vesselEl = document.getElementById('voy-vessel');
                var serviceEl = document.getElementById('voy-service');
                var operatorEl = document.getElementById('voy-operator');
                var slotEl = document.getElementById('voy-type');

                highlightField(vesselEl, false);
                highlightField(serviceEl, false);
                highlightField(operatorEl, false);
                highlightField(slotEl, false);

                if (!vesselEl.value) { highlightField(vesselEl, true); errors.push('Vessel is required.'); }
                if (!serviceEl.value) { highlightField(serviceEl, true); errors.push('Service is required.'); }
                if (!operatorEl.value) { highlightField(operatorEl, true); errors.push('Operator is required.'); }
                if (!slotEl.value) { highlightField(slotEl, true); errors.push('Slot is required.'); }

                // ── Row validation ──
                var rows = portBody.querySelectorAll('tr.port-row');
                for (var i = 0; i < rows.length; i++) {
                    var r = rows[i];
                    var rowNum = i + 1;
                    var voyNoEl = r.querySelector('.voy-no');
                    var boundEl = r.querySelector('.voy-bound');
                    var portEl = r.querySelector('.voy-port');
                    var etaEl = r.querySelector('.voy-eta');
                    var etbEl = r.querySelector('.voy-etb');
                    var etdEl = r.querySelector('.voy-etd');

                    // Reset highlights
                    [voyNoEl, boundEl, portEl, etaEl, etbEl, etdEl].forEach(function(el) { if (el) highlightField(el, false); });

                    // Required fields (user-editable)
                    if (voyNoEl && !voyNoEl.value.trim()) { highlightField(voyNoEl, true); errors.push('Row ' + rowNum + ': Voy No is required.'); }
                    if (boundEl && !boundEl.value.trim()) { highlightField(boundEl, true); errors.push('Row ' + rowNum + ': Bound is required.'); }
                    if (portEl && !portEl.value) { highlightField(portEl, true); errors.push('Row ' + rowNum + ': Port is required.'); }

                    // ETA: required on first row (user enters), auto-calc on 2nd+
                    if (i === 0 && etaEl && !etaEl.value.trim()) {
                        highlightField(etaEl, true); errors.push('Row ' + rowNum + ': ETA is required.');
                    } else if (etaEl && etaEl.value.trim() && !isValidDate(etaEl.value)) {
                        highlightField(etaEl, true); errors.push('Row ' + rowNum + ': ETA has invalid format. Use dd/mm/yyyy hh:mm');
                    }

                    // ETB: formula-driven (readonly), validate format only if has value
                    if (etbEl && etbEl.value.trim() && !isValidDate(etbEl.value)) {
                        highlightField(etbEl, true); errors.push('Row ' + rowNum + ': ETB has invalid format. Use dd/mm/yyyy hh:mm');
                    }

                    // ETD: formula-driven (readonly), validate format only if has value
                    if (etdEl && etdEl.value.trim() && !isValidDate(etdEl.value)) {
                        highlightField(etdEl, true); errors.push('Row ' + rowNum + ': ETD has invalid format. Use dd/mm/yyyy hh:mm');
                    }

                    // Validate date sequence: ETA < ETB < ETD
                    var eta = parseLocal(etaEl ? etaEl.value : '');
                    var etb = parseLocal(etbEl ? etbEl.value : '');
                    var etd = parseLocal(etdEl ? etdEl.value : '');

                    if (eta && etb && etb <= eta) {
                        highlightField(etbEl, true);
                        errors.push('Row ' + rowNum + ': ETB must be after ETA');
                    }
                    if (etb && etd && etd <= etb) {
                        highlightField(etdEl, true);
                        errors.push('Row ' + rowNum + ': ETD must be after ETB');
                    }
                    if (eta && etd && !etb && etd <= eta) {
                        highlightField(etdEl, true);
                        errors.push('Row ' + rowNum + ': ETD must be after ETA');
                    }
                }

                return errors;
            }

            // ── Save Voyage ──
            document.getElementById('btn-save-voyage').addEventListener('click', function() {

                // Run validation
                var valErrors = validateForm();
                if (valErrors.length > 0) {
                    showMessage('danger', valErrors);
                    return;
                }

                var vesselId = document.getElementById('voy-vessel').value;
                var serviceId = document.getElementById('voy-service').value || null;
                var operatorId = document.getElementById('voy-operator').value || null;
                var voyageType = document.getElementById('voy-type').value || null;

                var ports = [];
                var rows = portBody.querySelectorAll('tr.port-row');
                for (var i = 0; i < rows.length; i++) {
                    var r = rows[i];
                    var portId = r.querySelector('.voy-port') ? r.querySelector('.voy-port').value : '';
                    if (!portId) continue;

                    ports.push({
                        voyNo: r.querySelector('.voy-no') ? r.querySelector('.voy-no').value : '',
                        bound: r.querySelector('.voy-bound') ? r.querySelector('.voy-bound').value : '',
                        portId: portId,
                        terminalId: r.querySelector('.voy-terminal') ? r.querySelector('.voy-terminal').value || null : null,
                        eta: toIso(r.querySelector('.voy-eta').value),
                        etb: toIso(r.querySelector('.voy-etb').value),
                        etd: toIso(r.querySelector('.voy-etd').value),
                        portStay: r.querySelector('.voy-portstay') ? parseInt(r.querySelector('.voy-portstay').value) || null : null,
                        seaDay: r.querySelector('.voy-seaday') ? parseFloat(r.querySelector('.voy-seaday').value) || null : null,
                        speed: r.querySelector('.voy-speed') ? parseFloat(r.querySelector('.voy-speed').value) || null : null,
                        distance: r.querySelector('.voy-distance') ? parseFloat(r.querySelector('.voy-distance').value) || null : null,
                        sortOrder: i + 1
                    });
                }

                var payload = {
                    vesselId: vesselId,
                    serviceId: serviceId,
                    operatorId: operatorId,
                    voyageType: voyageType,
                    ports: ports
                };

                fetch('@Url.Action("Create", "Voyages")', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': token()
                    },
                    body: JSON.stringify(payload)
                })
                .then(function(res) { return res.json(); })
                .then(function(data) {
                    if (data.success) {
                        showMessage('success', 'Voyage saved successfully!');
                        setTimeout(function() { window.location.href = '@Url.Action("Index", "Voyages")'; }, 1500);
                    } else {
                        showMessage('danger', 'Error: ' + (data.message || 'Unknown error'));
                    }
                })
                .catch(function(err) {
                    showMessage('danger', 'Error saving voyage: ' + err.message);
                });
            });

        })();
    </script>
}
