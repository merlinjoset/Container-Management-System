@model IEnumerable<ContainerManagement.Application.Dtos.Jobs.JobListItemDto>
@{
    ViewData["Title"] = "Job Dashboard";
    var todo = Model.Where(j => j.Status == 0).OrderByDescending(j => j.CreatedOn).ToList();
    var inProgress = Model.Where(j => j.Status == 1).OrderByDescending(j => j.CreatedOn).ToList();
    var done = Model.Where(j => j.Status == 2).OrderByDescending(j => j.CompletedDate ?? j.ModifiedOn).ToList();
    var recentlyCompleted = done.Take(10).ToList();
}

@section Styles {
<style>
    .kanban-board { display: flex; gap: 1.25rem; align-items: flex-start; }
    .kanban-col { flex: 1; min-width: 0; background: #f8f9fa; border-radius: .75rem; padding: 1rem; min-height: 400px; }
    .kanban-col-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem; padding-bottom: .75rem; border-bottom: 3px solid #dee2e6; }
    .kanban-col[data-status="0"] .kanban-col-header { border-color: #ef4444; }
    .kanban-col[data-status="0"] .kanban-col-title { color: #ef4444; }
    .kanban-col[data-status="1"] .kanban-col-header { border-color: #3b82f6; }
    .kanban-col[data-status="1"] .kanban-col-title { color: #3b82f6; }
    .kanban-col[data-status="2"] .kanban-col-header { border-color: #22c55e; }
    .kanban-col[data-status="2"] .kanban-col-title { color: #22c55e; }
    .kanban-col-title { font-weight: 600; font-size: .95rem; }
    .kanban-col-count { background: #e5e7eb; color: #374151; font-size: .75rem; font-weight: 600; border-radius: 999px; padding: .15rem .55rem; }
    .kanban-card { background: #fff; border-radius: .5rem; padding: .85rem 1rem; margin-bottom: .65rem; box-shadow: 0 1px 3px rgba(0,0,0,.08); cursor: grab; transition: box-shadow .15s, transform .15s; border: 1px solid #e5e7eb; }
    .kanban-card:hover { box-shadow: 0 4px 12px rgba(0,0,0,.12); }
    .kanban-card.dragging { opacity: .5; transform: rotate(2deg); }
    .kanban-card-title { font-size: .85rem; font-weight: 500; color: #1f2937; margin-bottom: .4rem; }
    .kanban-card-meta { display: flex; justify-content: space-between; align-items: center; }
    .kanban-card-tag { font-size: .65rem; font-weight: 600; padding: .15rem .45rem; border-radius: .25rem; color: #fff; text-transform: uppercase; letter-spacing: .3px; }
    .kanban-card-att { font-size: .65rem; color: #6b7280; }
    .kanban-card-date { font-size: .7rem; color: #9ca3af; }
    .kanban-card-desc { font-size: .75rem; color: #6b7280; margin-top: .35rem; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
    .kanban-card-thumbs { display: flex; gap: .35rem; margin: .4rem 0; }
    .kanban-thumb { height: 40px; border-radius: .25rem; object-fit: cover; border: 1px solid #e5e7eb; }
    .kanban-card-actions { display: none; gap: .35rem; margin-top: .5rem; }
    .kanban-card:hover .kanban-card-actions { display: flex; }
    .kanban-card-actions button { font-size: .65rem; padding: .15rem .4rem; }
    .kanban-drop-zone { min-height: 60px; border: 2px dashed transparent; border-radius: .5rem; transition: border-color .2s, background .2s; }
    .kanban-drop-zone.drag-over { border-color: #3b82f6; background: rgba(59,130,246,.05); }
    .dashboard-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem; flex-wrap: wrap; gap: .75rem; }
    .dashboard-header h4 { margin: 0; font-weight: 700; color: #1e293b; }
    .dashboard-header .last-updated { font-size: .8rem; color: #9ca3af; }
    .recently-completed { margin-top: 2rem; }
    .recently-completed th { font-size: .75rem; text-transform: uppercase; color: #6b7280; letter-spacing: .5px; }
    .recently-completed td { font-size: .8rem; vertical-align: middle; }
    .tag-color-preview { width: 14px; height: 14px; border-radius: 3px; display: inline-block; border: 1px solid rgba(0,0,0,.1); cursor: pointer; }
    .tag-colors { display: flex; gap: .35rem; flex-wrap: wrap; }
    .tag-colors .tag-color-preview.active { outline: 2px solid #3b82f6; outline-offset: 1px; }

    /* Attachment styles */
    .att-section { border-top: 1px solid #e5e7eb; padding-top: .75rem; margin-top: .75rem; }
    .att-section-title { font-size: .8rem; font-weight: 600; color: #374151; margin-bottom: .5rem; }
    .att-list { display: flex; flex-wrap: wrap; gap: .5rem; margin-bottom: .5rem; }
    .att-item { position: relative; border: 1px solid #e5e7eb; border-radius: .35rem; overflow: hidden; }
    .att-item-img { width: 80px; height: 60px; object-fit: cover; display: block; cursor: pointer; }
    .att-item-file { display: flex; align-items: center; gap: .35rem; padding: .35rem .5rem; font-size: .7rem; color: #374151; max-width: 160px; }
    .att-item-file span { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .att-item-delete { position: absolute; top: 2px; right: 2px; background: rgba(0,0,0,.5); color: #fff; border: none; border-radius: 50%; width: 18px; height: 18px; font-size: .6rem; display: flex; align-items: center; justify-content: center; cursor: pointer; opacity: 0; transition: opacity .15s; }
    .att-item:hover .att-item-delete { opacity: 1; }
    .att-upload-row { display: flex; gap: .5rem; align-items: center; flex-wrap: wrap; }
    .paste-zone { border: 2px dashed #d1d5db; border-radius: .35rem; padding: .5rem .75rem; font-size: .7rem; color: #9ca3af; text-align: center; cursor: pointer; transition: border-color .2s, background .2s; flex: 1; min-width: 150px; }
    .paste-zone:focus, .paste-zone.active { border-color: #3b82f6; background: rgba(59,130,246,.05); outline: none; }
    .paste-zone.uploading { opacity: .5; pointer-events: none; }
</style>
}

<div class="operator-page">
    <!-- Header -->
    <div class="dashboard-header">
        <div class="d-flex align-items-center gap-3">
            <h4><i class="bi bi-kanban me-2"></i>Job Dashboard</h4>
            <span class="last-updated">Last updated: @DateTime.Now.ToString("MMM dd, yyyy")</span>
        </div>
        <button class="btn btn-dark btn-sm" data-bs-toggle="modal" data-bs-target="#jobModal" onclick="openCreateModal()">
            <i class="bi bi-plus-lg me-1"></i> New Task
        </button>
    </div>

    <!-- Kanban Board -->
    <div class="kanban-board">
        <!-- To Do -->
        <div class="kanban-col" data-status="0">
            <div class="kanban-col-header">
                <span class="kanban-col-title">To Do</span>
                <span class="kanban-col-count" id="countTodo">@todo.Count</span>
            </div>
            <div class="kanban-drop-zone" id="colTodo" ondrop="dropCard(event)" ondragover="dragOver(event)" ondragleave="dragLeave(event)">
                @foreach (var job in todo)
                {
                    @await Html.PartialAsync("_JobCard", job)
                }
            </div>
        </div>

        <!-- In Progress -->
        <div class="kanban-col" data-status="1">
            <div class="kanban-col-header">
                <span class="kanban-col-title">In Progress</span>
                <span class="kanban-col-count" id="countInProgress">@inProgress.Count</span>
            </div>
            <div class="kanban-drop-zone" id="colInProgress" ondrop="dropCard(event)" ondragover="dragOver(event)" ondragleave="dragLeave(event)">
                @foreach (var job in inProgress)
                {
                    @await Html.PartialAsync("_JobCard", job)
                }
            </div>
        </div>

        <!-- Done -->
        <div class="kanban-col" data-status="2">
            <div class="kanban-col-header">
                <span class="kanban-col-title">Done</span>
                <span class="kanban-col-count" id="countDone">@done.Count</span>
            </div>
            <div class="kanban-drop-zone" id="colDone" ondrop="dropCard(event)" ondragover="dragOver(event)" ondragleave="dragLeave(event)">
                @foreach (var job in done)
                {
                    @await Html.PartialAsync("_JobCard", job)
                }
            </div>
        </div>
    </div>

    <!-- Recently Completed -->
    @if (recentlyCompleted.Any())
    {
        <div class="recently-completed">
            <h6 class="fw-bold text-muted mb-3">Recently Completed</h6>
            <div class="table-responsive">
                <table class="table table-sm table-hover">
                    <thead>
                        <tr>
                            <th style="width:120px">Date</th>
                            <th>Task</th>
                            <th style="width:120px">Tag</th>
                            <th>Details</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var job in recentlyCompleted)
                        {
                            <tr>
                                <td>@(job.CompletedDate?.ToString("MMM dd, yyyy") ?? job.ModifiedOn.ToString("MMM dd, yyyy"))</td>
                                <td class="fw-medium">@job.Title</td>
                                <td>
                                    @if (!string.IsNullOrEmpty(job.Tag))
                                    {
                                        <span class="kanban-card-tag" style="background:@(job.TagColor ?? "#6b7280")">@job.Tag</span>
                                    }
                                </td>
                                <td class="text-muted">@(job.Description ?? "\u2014")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

<!-- Create/Edit Modal -->
<div class="modal fade" id="jobModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h6 class="modal-title fw-bold" id="jobModalTitle">New Task</h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="jobId" />
                <div class="mb-3">
                    <label class="form-label fw-medium" for="jobTitle">Title <span class="text-danger">*</span></label>
                    <input type="text" class="form-control form-control-sm" id="jobTitle" maxlength="300" required />
                </div>
                <div class="mb-3">
                    <label class="form-label fw-medium" for="jobDesc">Description</label>
                    <textarea class="form-control form-control-sm" id="jobDesc" rows="3" maxlength="2000"></textarea>
                </div>
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label fw-medium" for="jobStatus">Status</label>
                        <select class="form-select form-select-sm" id="jobStatus">
                            <option value="0">To Do</option>
                            <option value="1">In Progress</option>
                            <option value="2">Done</option>
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-medium" for="jobTag">Tag</label>
                        <input type="text" class="form-control form-control-sm" id="jobTag" maxlength="100" placeholder="e.g. bug, feature" />
                    </div>
                </div>
                <div class="mt-3">
                    <label class="form-label fw-medium">Tag Color</label>
                    <div class="tag-colors" id="tagColors">
                        <span class="tag-color-preview active" data-color="#6b7280" style="background:#6b7280" onclick="pickColor(this)"></span>
                        <span class="tag-color-preview" data-color="#ef4444" style="background:#ef4444" onclick="pickColor(this)"></span>
                        <span class="tag-color-preview" data-color="#f97316" style="background:#f97316" onclick="pickColor(this)"></span>
                        <span class="tag-color-preview" data-color="#eab308" style="background:#eab308" onclick="pickColor(this)"></span>
                        <span class="tag-color-preview" data-color="#22c55e" style="background:#22c55e" onclick="pickColor(this)"></span>
                        <span class="tag-color-preview" data-color="#06b6d4" style="background:#06b6d4" onclick="pickColor(this)"></span>
                        <span class="tag-color-preview" data-color="#3b82f6" style="background:#3b82f6" onclick="pickColor(this)"></span>
                        <span class="tag-color-preview" data-color="#8b5cf6" style="background:#8b5cf6" onclick="pickColor(this)"></span>
                        <span class="tag-color-preview" data-color="#ec4899" style="background:#ec4899" onclick="pickColor(this)"></span>
                    </div>
                    <input type="hidden" id="jobTagColor" value="#6b7280" />
                </div>

                <!-- Attachments Section -->
                <div class="att-section" id="attSection">
                    <div class="att-section-title"><i class="bi bi-paperclip me-1"></i>Attachments</div>
                    <div class="att-list" id="attList"></div>
                    <div class="att-upload-row">
                        <label class="btn btn-outline-secondary btn-sm mb-0">
                            <i class="bi bi-file-earmark-plus me-1"></i> Add File
                            <input type="file" id="fileInput" style="display:none" onchange="uploadFile(this)" multiple />
                        </label>
                        <div class="paste-zone" id="pasteZone" tabindex="0">
                            <i class="bi bi-clipboard me-1"></i> Paste screenshot (Ctrl+V)
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer d-flex justify-content-between">
                <button type="button" class="btn btn-outline-danger btn-sm" id="modalDeleteBtn" style="display:none" onclick="deleteJobFromModal()">
                    <i class="bi bi-trash me-1"></i> Delete
                </button>
                <div class="ms-auto d-flex gap-2">
                    <button type="button" class="btn btn-light btn-sm" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-dark btn-sm" onclick="saveJob()">Save</button>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Image Preview Modal -->
<div class="modal fade" id="imgPreviewModal" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content bg-transparent border-0 shadow-none">
            <div class="text-end mb-2">
                <button type="button" class="btn btn-sm btn-light" data-bs-dismiss="modal"><i class="bi bi-x-lg"></i></button>
            </div>
            <img id="imgPreviewSrc" src="" class="img-fluid rounded" style="max-height:80vh; margin:auto;" />
        </div>
    </div>
</div>

<!-- Toast -->
<div class="position-fixed bottom-0 end-0 p-3" style="z-index:1080">
    <div id="toast" class="toast align-items-center text-bg-success border-0" role="alert">
        <div class="d-flex">
            <div class="toast-body" id="toastMsg"></div>
            <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
        </div>
    </div>
</div>

@section Scripts {
<script>
    let editMode = false;
    let pendingFiles = [];      // queued {file, isScreenshot} for new tasks
    let pendingScreenshots = []; // queued dataUrls for new tasks

    function openCreateModal() {
        editMode = false;
        pendingFiles = [];
        pendingScreenshots = [];
        document.getElementById('jobModalTitle').textContent = 'New Task';
        document.getElementById('jobId').value = '';
        document.getElementById('jobTitle').value = '';
        document.getElementById('jobDesc').value = '';
        document.getElementById('jobStatus').value = '0';
        document.getElementById('jobTag').value = '';
        document.getElementById('jobTagColor').value = '#6b7280';
        document.querySelectorAll('.tag-color-preview').forEach(el => el.classList.remove('active'));
        document.querySelector('.tag-color-preview[data-color="#6b7280"]').classList.add('active');
        document.getElementById('attList').innerHTML = '';
        document.getElementById('modalDeleteBtn').style.display = 'none';
    }

    function openEditModal(card) {
        editMode = true;
        pendingFiles = [];
        pendingScreenshots = [];
        const jobId = card.dataset.id;
        document.getElementById('jobModalTitle').textContent = 'Edit Task';
        document.getElementById('jobId').value = jobId;
        document.getElementById('jobTitle').value = card.dataset.title;
        document.getElementById('jobDesc').value = card.dataset.desc || '';
        document.getElementById('jobStatus').value = card.dataset.status;
        document.getElementById('jobTag').value = card.dataset.tag || '';
        const color = card.dataset.tagcolor || '#6b7280';
        document.getElementById('jobTagColor').value = color;
        document.querySelectorAll('.tag-color-preview').forEach(el => {
            el.classList.toggle('active', el.dataset.color === color);
        });
        loadAttachments(jobId);
        document.getElementById('modalDeleteBtn').style.display = '';
        new bootstrap.Modal(document.getElementById('jobModal')).show();
    }

    function pickColor(el) {
        document.querySelectorAll('.tag-color-preview').forEach(e => e.classList.remove('active'));
        el.classList.add('active');
        document.getElementById('jobTagColor').value = el.dataset.color;
    }

    async function saveJob() {
        const title = document.getElementById('jobTitle').value.trim();
        if (!title) { document.getElementById('jobTitle').focus(); return; }

        const payload = {
            title,
            description: document.getElementById('jobDesc').value.trim() || null,
            status: parseInt(document.getElementById('jobStatus').value),
            tag: document.getElementById('jobTag').value.trim() || null,
            tagColor: document.getElementById('jobTagColor').value
        };

        let url;
        if (editMode) {
            payload.id = document.getElementById('jobId').value;
            url = '/jobs/update';
        } else {
            url = '/jobs/create';
        }

        try {
            const resp = await fetch(url, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payload)
            });
            const result = await resp.json();
            if (result.success) {
                const jobId = editMode ? payload.id : result.data.id;

                // Upload any queued files/screenshots
                if (!editMode && (pendingFiles.length || pendingScreenshots.length)) {
                    showToast('Task created, uploading attachments...', 'success');
                    await uploadPendingAttachments(jobId);
                }

                bootstrap.Modal.getInstance(document.getElementById('jobModal'))?.hide();
                showToast(editMode ? 'Task updated' : 'Task created', 'success');
                setTimeout(() => location.reload(), 500);
            } else {
                showToast(result.message || 'Error saving task', 'danger');
            }
        } catch (err) {
            showToast('Network error', 'danger');
        }
    }

    async function uploadPendingAttachments(jobId) {
        for (const pf of pendingFiles) {
            const form = new FormData();
            form.append('file', pf.file);
            form.append('jobId', jobId);
            form.append('isScreenshot', pf.isScreenshot ? 'true' : 'false');
            try {
                await fetch('/jobs/uploadattachment', { method: 'POST', body: form });
            } catch { /* best effort */ }
        }
        for (const dataUrl of pendingScreenshots) {
            try {
                await fetch('/jobs/uploadscreenshot', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ jobId, imageData: dataUrl })
                });
            } catch { /* best effort */ }
        }
        pendingFiles = [];
        pendingScreenshots = [];
    }

    async function deleteJob(id) {
        if (!confirm('Delete this task?')) return;
        try {
            const resp = await fetch('/jobs/delete', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ id })
            });
            const result = await resp.json();
            if (result.success) {
                showToast('Task deleted', 'success');
                setTimeout(() => location.reload(), 500);
            }
        } catch (err) {
            showToast('Error deleting task', 'danger');
        }
    }

    async function deleteJobFromModal() {
        const id = document.getElementById('jobId').value;
        if (!id) return;
        if (!confirm('Delete this task?')) return;
        try {
            const resp = await fetch('/jobs/delete', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ id })
            });
            const result = await resp.json();
            if (result.success) {
                bootstrap.Modal.getInstance(document.getElementById('jobModal'))?.hide();
                showToast('Task deleted', 'success');
                setTimeout(() => location.reload(), 500);
            }
        } catch (err) {
            showToast('Error deleting task', 'danger');
        }
    }

    // ---- Drag & Drop ----
    function dragStart(e) {
        e.dataTransfer.setData('text/plain', e.target.dataset.id);
        e.target.classList.add('dragging');
    }
    function dragEnd(e) { e.target.classList.remove('dragging'); }
    function dragOver(e) { e.preventDefault(); e.currentTarget.classList.add('drag-over'); }
    function dragLeave(e) { e.currentTarget.classList.remove('drag-over'); }

    async function dropCard(e) {
        e.preventDefault();
        e.currentTarget.classList.remove('drag-over');
        const id = e.dataTransfer.getData('text/plain');
        const col = e.currentTarget.closest('.kanban-col');
        const newStatus = parseInt(col.dataset.status);

        const card = document.querySelector(`.kanban-card[data-id="${id}"]`);
        if (!card || parseInt(card.dataset.status) === newStatus) return;

        e.currentTarget.appendChild(card);
        card.dataset.status = newStatus;
        updateCounts();

        try {
            const resp = await fetch('/jobs/updatestatus', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ id, status: newStatus })
            });
            const result = await resp.json();
            if (result.success) {
                showToast('Status updated', 'success');
                setTimeout(() => location.reload(), 800);
            } else {
                showToast('Error updating status', 'danger');
                location.reload();
            }
        } catch (err) {
            showToast('Network error', 'danger');
            location.reload();
        }
    }

    function updateCounts() {
        document.getElementById('countTodo').textContent = document.querySelectorAll('#colTodo .kanban-card').length;
        document.getElementById('countInProgress').textContent = document.querySelectorAll('#colInProgress .kanban-card').length;
        document.getElementById('countDone').textContent = document.querySelectorAll('#colDone .kanban-card').length;
    }

    // ---- Attachments ----
    async function loadAttachments(jobId) {
        const list = document.getElementById('attList');
        list.innerHTML = '<span class="text-muted" style="font-size:.7rem">Loading...</span>';
        try {
            const resp = await fetch(`/jobs/getattachments?jobId=${jobId}`);
            const result = await resp.json();
            list.innerHTML = '';
            if (result.success && result.data) {
                result.data.forEach(att => list.appendChild(createAttItem(att)));
            }
        } catch {
            list.innerHTML = '<span class="text-danger" style="font-size:.7rem">Failed to load</span>';
        }
    }

    function createAttItem(att) {
        const div = document.createElement('div');
        div.className = 'att-item';
        div.dataset.attId = att.id;

        const isImage = att.contentType && att.contentType.startsWith('image/');
        if (isImage) {
            const img = document.createElement('img');
            img.src = att.url;
            img.alt = att.fileName;
            img.className = 'att-item-img';
            img.onclick = () => previewImage(att.url);
            div.appendChild(img);
        } else {
            const fileDiv = document.createElement('div');
            fileDiv.className = 'att-item-file';
            fileDiv.innerHTML = `<i class="bi bi-file-earmark"></i><span title="${att.fileName}">${att.fileName}</span>`;
            fileDiv.style.cursor = 'pointer';
            fileDiv.onclick = () => window.open(att.url, '_blank');
            div.appendChild(fileDiv);
        }

        const delBtn = document.createElement('button');
        delBtn.className = 'att-item-delete';
        delBtn.innerHTML = '<i class="bi bi-x"></i>';
        delBtn.onclick = (e) => { e.stopPropagation(); deleteAttachment(att.id, div); };
        div.appendChild(delBtn);

        return div;
    }

    // Create a preview item for queued (not yet uploaded) files
    function createPendingAttItem(file, idx, isScreenshot) {
        const div = document.createElement('div');
        div.className = 'att-item';
        div.dataset.pendingIdx = idx;

        const isImage = file.type.startsWith('image/');
        if (isImage) {
            const img = document.createElement('img');
            img.className = 'att-item-img';
            const reader = new FileReader();
            reader.onload = (e) => { img.src = e.target.result; };
            reader.readAsDataURL(file);
            img.onclick = () => { if (img.src) previewImage(img.src); };
            div.appendChild(img);
        } else {
            const fileDiv = document.createElement('div');
            fileDiv.className = 'att-item-file';
            fileDiv.innerHTML = `<i class="bi bi-file-earmark"></i><span title="${file.name}">${file.name}</span>`;
            div.appendChild(fileDiv);
        }

        const delBtn = document.createElement('button');
        delBtn.className = 'att-item-delete';
        delBtn.innerHTML = '<i class="bi bi-x"></i>';
        delBtn.onclick = (e) => {
            e.stopPropagation();
            // Remove from pending queue
            pendingFiles = pendingFiles.filter((_, i) => i !== idx);
            div.remove();
            rebuildPendingIndices();
        };
        div.appendChild(delBtn);

        return div;
    }

    function createPendingScreenshotItem(dataUrl, idx) {
        const div = document.createElement('div');
        div.className = 'att-item';
        div.dataset.pendingScreenIdx = idx;

        const img = document.createElement('img');
        img.src = dataUrl;
        img.className = 'att-item-img';
        img.onclick = () => previewImage(dataUrl);
        div.appendChild(img);

        const delBtn = document.createElement('button');
        delBtn.className = 'att-item-delete';
        delBtn.innerHTML = '<i class="bi bi-x"></i>';
        delBtn.onclick = (e) => {
            e.stopPropagation();
            pendingScreenshots = pendingScreenshots.filter((_, i) => i !== idx);
            div.remove();
        };
        div.appendChild(delBtn);

        return div;
    }

    function rebuildPendingIndices() {
        document.querySelectorAll('.att-item[data-pending-idx]').forEach((el, i) => {
            el.dataset.pendingIdx = i;
        });
    }

    function previewImage(url) {
        document.getElementById('imgPreviewSrc').src = url;
        new bootstrap.Modal(document.getElementById('imgPreviewModal')).show();
    }

    function uploadFile(input) {
        const jobId = document.getElementById('jobId').value;
        const list = document.getElementById('attList');

        if (jobId) {
            // Edit mode: upload immediately
            uploadFilesImmediate(input, jobId);
        } else {
            // Create mode: queue for later
            for (const file of input.files) {
                const idx = pendingFiles.length;
                pendingFiles.push({ file, isScreenshot: false });
                list.appendChild(createPendingAttItem(file, idx, false));
            }
            input.value = '';
        }
    }

    async function uploadFilesImmediate(input, jobId) {
        for (const file of input.files) {
            const form = new FormData();
            form.append('file', file);
            form.append('jobId', jobId);
            form.append('isScreenshot', 'false');
            try {
                const resp = await fetch('/jobs/uploadattachment', { method: 'POST', body: form });
                const result = await resp.json();
                if (result.success) {
                    document.getElementById('attList').appendChild(createAttItem(result.data));
                    showToast('File uploaded', 'success');
                } else {
                    showToast(result.message || 'Upload failed', 'danger');
                }
            } catch {
                showToast('Upload error', 'danger');
            }
        }
        input.value = '';
    }

    function handleScreenshotPaste(dataUrl) {
        const jobId = document.getElementById('jobId').value;

        if (jobId) {
            // Edit mode: upload immediately
            uploadScreenshotImmediate(dataUrl, jobId);
        } else {
            // Create mode: queue for later
            const idx = pendingScreenshots.length;
            pendingScreenshots.push(dataUrl);
            document.getElementById('attList').appendChild(createPendingScreenshotItem(dataUrl, idx));
        }
    }

    async function uploadScreenshotImmediate(dataUrl, jobId) {
        const pasteZone = document.getElementById('pasteZone');
        pasteZone.classList.add('uploading');
        pasteZone.textContent = 'Uploading...';

        try {
            const resp = await fetch('/jobs/uploadscreenshot', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ jobId, imageData: dataUrl })
            });
            const result = await resp.json();
            if (result.success) {
                document.getElementById('attList').appendChild(createAttItem(result.data));
                showToast('Screenshot uploaded', 'success');
            } else {
                showToast(result.message || 'Upload failed', 'danger');
            }
        } catch {
            showToast('Upload error', 'danger');
        } finally {
            pasteZone.classList.remove('uploading');
            pasteZone.innerHTML = '<i class="bi bi-clipboard me-1"></i> Paste screenshot (Ctrl+V)';
        }
    }

    async function deleteAttachment(id, el) {
        if (!confirm('Delete this attachment?')) return;
        try {
            const resp = await fetch('/jobs/deleteattachment', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ id })
            });
            const result = await resp.json();
            if (result.success) {
                el?.remove();
                showToast('Attachment deleted', 'success');
            }
        } catch {
            showToast('Error deleting attachment', 'danger');
        }
    }

    // ---- Paste handler on modal ----
    document.getElementById('jobModal').addEventListener('paste', (e) => {
        const items = e.clipboardData?.items;
        if (!items) return;
        for (const item of items) {
            if (item.type.startsWith('image/')) {
                e.preventDefault();
                const file = item.getAsFile();
                const reader = new FileReader();
                reader.onload = (ev) => handleScreenshotPaste(ev.target.result);
                reader.readAsDataURL(file);
                return;
            }
        }
    });

    // Paste zone specific handler
    document.getElementById('pasteZone').addEventListener('paste', (e) => {
        const items = e.clipboardData?.items;
        if (!items) return;
        for (const item of items) {
            if (item.type.startsWith('image/')) {
                e.preventDefault();
                e.stopPropagation();
                const file = item.getAsFile();
                const reader = new FileReader();
                reader.onload = (ev) => handleScreenshotPaste(ev.target.result);
                reader.readAsDataURL(file);
                return;
            }
        }
    });

    function showToast(msg, type) {
        const t = document.getElementById('toast');
        t.className = `toast align-items-center text-bg-${type} border-0`;
        document.getElementById('toastMsg').textContent = msg;
        new bootstrap.Toast(t).show();
    }
</script>
}
