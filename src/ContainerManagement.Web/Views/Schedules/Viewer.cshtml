@using Microsoft.AspNetCore.Mvc.Rendering
@{
    ViewData["Title"] = "Schedule Viewer";
    ViewData["ShowNew"] = false;
    ViewData["ShowExport"] = false;
    ViewData["ShowImport"] = false;
}

@section Styles{
    <link rel="stylesheet" href="~/css/ui-common.css" asp-append-version="true" />
    <style>
        /* ── Schedule Viewer ── */
        .sv-tabs { display: flex; gap: 0; border-bottom: 2px solid #e5e7eb; background: #fff; }
        .sv-tabs .sv-tab { padding: .5rem 1.25rem; font-size: .8rem; font-weight: 500; color: #64748b; cursor: pointer; border-bottom: 2px solid transparent; margin-bottom: -2px; transition: all .15s; }
        .sv-tabs .sv-tab:hover { color: #1e3a8a; }
        .sv-tabs .sv-tab.active { color: #1e3a8a; border-bottom-color: #1e3a8a; font-weight: 600; }

        .sv-section-header { background: linear-gradient(135deg, #312e81, #4338ca); color: #fff; padding: .4rem .75rem; font-size: .8rem; font-weight: 600; border-radius: .25rem .25rem 0 0; }

        .sv-filter-panel { background: #fff; border: 1px solid #e5e7eb; border-top: none; padding: .75rem 1rem; display: flex; align-items: flex-start; gap: 1.5rem; flex-wrap: wrap; }

        .sv-routing fieldset { border: 1px solid #f97316; border-radius: .25rem; padding: .4rem .6rem; }
        .sv-routing legend { font-size: .7rem; color: #f97316; font-weight: 600; padding: 0 .25rem; width: auto; margin: 0; float: none; }
        .sv-routing label { font-size: .75rem; cursor: pointer; }
        .sv-routing input[type="radio"] { accent-color: #2563eb; }

        .sv-fields { display: flex; flex-wrap: wrap; align-items: center; gap: .75rem; flex: 1; }
        .sv-field { display: flex; align-items: center; gap: .35rem; }
        .sv-field label { font-size: .75rem; font-weight: 500; color: #374151; white-space: nowrap; }
        .sv-field input, .sv-field select { font-size: .75rem; padding: .3rem .5rem; border: 1px solid #cbd5e1; border-radius: .25rem; background: #e0f2fe; }
        .sv-field input[type="date"] { min-width: 120px; }
        .sv-field select { min-width: 220px; background: #e0f2fe; }

        .sv-swap-btn { background: none; border: 1px solid #7c3aed; color: #7c3aed; border-radius: 50%; width: 24px; height: 24px; display: flex; align-items: center; justify-content: center; cursor: pointer; font-size: .7rem; }
        .sv-swap-btn:hover { background: #7c3aed; color: #fff; }

        .sv-actions { display: flex; gap: .5rem; align-items: center; }
        .sv-btn-show { background: #f97316; color: #fff; border: none; padding: .35rem .85rem; border-radius: .25rem; font-size: .75rem; font-weight: 600; cursor: pointer; display: flex; align-items: center; gap: .3rem; }
        .sv-btn-show:hover { background: #ea580c; }
        .sv-btn-clear { background: #6b7280; color: #fff; border: none; padding: .35rem .85rem; border-radius: .25rem; font-size: .75rem; font-weight: 600; cursor: pointer; display: flex; align-items: center; gap: .3rem; }
        .sv-btn-clear:hover { background: #4b5563; }

        .sv-grid-toolbar { display: flex; justify-content: flex-end; align-items: center; gap: .5rem; padding: .4rem .75rem; background: #f9fafb; border-bottom: 1px solid #e5e7eb; font-size: .75rem; color: #374151; }
        .sv-grid-toolbar .sv-total { font-weight: 600; }
        .sv-grid-toolbar .sv-icon-btn { width: 22px; height: 22px; border-radius: .2rem; display: flex; align-items: center; justify-content: center; border: none; cursor: pointer; font-size: .7rem; color: #fff; }

        /* ── Drag-to-Group zone ── */
        .sv-drag-row {
            padding: .4rem .75rem; font-size: .72rem; color: #9ca3af;
            border-bottom: 1px solid #e5e7eb; background: #fafafa;
            min-height: 34px; display: flex; align-items: center; gap: .4rem;
            flex-wrap: wrap; transition: background .15s, border-color .15s;
        }
        .sv-drag-row.drag-over {
            background: #eff6ff; border-bottom-color: #3b82f6;
            outline: 2px dashed #3b82f6; outline-offset: -2px;
        }
        .sv-drag-row .drag-placeholder { display: flex; align-items: center; gap: .25rem; }
        .sv-drag-row .drag-placeholder i { margin-right: .15rem; }
        .sv-drag-row.has-chips .drag-placeholder { display: none; }

        .sv-group-chip {
            display: inline-flex; align-items: center; gap: .3rem;
            background: #1e3a8a; color: #fff; padding: .15rem .5rem .15rem .6rem;
            border-radius: 1rem; font-size: .68rem; font-weight: 500;
            user-select: none; white-space: nowrap; transition: background .15s;
        }
        .sv-group-chip:hover { background: #1e40af; }
        .sv-group-chip .chip-remove {
            display: flex; align-items: center; justify-content: center;
            width: 14px; height: 14px; border-radius: 50%;
            background: rgba(255,255,255,.25); border: none; color: #fff;
            font-size: .55rem; cursor: pointer; line-height: 1; padding: 0;
        }
        .sv-group-chip .chip-remove:hover { background: rgba(255,255,255,.5); }

        .sv-group-separator { color: #cbd5e1; font-size: .65rem; }

        /* Column headers - grab cursor hint */
        .sv-header-th { cursor: grab; -webkit-user-select: none; -moz-user-select: none; user-select: none; }
        .sv-header-th:active { cursor: grabbing; }
        .sv-header-th.col-grouped { background: rgba(255,255,255,.08) !important; opacity: .55; }

        /* Floating ghost while dragging */
        .sv-drag-ghost {
            position: fixed; z-index: 99999; pointer-events: none;
            background: #1e3a8a; color: #fff; padding: 4px 14px;
            border-radius: 4px; font-size: 12px; font-weight: 600;
            white-space: nowrap; box-shadow: 0 4px 12px rgba(0,0,0,.25);
            opacity: .92; display: none;
        }

        /* Group rows in grid */
        .sv-group-header td {
            background: #f1f5f9 !important; font-weight: 600; font-size: .78rem;
            color: #1e3a8a; padding: .4rem .75rem !important; cursor: pointer; user-select: none;
        }
        .sv-group-header td i { margin-right: .3rem; font-size: .7rem; transition: transform .15s; }
        .sv-group-header.collapsed td i { transform: rotate(-90deg); }
        .sv-group-row-hidden { display: none !important; }

        .sv-tab-content { display: none; }
        .sv-tab-content.active { display: block; }
    </style>
}

<div class="operator-page">
    <div class="page-header">Schedule Viewer</div>

    <div class="content" style="flex-direction: column; max-width: 100%;">
        <div style="width: 100%;">

            @* ── Tabs ── *@
            <div class="sv-tabs">
                <div class="sv-tab active" data-tab="byDate">By Date</div>
                <div class="sv-tab" data-tab="byService">By Service</div>
                <div class="sv-tab" data-tab="byPort">By Port</div>
                <div class="sv-tab" data-tab="byPolPod">By POL/POD</div>
                <div class="sv-tab" data-tab="byRoute">By Route</div>
            </div>

            @* ── By Date ── *@
            <div class="sv-tab-content active" id="tab-byDate">
                <div class="sv-section-header">Date Details</div>
                <div class="sv-filter-panel">
                    <div class="sv-fields">
                        <div class="sv-field">
                            <label>From Date</label>
                            <input type="date" id="date-from" />
                        </div>
                        <div class="sv-field">
                            <label>To Date</label>
                            <input type="date" id="date-to" />
                        </div>
                    </div>
                    <div class="sv-actions">
                        <button class="sv-btn-show" onclick="showSchedule()"><i class="bi bi-play-fill"></i> Show</button>
                        <button class="sv-btn-clear" onclick="clearFilters(this)"><i class="bi bi-arrow-counterclockwise"></i> Clear</button>
                    </div>
                </div>
            </div>

            @* ── By Service ── *@
            <div class="sv-tab-content" id="tab-byService">
                <div class="sv-section-header">Service Details</div>
                <div class="sv-filter-panel">
                    <div class="sv-fields">
                        <div class="sv-field">
                            <label>From Date</label>
                            <input type="date" id="svc-date-from" />
                        </div>
                        <div class="sv-field">
                            <label>To Date</label>
                            <input type="date" id="svc-date-to" />
                        </div>
                        <div class="sv-field">
                            <label>Service</label>
                            <select id="svc-service">
                                <option value="">-- Select Service --</option>
                                @if (ViewBag.Services is IEnumerable<SelectListItem> serviceItems)
                                { foreach (var s in serviceItems){ <option value="@s.Value">@s.Text</option> } }
                            </select>
                        </div>
                    </div>
                    <div class="sv-actions">
                        <button class="sv-btn-show" onclick="showSchedule()"><i class="bi bi-play-fill"></i> Show</button>
                        <button class="sv-btn-clear" onclick="clearFilters(this)"><i class="bi bi-arrow-counterclockwise"></i> Clear</button>
                    </div>
                </div>
            </div>

            @* ── By Port ── *@
            <div class="sv-tab-content" id="tab-byPort">
                <div class="sv-section-header">Port Details</div>
                <div class="sv-filter-panel">
                    <div class="sv-fields">
                        <div class="sv-field">
                            <label>From Date</label>
                            <input type="date" id="port-date-from" />
                        </div>
                        <div class="sv-field">
                            <label>To Date</label>
                            <input type="date" id="port-date-to" />
                        </div>
                        <div class="sv-field">
                            <label>Port</label>
                            <select id="port-port">
                                <option value="">-- Select Port --</option>
                                @if (ViewBag.Ports is IEnumerable<SelectListItem> portItems)
                                { foreach (var p in portItems){ <option value="@p.Value">@p.Text</option> } }
                            </select>
                        </div>
                    </div>
                    <div class="sv-actions">
                        <button class="sv-btn-show" onclick="showSchedule()"><i class="bi bi-play-fill"></i> Show</button>
                        <button class="sv-btn-clear" onclick="clearFilters(this)"><i class="bi bi-arrow-counterclockwise"></i> Clear</button>
                    </div>
                </div>
            </div>

            @* ── By POL/POD ── *@
            <div class="sv-tab-content" id="tab-byPolPod">
                <div class="sv-section-header">POL/POD Details</div>
                <div class="sv-filter-panel">
                    <div class="sv-routing">
                        <fieldset>
                            <legend>Routing Type</legend>
                            <div class="d-flex flex-column gap-1">
                                <label><input type="radio" name="routingType" value="direct" checked /> Direct</label>
                                <label><input type="radio" name="routingType" value="transhipment" /> Transhipment</label>
                            </div>
                        </fieldset>
                    </div>
                    <div class="sv-fields">
                        <div class="sv-field">
                            <label>From Date</label>
                            <input type="date" id="polpod-date-from" />
                        </div>
                        <div class="sv-field">
                            <label>To Date</label>
                            <input type="date" id="polpod-date-to" />
                        </div>
                        <div class="sv-field">
                            <label>POL</label>
                            <select id="sv-pol">
                                <option value="">-- Select POL --</option>
                                @if (ViewBag.Ports is IEnumerable<SelectListItem> polItems)
                                { foreach (var p in polItems){ <option value="@p.Value">@p.Text</option> } }
                            </select>
                        </div>
                        <button type="button" class="sv-swap-btn" title="Swap POL/POD" onclick="swapPolPod()"><i class="bi bi-arrow-down-up"></i></button>
                        <div class="sv-field">
                            <label>POD</label>
                            <select id="sv-pod">
                                <option value="">-- Select POD --</option>
                                @if (ViewBag.Ports is IEnumerable<SelectListItem> podItems)
                                { foreach (var p in podItems){ <option value="@p.Value">@p.Text</option> } }
                            </select>
                        </div>
                    </div>
                    <div class="sv-actions">
                        <button class="sv-btn-show" onclick="showSchedule()"><i class="bi bi-play-fill"></i> Show</button>
                        <button class="sv-btn-clear" onclick="clearFilters(this)"><i class="bi bi-arrow-counterclockwise"></i> Clear</button>
                    </div>
                </div>
            </div>

            @* ── By Route ── *@
            <div class="sv-tab-content" id="tab-byRoute">
                <div class="sv-section-header">Route Details</div>
                <div class="sv-filter-panel">
                    <div class="sv-fields">
                        <div class="sv-field">
                            <label>From Date</label>
                            <input type="date" id="route-date-from" />
                        </div>
                        <div class="sv-field">
                            <label>To Date</label>
                            <input type="date" id="route-date-to" />
                        </div>
                        <div class="sv-field">
                            <label>Route</label>
                            <select id="route-route">
                                <option value="">-- Select Route --</option>
                                @if (ViewBag.Routes is IEnumerable<SelectListItem> routeItems)
                                { foreach (var r in routeItems){ <option value="@r.Value">@r.Text</option> } }
                            </select>
                        </div>
                    </div>
                    <div class="sv-actions">
                        <button class="sv-btn-show" onclick="showSchedule()"><i class="bi bi-play-fill"></i> Show</button>
                        <button class="sv-btn-clear" onclick="clearFilters(this)"><i class="bi bi-arrow-counterclockwise"></i> Clear</button>
                    </div>
                </div>
            </div>

            @* ── Grid ── *@
            <div class="grid-card" style="margin-top: .75rem;">
                <div class="sv-grid-toolbar">
                    <span class="sv-total">Total Records : <span id="sv-total-count">0</span></span>
                    <button class="sv-icon-btn" style="background:#f97316;" title="Filter"><i class="bi bi-funnel-fill"></i></button>
                    <button class="sv-icon-btn" style="background:#ef4444;" title="Reset"><i class="bi bi-arrow-counterclockwise"></i></button>
                    <button class="sv-icon-btn" style="background:#22c55e;" title="Export Excel"><i class="bi bi-file-earmark-excel"></i></button>
                    <button class="sv-icon-btn" style="background:#3b82f6;" title="Export PDF"><i class="bi bi-file-earmark-pdf"></i></button>
                    <button class="sv-icon-btn" style="background:#8b5cf6;" title="Chart"><i class="bi bi-bar-chart-fill"></i></button>
                    <button class="sv-icon-btn" style="background:#06b6d4;" title="Columns"><i class="bi bi-layout-three-columns"></i></button>
                </div>
                <div class="sv-drag-row" id="sv-group-zone">
                    <span class="drag-placeholder"><i class="bi bi-grip-horizontal"></i> Drag here to set row groups</span>
                </div>
                <div class="table-wrapper">
                    <table class="table table-sm mb-0 sticky">
                        <thead>
                            <tr id="sv-header-row">
                                <th class="sv-header-th" data-col="service">Service</th>
                                <th class="sv-header-th" data-col="vesselCode">Vessel Code</th>
                                <th class="sv-header-th" data-col="vesselName">Vessel Name</th>
                                <th class="sv-header-th" data-col="operator">Operator</th>
                                <th class="sv-header-th" data-col="slot">Slot</th>
                                <th class="sv-header-th" data-col="voyage">Voyage</th>
                                <th class="sv-header-th" data-col="bound">Bound</th>
                                <th class="sv-header-th" data-col="leg">Leg</th>
                                <th class="sv-header-th" data-col="port">Port</th>
                                <th class="sv-header-th" data-col="terminal">Terminal</th>
                                <th class="sv-header-th" data-col="eta">ETA</th>
                                <th class="sv-header-th" data-col="etb">ETB</th>
                                <th class="sv-header-th" data-col="etd">ETD</th>
                                <th class="sv-header-th" data-col="portStay">Port Stay</th>
                                <th class="sv-header-th" data-col="seaDay">Sea Day</th>
                                <th class="sv-header-th" data-col="speed">Speed</th>
                                <th class="sv-header-th" data-col="distance">Distance</th>
                            </tr>
                        </thead>
                        <tbody id="sv-grid-body">
                        </tbody>
                    </table>
                </div>
            </div>

        </div>
    </div>
</div>

@* Ghost element for drag visual - sits outside the table *@
<div class="sv-drag-ghost" id="sv-ghost"></div>

@section Scripts {
    <script>
        // ── Tab switching ──
        document.querySelectorAll('.sv-tab').forEach(function(tab) {
            tab.addEventListener('click', function() {
                document.querySelectorAll('.sv-tab').forEach(function(t) { t.classList.remove('active'); });
                document.querySelectorAll('.sv-tab-content').forEach(function(c) { c.classList.remove('active'); });
                tab.classList.add('active');
                var target = document.getElementById('tab-' + tab.getAttribute('data-tab'));
                if (target) target.classList.add('active');
            });
        });

        // ══════════════════════════════════════════════════════
        //  Row grouping via drag from column headers
        // ══════════════════════════════════════════════════════
        (function() {
            var groupZone = document.getElementById('sv-group-zone');
            var headerRow = document.getElementById('sv-header-row');
            var gridBody  = document.getElementById('sv-grid-body');
            var ghostEl   = document.getElementById('sv-ghost');
            var activeGroups = [];

            // Build label map
            var colLabels = {};
            var ths = headerRow.querySelectorAll('th[data-col]');
            for (var i = 0; i < ths.length; i++) {
                colLabels[ths[i].getAttribute('data-col')] = ths[i].textContent.trim();
            }

            // ── Drag state ──
            var dragging = false;
            var dragCol = null;
            var startX = 0, startY = 0;

            // Hit test
            function hitTest(el, x, y) {
                var r = el.getBoundingClientRect();
                return x >= r.left && x <= r.right && y >= r.top && y <= r.bottom;
            }

            // ── Attach mousedown to each TH ──
            for (var i = 0; i < ths.length; i++) {
                (function(th) {
                    th.addEventListener('mousedown', function(e) {
                        if (e.button !== 0) return;
                        e.preventDefault();
                        e.stopPropagation();
                        var col = th.getAttribute('data-col');
                        if (!col) return;
                        // Already grouped — skip
                        for (var g = 0; g < activeGroups.length; g++) {
                            if (activeGroups[g] === col) return;
                        }

                        startX = e.clientX;
                        startY = e.clientY;
                        dragCol = col;
                        dragging = false;

                        function onMove(ev) {
                            var dx = Math.abs(ev.clientX - startX);
                            var dy = Math.abs(ev.clientY - startY);
                            if (!dragging && (dx + dy) < 5) return;

                            if (!dragging) {
                                dragging = true;
                                ghostEl.textContent = colLabels[col] || col;
                                ghostEl.style.display = 'block';
                            }

                            ghostEl.style.left = (ev.clientX + 14) + 'px';
                            ghostEl.style.top  = (ev.clientY - 16) + 'px';

                            if (hitTest(groupZone, ev.clientX, ev.clientY)) {
                                groupZone.classList.add('drag-over');
                            } else {
                                groupZone.classList.remove('drag-over');
                            }
                        }

                        function onUp(ev) {
                            document.removeEventListener('mousemove', onMove, true);
                            document.removeEventListener('mouseup', onUp, true);

                            ghostEl.style.display = 'none';
                            groupZone.classList.remove('drag-over');

                            if (dragging && hitTest(groupZone, ev.clientX, ev.clientY)) {
                                addGroup(dragCol);
                            } else if (!dragging) {
                                // Click (no drag) — also add to group
                                addGroup(dragCol);
                            }

                            dragging = false;
                            dragCol = null;
                        }

                        document.addEventListener('mousemove', onMove, true);
                        document.addEventListener('mouseup', onUp, true);
                    });
                })(ths[i]);
            }

            // ── Add a group ──
            function addGroup(col) {
                for (var g = 0; g < activeGroups.length; g++) {
                    if (activeGroups[g] === col) return;
                }
                activeGroups.push(col);
                renderChips();
                applyRowGroups();
            }

            // ── Render chips ──
            function renderChips() {
                // Remove old chips
                var old = groupZone.querySelectorAll('.sv-group-chip, .sv-group-separator');
                for (var i = 0; i < old.length; i++) old[i].remove();

                groupZone.classList.toggle('has-chips', activeGroups.length > 0);

                // Update header highlights
                for (var i = 0; i < ths.length; i++) {
                    var col = ths[i].getAttribute('data-col');
                    var isGrouped = false;
                    for (var g = 0; g < activeGroups.length; g++) {
                        if (activeGroups[g] === col) { isGrouped = true; break; }
                    }
                    if (isGrouped) ths[i].classList.add('col-grouped');
                    else ths[i].classList.remove('col-grouped');
                }

                for (var idx = 0; idx < activeGroups.length; idx++) {
                    var col = activeGroups[idx];

                    if (idx > 0) {
                        var sep = document.createElement('span');
                        sep.className = 'sv-group-separator';
                        sep.textContent = '\u203A';
                        groupZone.appendChild(sep);
                    }

                    var chip = document.createElement('span');
                    chip.className = 'sv-group-chip';
                    chip.setAttribute('data-col', col);
                    chip.innerHTML = (colLabels[col] || col) + '<button class="chip-remove" title="Remove group">&times;</button>';

                    (function(c) {
                        chip.querySelector('.chip-remove').addEventListener('click', function(e) {
                            e.stopPropagation();
                            var newGroups = [];
                            for (var g = 0; g < activeGroups.length; g++) {
                                if (activeGroups[g] !== c) newGroups.push(activeGroups[g]);
                            }
                            activeGroups = newGroups;
                            renderChips();
                            applyRowGroups();
                        });
                    })(col);

                    groupZone.appendChild(chip);
                }
            }

            // ── Column index map ──
            var colIndex = {};
            for (var i = 0; i < ths.length; i++) {
                colIndex[ths[i].getAttribute('data-col')] = i;
            }

            // ── Apply row grouping ──
            function applyRowGroups() {
                // Remove existing group headers
                var headers = gridBody.querySelectorAll('.sv-group-header');
                for (var i = 0; i < headers.length; i++) headers[i].remove();
                // Reset hidden
                var allRows = gridBody.querySelectorAll('tr');
                for (var i = 0; i < allRows.length; i++) allRows[i].classList.remove('sv-group-row-hidden');

                var dataRows = gridBody.querySelectorAll('tr:not(.sv-group-header)');
                if (!dataRows.length || !activeGroups.length) return;

                var colCount = ths.length;
                groupRowsRecursive(Array.prototype.slice.call(dataRows), activeGroups, 0, colCount);
            }

            function groupRowsRecursive(rows, keys, depth, colCount) {
                if (!keys.length || !rows.length) return;
                var key = keys[0];
                var ci = colIndex[key];
                if (ci === undefined) return;

                // Bucket rows by cell value
                var bucketOrder = [];
                var bucketMap = {};
                for (var i = 0; i < rows.length; i++) {
                    var cells = rows[i].querySelectorAll('td');
                    var val = cells[ci] ? cells[ci].textContent.trim() : '';
                    if (!bucketMap[val]) {
                        bucketMap[val] = [];
                        bucketOrder.push(val);
                    }
                    bucketMap[val].push(rows[i]);
                }

                for (var b = 0; b < bucketOrder.length; b++) {
                    var val = bucketOrder[b];
                    var bRows = bucketMap[val];
                    var label = (colLabels[key] || key) + ': ' + (val || '(empty)');
                    var grpTr = document.createElement('tr');
                    grpTr.className = 'sv-group-header';
                    grpTr.setAttribute('data-depth', depth);

                    var td = document.createElement('td');
                    td.setAttribute('colspan', colCount);
                    td.style.paddingLeft = (0.75 + depth * 1.2) + 'rem';
                    td.innerHTML = '<i class="bi bi-chevron-down"></i>' + label + ' <span style="opacity:.5;font-weight:400;">(' + bRows.length + ')</span>';
                    grpTr.appendChild(td);

                    bRows[0].parentNode.insertBefore(grpTr, bRows[0]);

                    (function(grp, d) {
                        grp.addEventListener('click', function() {
                            var collapsed = grp.classList.toggle('collapsed');
                            var sib = grp.nextElementSibling;
                            while (sib) {
                                if (sib.classList.contains('sv-group-header')) {
                                    var sibD = parseInt(sib.getAttribute('data-depth') || '0', 10);
                                    if (sibD <= d) break;
                                }
                                if (collapsed) sib.classList.add('sv-group-row-hidden');
                                else sib.classList.remove('sv-group-row-hidden');
                                sib = sib.nextElementSibling;
                            }
                        });
                    })(grpTr, depth);

                    if (keys.length > 1) {
                        groupRowsRecursive(bRows, keys.slice(1), depth + 1, colCount);
                    }
                }
            }

            window.svGrouping = { applyRowGroups: applyRowGroups };
        })();

        function swapPolPod() {
            var pol = document.getElementById('sv-pol');
            var pod = document.getElementById('sv-pod');
            var tmp = pol.value;
            pol.value = pod.value;
            pod.value = tmp;
        }

        function clearFilters(btn) {
            var panel = btn.closest('.sv-filter-panel');
            if (!panel) return;
            var inputs = panel.querySelectorAll('input[type="date"]');
            for (var i = 0; i < inputs.length; i++) inputs[i].value = '';
            var selects = panel.querySelectorAll('select');
            for (var i = 0; i < selects.length; i++) selects[i].value = '';
            var direct = panel.querySelector('input[value="direct"]');
            if (direct) direct.checked = true;
            showSchedule();
        }

        function formatDate(val) {
            if (!val) return '';
            var d = new Date(val);
            if (isNaN(d.getTime())) return '';
            var dd = ('0' + d.getDate()).slice(-2);
            var mm = ('0' + (d.getMonth() + 1)).slice(-2);
            var yyyy = d.getFullYear();
            var hh = ('0' + d.getHours()).slice(-2);
            var mi = ('0' + d.getMinutes()).slice(-2);
            return dd + '/' + mm + '/' + yyyy + ' ' + hh + ':' + mi;
        }

        // ── Store full data for client-side filtering ──
        var svAllData = [];

        function showSchedule() {
            // Detect active tab
            var activeTab = document.querySelector('.sv-tab.active');
            if (!activeTab) return;
            var tab = activeTab.getAttribute('data-tab');

            // Build query params based on active tab filters
            var params = new URLSearchParams();
            var routingType = 'transhipment'; // default: show all ports

            if (tab === 'byService') {
                var svcFrom = document.getElementById('svc-date-from');
                var svcTo = document.getElementById('svc-date-to');
                var svcSel = document.getElementById('svc-service');
                if (svcFrom && svcFrom.value) params.set('fromDate', svcFrom.value);
                if (svcTo && svcTo.value) params.set('toDate', svcTo.value);
                if (svcSel && svcSel.value) params.set('serviceId', svcSel.value);
            }
            else if (tab === 'byPort') {
                var portFrom = document.getElementById('port-date-from');
                var portTo = document.getElementById('port-date-to');
                var portSel = document.getElementById('port-port');
                if (portFrom && portFrom.value) params.set('fromDate', portFrom.value);
                if (portTo && portTo.value) params.set('toDate', portTo.value);
                if (portSel && portSel.value) params.set('portId', portSel.value);
            }
            else if (tab === 'byPolPod') {
                var ppFrom = document.getElementById('polpod-date-from');
                var ppTo = document.getElementById('polpod-date-to');
                var polSel = document.getElementById('sv-pol');
                var podSel = document.getElementById('sv-pod');
                if (ppFrom && ppFrom.value) params.set('fromDate', ppFrom.value);
                if (ppTo && ppTo.value) params.set('toDate', ppTo.value);
                if (polSel && polSel.value) params.set('polId', polSel.value);
                if (podSel && podSel.value) params.set('podId', podSel.value);
                // Get routing type
                var rt = document.querySelector('input[name="routingType"]:checked');
                routingType = rt ? rt.value : 'transhipment';
            }
            else if (tab === 'byRoute') {
                var rtFrom = document.getElementById('route-date-from');
                var rtTo = document.getElementById('route-date-to');
                var rtSel = document.getElementById('route-route');
                if (rtFrom && rtFrom.value) params.set('fromDate', rtFrom.value);
                if (rtTo && rtTo.value) params.set('toDate', rtTo.value);
                if (rtSel && rtSel.value) params.set('routeId', rtSel.value);
            }
            else {
                // byDate (default)
                var dtFrom = document.getElementById('date-from');
                var dtTo = document.getElementById('date-to');
                if (dtFrom && dtFrom.value) params.set('fromDate', dtFrom.value);
                if (dtTo && dtTo.value) params.set('toDate', dtTo.value);
            }

            var baseUrl = '@Url.Action("GetSchedule", "Schedules")';
            if (!baseUrl) baseUrl = '/schedules/api/schedule'; // fallback
            var qs = params.toString();
            var url = qs ? baseUrl + '?' + qs : baseUrl;

            console.log('[Schedule] tab=' + tab + ' url=' + url);

            var gridBody = document.getElementById('sv-grid-body');
            gridBody.innerHTML = '<tr><td colspan="17" class="text-center py-3"><i class="bi bi-hourglass-split"></i> Loading…</td></tr>';

            fetch(url)
                .then(function(resp) {
                    console.log('[Schedule] HTTP ' + resp.status + ' type=' + (resp.headers.get('content-type') || ''));
                    var ct = resp.headers.get('content-type') || '';
                    if (!resp.ok) {
                        if (ct.indexOf('json') !== -1) {
                            return resp.json().then(function(err) { throw new Error(err.error || 'HTTP ' + resp.status); });
                        }
                        throw new Error('HTTP ' + resp.status);
                    }
                    if (ct.indexOf('json') === -1) throw new Error('Auth redirect – please re-login');
                    return resp.json();
                })
                .then(function(data) {
                    svAllData = data || [];
                    console.log('[Schedule] Received ' + svAllData.length + ' rows');

                    // Apply Direct/Transhipment filter
                    var filtered = svAllData;
                    if (routingType === 'direct') {
                        // Direct: show only first and last port per voyage
                        filtered = svAllData.filter(function(r) {
                            return r.leg === 1 || r.leg === r.totalLegs;
                        });
                        console.log('[Schedule] Direct filter: ' + filtered.length + ' of ' + svAllData.length);
                    }

                    renderGrid(filtered);
                })
                .catch(function(err) {
                    console.error('[Schedule] Error: ' + err.message);
                    gridBody.innerHTML = '<tr><td colspan="17" class="text-center py-3 text-danger"><i class="bi bi-exclamation-triangle"></i> ' + err.message + '</td></tr>';
                });
        }

        function renderGrid(data) {
            var gridBody = document.getElementById('sv-grid-body');
            gridBody.innerHTML = '';
            if (!data || !data.length) {
                gridBody.innerHTML = '<tr><td colspan="17" class="text-center py-3 text-muted">No records found</td></tr>';
                document.getElementById('sv-total-count').textContent = '0';
                return;
            }

            for (var i = 0; i < data.length; i++) {
                var r = data[i];
                var tr = document.createElement('tr');
                tr.innerHTML =
                    '<td>' + (r.service || '') + '</td>' +
                    '<td>' + (r.vesselCode || '') + '</td>' +
                    '<td>' + (r.vesselName || '') + '</td>' +
                    '<td>' + (r.operator || '') + '</td>' +
                    '<td>' + (r.slot || '') + '</td>' +
                    '<td>' + (r.voyage || '') + '</td>' +
                    '<td>' + (r.bound || '') + '</td>' +
                    '<td>' + (r.leg || '') + '</td>' +
                    '<td>' + (r.port || '') + '</td>' +
                    '<td>' + (r.terminal || '') + '</td>' +
                    '<td>' + formatDate(r.eta) + '</td>' +
                    '<td>' + formatDate(r.etb) + '</td>' +
                    '<td>' + formatDate(r.etd) + '</td>' +
                    '<td>' + (r.portStay != null ? r.portStay : '') + '</td>' +
                    '<td>' + (r.seaDay != null ? parseFloat(r.seaDay).toFixed(2) : '') + '</td>' +
                    '<td>' + (r.speed != null ? parseFloat(r.speed).toFixed(1) : '') + '</td>' +
                    '<td>' + (r.distance != null ? parseFloat(r.distance).toFixed(0) : '') + '</td>';
                gridBody.appendChild(tr);
            }

            document.getElementById('sv-total-count').textContent = data.length;
            window.svGrouping.applyRowGroups();
        }

        // ── Auto-load all schedule data when page opens ──
        showSchedule();
    </script>
}
