@using Microsoft.AspNetCore.Mvc.Rendering
@model IEnumerable<ContainerManagement.Application.Dtos.Routes.RouteListItemDto>

@{
    ViewData["Title"] = "Routes";
    ViewData["ShowNew"] = false;
}

@section Styles{
    <link rel="stylesheet" href="~/css/ui-common.css" asp-append-version="true" />
    <style>
        .op-toast { position: fixed; right: 1rem; bottom: 1rem; background: #111827; color: #fff; padding: .5rem .75rem; border-radius: .375rem; opacity: 0; transition: opacity .2s ease; }
        .op-toast.show { opacity: .95; }
        .rt-validation { color: #dc3545; font-size: .75rem; padding: .25rem .5rem; display: none; }
        .rt-validation.show { display: block; }
    </style>
}

<div class="operator-page">
    <div class="page-header">Routes</div>
    <div class="d-flex gap-2 toolbar align-items-center">
        <button type="button" class="btn btn-outline-secondary btn-sm" id="btn-new-route" data-bs-toggle="tooltip" title="New">
            <i class="bi bi-plus-square"></i>
        </button>
        @await Html.PartialAsync("_GridToolbar")
    </div>

    <div class="content">
        <div class="left-grid">
            <div class="grid-card">
                <div class="grid-header">
                    <div>Route Data</div>
                    <span class="badge badge-count" id="rt-total">@(Model?.Count() ?? 0)</span>
                </div>

                <div class="table-wrapper">
                    <table class="table table-sm mb-0 sticky" id="routesTable">
                        <thead>
                            <tr>
                                <th>Route Name</th>
                                <th>Port of Origin</th>
                                <th>Final Destination</th>
                                <th style="width:130px;">Actions</th>
                            </tr>
                            <tr class="filter-row">
                                <th><input id="cf-name" class="form-control form-control-sm" placeholder="Filter..." /></th>
                                <th><input id="cf-origin" class="form-control form-control-sm" placeholder="Filter..." /></th>
                                <th><input id="cf-dest" class="form-control form-control-sm" placeholder="Filter..." /></th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody id="rt-grid-body">
                        @* -- Inline create row (hidden by default) -- *@
                        <tr id="new-row" class="table-info d-none">
                            <td class="col-name">
                                <input class="form-control form-control-sm" id="new-name" placeholder="Route Name" />
                            </td>
                            <td class="col-origin">
                                <select class="form-select form-select-sm" id="new-origin">
                                    <option value="">-- Port of Origin --</option>
                                    @if (ViewBag.Ports is IEnumerable<SelectListItem> originPorts)
                                    { foreach (var p in originPorts){ <option value="@p.Value">@p.Text</option> } }
                                </select>
                            </td>
                            <td class="col-dest">
                                <select class="form-select form-select-sm" id="new-dest">
                                    <option value="">-- Final Destination --</option>
                                    @if (ViewBag.Ports is IEnumerable<SelectListItem> destPorts)
                                    { foreach (var p in destPorts){ <option value="@p.Value">@p.Text</option> } }
                                </select>
                            </td>
                            <td>
                                <div class="d-flex gap-2 align-items-center">
                                    <button type="button" class="btn btn-sm btn-success" id="btn-save-new" data-bs-toggle="tooltip" title="Save"><i class="bi bi-check-lg"></i></button>
                                    <button type="button" class="btn btn-sm btn-secondary" id="btn-cancel-new" data-bs-toggle="tooltip" title="Cancel"><i class="bi bi-x-lg"></i></button>
                                </div>
                            </td>
                        </tr>
                        @if (Model?.Any() == true)
                        {
                            foreach (var r in Model)
                            {
                                <tr data-id="@r.Id">
                                    <td class="col-name">
                                        <span class="disp">@r.RouteName</span>
                                        <input class="form-control form-control-sm edit d-none" value="@r.RouteName" />
                                    </td>
                                    <td class="col-origin">
                                        <span class="disp">@r.PortOfOriginName</span>
                                        <select class="form-select form-select-sm edit d-none">
                                            @if (ViewBag.Ports is IEnumerable<SelectListItem> oPorts)
                                            { foreach (var p in oPorts){ <option value="@p.Value" selected="@(r.PortOfOriginId.ToString()==p.Value)">@p.Text</option>; } }
                                        </select>
                                    </td>
                                    <td class="col-dest">
                                        <span class="disp">@r.FinalDestinationName</span>
                                        <select class="form-select form-select-sm edit d-none">
                                            @if (ViewBag.Ports is IEnumerable<SelectListItem> dPorts)
                                            { foreach (var p in dPorts){ <option value="@p.Value" selected="@(r.FinalDestinationId.ToString()==p.Value)">@p.Text</option>; } }
                                        </select>
                                    </td>
                                    <td>
                                        <div class="d-flex gap-2 align-items-center">
                                            <button type="button" class="btn btn-sm btn-outline-primary btn-edit" data-bs-toggle="tooltip" title="Edit"><i class="bi bi-pencil"></i></button>
                                            <button type="button" class="btn btn-sm btn-success d-none btn-save" data-bs-toggle="tooltip" title="Save"><i class="bi bi-check-lg"></i></button>
                                            <button type="button" class="btn btn-sm btn-secondary d-none btn-cancel" data-bs-toggle="tooltip" title="Cancel"><i class="bi bi-x-lg"></i></button>
                                            <form asp-action="Delete" method="post" class="d-inline m-0">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@r.Id" />
                                                <button type="submit" class="btn btn-sm btn-outline-danger" data-bs-toggle="tooltip" title="Delete" onclick="return confirm('Delete this route?');"><i class="bi bi-trash"></i></button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        </tbody>
                    </table>
                </div>
                <div id="rt-validation" class="rt-validation"></div>
            </div>
        </div>
        <div class="right-blank"></div>
    </div>
</div>

<div id="rt-toast" class="op-toast" role="status" aria-live="polite"></div>
<form id="rt-af">@Html.AntiForgeryToken()</form>

@section Scripts{
    <script>
        (function(){
            const q = (s)=>document.querySelector(s);
            const rows = Array.from(document.querySelectorAll('#rt-grid-body tr[data-id]'));
            const total = q('#rt-total');
            const refreshBtn = q('#grid-refresh');
            const toast = q('#rt-toast');
            function showToast(msg){ if(!toast) return; toast.textContent = msg; toast.classList.add('show'); setTimeout(()=>toast.classList.remove('show'), 1500); }
            const valMsg = q('#rt-validation');
            function showValidation(msg){ if(!valMsg) return; valMsg.textContent = msg; valMsg.classList.add('show'); }
            function hideValidation(){ if(!valMsg) return; valMsg.textContent=''; valMsg.classList.remove('show'); }
            function applyFilter(){
                const fname = (q('#cf-name')?.value||'').toLowerCase();
                const forigin = (q('#cf-origin')?.value||'').toLowerCase();
                const fdest = (q('#cf-dest')?.value||'').toLowerCase();
                let count=0;
                rows.forEach(r=>{
                    const name = r.querySelector('.col-name .disp').textContent.toLowerCase();
                    const origin = r.querySelector('.col-origin .disp').textContent.toLowerCase();
                    const dest = r.querySelector('.col-dest .disp').textContent.toLowerCase();
                    const show = (!fname||name.includes(fname)) && (!forigin||origin.includes(forigin)) && (!fdest||dest.includes(fdest));
                    r.style.display = show? '':'none';
                    if (show) count++;
                });
                if (total) total.textContent = count;
            }
            ['#cf-name','#cf-origin','#cf-dest'].forEach(id=>{ const e=q(id); if(e) e.addEventListener('input', applyFilter);}); applyFilter();
            function token(){ const el=document.querySelector('#rt-af input[name="__RequestVerificationToken"]'); return el?el.value:''; }
            rows.forEach(r=> wireEditRow(r));
            refreshBtn?.addEventListener('click', ()=>{ applyFilter(); showToast('Grid refreshed'); });

            // -- Inline Create --
            const newRow = q('#new-row');
            const btnNew = q('#btn-new-route');
            const btnSaveNew = q('#btn-save-new');
            const btnCancelNew = q('#btn-cancel-new');

            function showNewRow(){ newRow.classList.remove('d-none'); q('#new-name')?.focus(); }
            function hideNewRow(){ newRow.classList.add('d-none'); q('#new-name').value=''; q('#new-origin').value=''; q('#new-dest').value=''; hideValidation(); }

            btnNew?.addEventListener('click', showNewRow);
            btnCancelNew?.addEventListener('click', hideNewRow);

            btnSaveNew?.addEventListener('click', async ()=>{
                const name = q('#new-name').value.trim();
                const originId = q('#new-origin').value;
                const destId = q('#new-dest').value;
                hideValidation();
                if(!name||!originId||!destId){ showValidation('All fields are required.'); return; }
                if(originId === destId){ showValidation('Port of Origin and Final Destination cannot be the same.'); return; }
                const payload = { routeName:name, portOfOriginId:originId, finalDestinationId:destId };
                const resp = await fetch('/RouteMasters/InlineCreate',{ method:'POST', headers:{ 'Content-Type':'application/json','RequestVerificationToken': token() }, body: JSON.stringify(payload) });
                if(resp.ok){
                    const data = await resp.json();
                    const tr = document.createElement('tr');
                    tr.setAttribute('data-id', data.id);
                    tr.innerHTML = `
                        <td class="col-name"><span class="disp">${data.routeName||''}</span><input class="form-control form-control-sm edit d-none" value="${data.routeName||''}" /></td>
                        <td class="col-origin"><span class="disp">${data.portOfOriginName||''}</span><select class="form-select form-select-sm edit d-none">${q('#new-origin').innerHTML}</select></td>
                        <td class="col-dest"><span class="disp">${data.finalDestinationName||''}</span><select class="form-select form-select-sm edit d-none">${q('#new-dest').innerHTML}</select></td>
                        <td><div class="d-flex gap-2 align-items-center">
                            <button type="button" class="btn btn-sm btn-outline-primary btn-edit" title="Edit"><i class="bi bi-pencil"></i></button>
                            <button type="button" class="btn btn-sm btn-success d-none btn-save" title="Save"><i class="bi bi-check-lg"></i></button>
                            <button type="button" class="btn btn-sm btn-secondary d-none btn-cancel" title="Cancel"><i class="bi bi-x-lg"></i></button>
                            <form action="/RouteMasters/Delete" method="post" class="d-inline m-0">
                                <input type="hidden" name="__RequestVerificationToken" value="${token()}" />
                                <input type="hidden" name="id" value="${data.id}" />
                                <button type="submit" class="btn btn-sm btn-outline-danger" title="Delete" onclick="return confirm('Delete this route?');"><i class="bi bi-trash"></i></button>
                            </form>
                        </div></td>`;
                    if(originId) tr.querySelector('.col-origin select').value = originId;
                    if(destId) tr.querySelector('.col-dest select').value = destId;
                    newRow.after(tr);
                    wireEditRow(tr);
                    rows.push(tr);
                    hideNewRow();
                    if(total) total.textContent = parseInt(total.textContent||'0',10)+1;
                    showToast('Route created');
                } else { const err = await resp.text(); showValidation(err); }
            });

            // Extracted so new rows can reuse the edit wiring
            function wireEditRow(r){
                const edit=r.querySelector('.btn-edit'); const save=r.querySelector('.btn-save'); const cancel=r.querySelector('.btn-cancel');
                const toggle=()=>{ r.querySelectorAll('.disp').forEach(e=>e.classList.toggle('d-none')); r.querySelectorAll('.edit').forEach(e=>e.classList.toggle('d-none')); edit.classList.toggle('d-none'); save.classList.toggle('d-none'); cancel.classList.toggle('d-none'); };
                let orig=null;
                edit?.addEventListener('click',()=>{ orig={ name:r.querySelector('.col-name input').value, origin:r.querySelector('.col-origin select').value, dest:r.querySelector('.col-dest select').value }; toggle(); });
                cancel?.addEventListener('click',()=>{ if(orig){ r.querySelector('.col-name input').value=orig.name; r.querySelector('.col-origin select').value=orig.origin; r.querySelector('.col-dest select').value=orig.dest; } toggle(); hideValidation(); });
                save?.addEventListener('click', async ()=>{
                    hideValidation();
                    const payload = { id:r.getAttribute('data-id'), routeName:r.querySelector('.col-name input').value, portOfOriginId:r.querySelector('.col-origin select').value, finalDestinationId:r.querySelector('.col-dest select').value };
                    if(payload.portOfOriginId === payload.finalDestinationId){ showValidation('Port of Origin and Final Destination cannot be the same.'); return; }
                    const resp = await fetch('/RouteMasters/InlineUpdate',{ method:'POST', headers:{ 'Content-Type':'application/json','RequestVerificationToken': token() }, body: JSON.stringify(payload)});
                    if (resp.ok){ const data=await resp.json(); r.querySelector('.col-name .disp').textContent=data.routeName||payload.routeName; r.querySelector('.col-origin .disp').textContent=data.portOfOriginName||''; r.querySelector('.col-dest .disp').textContent=data.finalDestinationName||''; toggle(); showToast('Saved'); }
                    else { const err = await resp.text(); showValidation(err); }
                });
            }
        })();
    </script>
}
