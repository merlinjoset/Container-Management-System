@model IEnumerable<ContainerManagement.Application.Dtos.Slots.SlotListItemDto>

@{
    ViewData["Title"] = "Slots";
    ViewData["ShowNew"] = false;
}

@section Styles{
    <link rel="stylesheet" href="~/css/ui-common.css" asp-append-version="true" />
    <style>
        .op-toast { position: fixed; right: 1rem; bottom: 1rem; background: #111827; color: #fff; padding: .5rem .75rem; border-radius: .375rem; opacity: 0; transition: opacity .2s ease; }
        .op-toast.show { opacity: .95; }
    </style>
}

<div class="operator-page">
    <div class="page-header">Slots</div>
    <div class="d-flex gap-2 toolbar align-items-center">
        <button type="button" class="btn btn-outline-secondary btn-sm" id="btn-new-slot" data-bs-toggle="tooltip" title="New">
            <i class="bi bi-plus-square"></i>
        </button>
        @await Html.PartialAsync("_GridToolbar")
    </div>

    <div class="content">
        <div class="left-grid">
            <div class="grid-card">
                <div class="grid-header">
                    <div>Slot Data</div>
                    <span class="badge badge-count" id="slot-total">@(Model?.Count() ?? 0)</span>
                </div>

                <div class="table-wrapper">
                    <table class="table table-sm mb-0 sticky" id="slotsTable">
                        <thead>
                            <tr>
                                <th>Slot Name</th>
                                <th style="width:120px;">Actions</th>
                            </tr>
                            <tr class="filter-row">
                                <th><input id="cf-name" class="form-control form-control-sm" placeholder="Filter..." /></th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody id="slot-grid-body">
                        @* -- Inline create row (hidden by default) -- *@
                        <tr id="new-row" class="table-info d-none">
                            <td class="col-name">
                                <input class="form-control form-control-sm" id="new-name" placeholder="Slot Name" maxlength="150" />
                            </td>
                            <td>
                                <div class="d-flex gap-2 align-items-center">
                                    <button type="button" class="btn btn-sm btn-success" id="btn-save-new" data-bs-toggle="tooltip" title="Save"><i class="bi bi-check-lg"></i></button>
                                    <button type="button" class="btn btn-sm btn-secondary" id="btn-cancel-new" data-bs-toggle="tooltip" title="Cancel"><i class="bi bi-x-lg"></i></button>
                                </div>
                            </td>
                        </tr>
                        @if (Model?.Any() == true)
                        {
                            foreach (var s in Model)
                            {
                                <tr data-id="@s.Id">
                                    <td class="col-name">
                                        <span class="disp">@s.SlotName</span>
                                        <input class="form-control form-control-sm edit d-none" value="@s.SlotName" maxlength="150" />
                                    </td>
                                    <td>
                                        <div class="d-flex gap-2 align-items-center">
                                            <button type="button" class="btn btn-sm btn-outline-primary btn-edit" data-bs-toggle="tooltip" title="Edit"><i class="bi bi-pencil"></i></button>
                                            <button type="button" class="btn btn-sm btn-success d-none btn-save" data-bs-toggle="tooltip" title="Save"><i class="bi bi-check-lg"></i></button>
                                            <button type="button" class="btn btn-sm btn-secondary d-none btn-cancel" data-bs-toggle="tooltip" title="Cancel"><i class="bi bi-x-lg"></i></button>
                                            <form asp-action="Delete" method="post" class="d-inline m-0">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@s.Id" />
                                                <button type="submit" class="btn btn-sm btn-outline-danger" data-bs-toggle="tooltip" title="Delete" onclick="return confirm('Delete this slot?');"><i class="bi bi-trash"></i></button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
        <div class="right-blank"></div>
    </div>
</div>

<div id="slot-toast" class="op-toast" role="status" aria-live="polite"></div>
<form id="slot-af">@Html.AntiForgeryToken()</form>

@section Scripts{
    <script>
        (function(){
            const q = (s)=>document.querySelector(s);
            const rows = Array.from(document.querySelectorAll('#slot-grid-body tr[data-id]'));
            const total = q('#slot-total');
            const refreshBtn = q('#grid-refresh');
            const toast = q('#slot-toast');
            function showToast(msg){ if (!toast) return; toast.textContent = msg; toast.classList.add('show'); setTimeout(()=>toast.classList.remove('show'), 1500); }
            function applyFilter(){
                const name = (q('#cf-name')?.value || '').toLowerCase();
                let count=0;
                rows.forEach(r=>{
                    const n = r.querySelector('.col-name .disp').textContent.toLowerCase();
                    const show = !name || n.includes(name);
                    r.style.display = show ? '' : 'none';
                    if (show) count++;
                });
                if (total) total.textContent = count;
            }
            q('#cf-name')?.addEventListener('input', applyFilter);
            refreshBtn?.addEventListener('click', ()=>{ applyFilter(); showToast('Grid refreshed'); });
            function token(){ const el=document.querySelector('#slot-af input[name="__RequestVerificationToken"]'); return el?el.value:''; }
            rows.forEach(r=> wireEditRow(r));
            applyFilter();

            // -- Inline Create --
            const newRow = q('#new-row');
            const btnNew = q('#btn-new-slot');
            const btnSaveNew = q('#btn-save-new');
            const btnCancelNew = q('#btn-cancel-new');

            function showNewRow(){ newRow.classList.remove('d-none'); q('#new-name')?.focus(); }
            function hideNewRow(){ newRow.classList.add('d-none'); q('#new-name').value=''; }

            btnNew?.addEventListener('click', showNewRow);
            btnCancelNew?.addEventListener('click', hideNewRow);

            btnSaveNew?.addEventListener('click', async ()=>{
                const name = q('#new-name').value.trim();
                if(!name){ alert('Slot Name is required.'); return; }
                const payload = { slotName: name };
                const resp = await fetch('/SlotMasters/InlineCreate',{ method:'POST', headers:{ 'Content-Type':'application/json','RequestVerificationToken': token() }, body: JSON.stringify(payload) });
                if(resp.ok){
                    const data = await resp.json();
                    const tr = document.createElement('tr');
                    tr.setAttribute('data-id', data.id);
                    tr.innerHTML = `
                        <td class="col-name"><span class="disp">${data.slotName||''}</span><input class="form-control form-control-sm edit d-none" value="${data.slotName||''}" maxlength="150" /></td>
                        <td><div class="d-flex gap-2 align-items-center">
                            <button type="button" class="btn btn-sm btn-outline-primary btn-edit" title="Edit"><i class="bi bi-pencil"></i></button>
                            <button type="button" class="btn btn-sm btn-success d-none btn-save" title="Save"><i class="bi bi-check-lg"></i></button>
                            <button type="button" class="btn btn-sm btn-secondary d-none btn-cancel" title="Cancel"><i class="bi bi-x-lg"></i></button>
                            <form action="/SlotMasters/Delete" method="post" class="d-inline m-0">
                                <input type="hidden" name="__RequestVerificationToken" value="${token()}" />
                                <input type="hidden" name="id" value="${data.id}" />
                                <button type="submit" class="btn btn-sm btn-outline-danger" title="Delete" onclick="return confirm('Delete this slot?');"><i class="bi bi-trash"></i></button>
                            </form>
                        </div></td>`;
                    newRow.after(tr);
                    wireEditRow(tr);
                    rows.push(tr);
                    hideNewRow();
                    if(total) total.textContent = parseInt(total.textContent||'0',10)+1;
                    showToast('Slot created');
                } else { const err = await resp.text(); alert('Failed to create: ' + err); }
            });

            // Extracted so new rows can reuse the edit wiring
            function wireEditRow(r){
                const edit=r.querySelector('.btn-edit'); const save=r.querySelector('.btn-save'); const cancel=r.querySelector('.btn-cancel');
                const toggle=()=>{ r.querySelectorAll('.disp').forEach(e=>e.classList.toggle('d-none')); r.querySelectorAll('.edit').forEach(e=>e.classList.toggle('d-none')); edit.classList.toggle('d-none'); save.classList.toggle('d-none'); cancel.classList.toggle('d-none'); };
                let orig=null;
                edit?.addEventListener('click',()=>{ orig={ name: r.querySelector('.col-name input').value }; toggle(); });
                cancel?.addEventListener('click',()=>{ if(orig){ r.querySelector('.col-name input').value=orig.name; } toggle(); });
                save?.addEventListener('click', async ()=>{
                    const payload = { id: r.getAttribute('data-id'), slotName: r.querySelector('.col-name input').value };
                    const resp = await fetch('/SlotMasters/InlineUpdate',{ method:'POST', headers:{ 'Content-Type':'application/json','RequestVerificationToken': token() }, body: JSON.stringify(payload)});
                    if (resp.ok){ const data=await resp.json(); r.querySelector('.col-name .disp').textContent = data.slotName||payload.slotName; toggle(); showToast('Saved'); }
                    else { const err = await resp.text(); alert('Failed to save: ' + err); }
                });
            }
        })();
    </script>
}
