@using System.Security.Claims
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Container Processing & Customer Compliance System - @ViewData["Title"]</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ContainerManagement.Web.styles.css" asp-append-version="true" />

    <style>
        .app-navbar {
            background: linear-gradient(90deg, #0f172a, #111827);
        }

            .app-navbar .nav-link {
                color: rgba(255,255,255,.85) !important;
                border-radius: .5rem;
                padding: .45rem .8rem;
            }

                .app-navbar .nav-link:hover {
                    background: rgba(255,255,255,.08);
                    color: #fff !important;
                }

                .app-navbar .nav-link.active {
                    background: rgba(255,255,255,.14);
                    color: #fff !important;
                }

            .app-navbar .navbar-brand {
                color: #fff !important;
                font-weight: 600;
                letter-spacing: .2px;
            }

        .app-logo-slot {
            width: 36px;
            height: 36px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border-radius: .5rem;
            background: rgba(255,255,255,.10);
            border: 1px solid rgba(255,255,255,.18);
            color: #fff;
            font-weight: 700;
            font-size: .9rem;
        }

            .app-logo-slot img {
                width: 100%;
                height: 100%;
                object-fit: contain;
                border-radius: .4rem;
                display: block;
            }

        .user-pill {
            background: rgba(255,255,255,.10);
            border: 1px solid rgba(255,255,255,.18);
            color: rgba(255,255,255,.92);
            padding: .35rem .65rem;
            border-radius: 999px;
            font-size: .9rem;
            display: inline-flex;
            gap: .35rem;
            align-items: center;
        }

        .app-container {
            min-height: calc(100vh - 120px);
        }

        .app-footer {
            background: #f8fafc;
        }

        /* ── Top menu bar ── */
        .app-topmenu {
            background: #fff;
            border-bottom: 1px solid #e5e7eb;
            box-shadow: 0 1px 3px rgba(0,0,0,.04);
            padding: 0 1rem;
            position: sticky;
            top: 0;
            z-index: 1020;
        }
        .app-topmenu .navbar-nav { gap: 0; }
        .app-topmenu .nav-item { position: relative; }
        .app-topmenu .nav-link {
            color: #374151 !important;
            font-size: .8rem;
            font-weight: 500;
            padding: .6rem .75rem;
            border-radius: 0;
            border-bottom: 2px solid transparent;
            white-space: nowrap;
        }
        .app-topmenu .nav-link:hover {
            color: #0f172a !important;
            background: #f1f5f9;
            border-bottom-color: #cbd5e1;
        }
        .app-topmenu .nav-link.active {
            color: #0f172a !important;
            background: transparent;
            border-bottom-color: #0f172a;
            font-weight: 600;
        }
        .app-topmenu .dropdown-menu {
            font-size: .8rem;
            border: 1px solid #e5e7eb;
            box-shadow: 0 8px 24px rgba(0,0,0,.1);
            border-radius: .5rem;
            padding: .35rem 0;
            min-width: 180px;
        }
        .app-topmenu .dropdown-item {
            padding: .4rem .85rem;
            font-size: .8rem;
            color: #374151;
        }
        .app-topmenu .dropdown-item:hover { background: #f1f5f9; color: #0f172a; }
        .app-topmenu .dropdown-item.active,
        .app-topmenu .dropdown-item:active { background: #0f172a; color: #fff; }
        .app-topmenu .dropdown-header {
            font-size: .65rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: .5px;
            color: #9ca3af;
            padding: .4rem .85rem .2rem;
        }
        .app-topmenu .dropdown-divider { margin: .25rem 0; }

        /* Sticky table header utility */
        table.sticky thead th {
            position: sticky;
            top: 0;
            background: #1e293b;
            color: #fff;
            z-index: 1;
        }
        table.sticky thead tr.filter-row th {
            position: sticky;
            top: 42px;
            background: #eef2f7;
            color: #111827;
            z-index: 1;
            border-bottom: 1px solid #d1d5db;
        }
        table.sticky thead tr.filter-row input,
        table.sticky thead tr.filter-row select {
            width: 100%;
            padding: .25rem .4rem;
            border: 1px solid #cbd5e1;
            border-radius: .25rem;
            font-size: .875rem;
        }

        @@media (max-width: 991.98px) {
            .app-topmenu .navbar-collapse { padding: .5rem 0; }
            .app-topmenu .nav-link { padding: .5rem .6rem; }
        }

        @@media (min-width: 1400px) {
            .container-xxl, .container-xl, .container-lg, .container-md, .container-sm, .container {
                max-width: 100% !important;
            }
        }

        .operator-page .table { font-size: .75rem; }
        .operator-page .table .btn { font-size: .7rem; padding: .15rem .35rem; }
        .operator-page .table .btn i { font-size: .7rem; }
        .operator-page .table .form-control, .operator-page .table .form-select { font-size: .75rem; padding: .2rem .35rem; }

        /* ── Open-tabs bar (browser-style) ── */
        .app-tabbar {
            background: #1e293b;
            padding: 0 .5rem;
            display: flex;
            align-items: flex-end;
            gap: 1px;
            overflow-x: auto;
            min-height: 34px;
            scrollbar-width: thin;
            scrollbar-color: rgba(255,255,255,.15) transparent;
        }
        .app-tabbar::-webkit-scrollbar { height: 3px; }
        .app-tabbar::-webkit-scrollbar-thumb { background: rgba(255,255,255,.15); border-radius: 3px; }
        .app-tabbar:empty { display: none; }
        .app-tab {
            display: inline-flex;
            align-items: center;
            gap: .4rem;
            background: #334155;
            border: none;
            border-radius: .45rem .45rem 0 0;
            padding: .38rem .5rem .38rem .7rem;
            font-size: .73rem;
            font-weight: 500;
            color: #ffffff;
            white-space: nowrap;
            cursor: pointer;
            text-decoration: none;
            transition: all .15s;
            position: relative;
            max-width: 180px;
        }
        .app-tab-label {
            overflow: hidden;
            text-overflow: ellipsis;
        }
        .app-tab:hover { background: #475569; color: #e2e8f0; text-decoration: none; }
        .app-tab.active {
            background: #f8fafc;
            color: #0f172a;
            font-weight: 600;
            z-index: 1;
        }
        .app-tab-icon {
            font-size: .65rem;
            opacity: .7;
        }
        .app-tab.active .app-tab-icon { opacity: 1; color: #3b82f6; }
        .app-tab-close {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 18px;
            height: 18px;
            border-radius: .25rem;
            border: none;
            background: transparent;
            color: inherit;
            font-size: .55rem;
            padding: 0;
            cursor: pointer;
            opacity: 0;
            transition: opacity .12s, background .12s;
            flex-shrink: 0;
        }
        .app-tab:hover .app-tab-close { opacity: .6; }
        .app-tab-close:hover { opacity: 1 !important; background: rgba(239,68,68,.15); color: #ef4444; }
        .app-tab.active .app-tab-close:hover { background: rgba(239,68,68,.1); color: #dc2626; }
    </style>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="bg-light">
    <div id="globalPageLoader" class="global-page-loader" aria-live="polite" aria-busy="false">
        <div class="global-page-loader__panel" role="status">
            <div class="spinner-border text-primary" aria-hidden="true"></div>
            <span class="global-page-loader__text">Loading...</span>
        </div>
    </div>

    @{
        var path = Context?.Request?.Path.Value?.ToLowerInvariant() ?? "";
        var isPorts = path.StartsWith("/ports");
        var isRegions = path.StartsWith("/regions");
        var isCountries = path.StartsWith("/countries");
        var isTerminals = path.StartsWith("/terminals");
        var isVessels = path.StartsWith("/vessels");
        var isVendors = path.StartsWith("/vendors");
        var isOperators = path.StartsWith("/operators");
        var isServices = path.StartsWith("/servicemasters");
        var isRoutes = path.StartsWith("/routemasters");
        var isDistances = path.StartsWith("/distancemasters");
        var isSlots = path.StartsWith("/slotmasters");
        var isVoyages = path.StartsWith("/voyages");
        var isProviders = path.StartsWith("/providers");
        var isUsers = path.StartsWith("/users");
        var isAccount = path.StartsWith("/account");
        var isJobs = path.StartsWith("/jobs");
        var isSchedules = path.StartsWith("/schedules");

        var globalMastersActive = isOperators || isVessels || isRegions || isCountries || isPorts || isTerminals || isVendors || isServices || isRoutes || isDistances || isSlots;
        var scheduleActive = isSchedules || isVoyages;

        var display =
        User.FindFirstValue(ClaimTypes.Email)
        ?? User.Identity?.Name
        ?? User.FindFirstValue(ClaimTypes.NameIdentifier)
        ?? "User";
    }

    <header>
        <nav class="navbar app-navbar shadow-sm">
            <div class="container-fluid px-3">
                <a class="navbar-brand d-flex align-items-center gap-2" asp-controller="Home" asp-action="Index">
                    <span class="app-logo-slot me-1">CM</span>
                    <span>Container Processing & Customer Compliance System</span>
                </a>

                <ul class="navbar-nav ms-auto align-items-center gap-2 flex-row">
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <li class="nav-item my-2 my-lg-0">
                            <span class="user-pill">
                                <span style="width:8px;height:8px;border-radius:50%;background:#22c55e;display:inline-block;"></span>
                                <span>Signed in</span>
                                <strong class="ms-1">@display</strong>
                            </span>
                        </li>
                        <li class="nav-item">
                            <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-outline-light btn-sm">Logout</button>
                            </form>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="btn btn-outline-light btn-sm" asp-controller="Account" asp-action="Login">Login</a>
                        </li>
                    }
                </ul>
            </div>
        </nav>
    </header>

    @* ── Top Menu Bar ── *@
    @if (User.Identity?.IsAuthenticated == true)
    {
        <nav class="navbar navbar-expand-lg app-topmenu">
            <div class="container-fluid px-2">
                <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#topMenuCollapse">
                    <i class="bi bi-list fs-5"></i>
                </button>
                <div class="collapse navbar-collapse" id="topMenuCollapse">
                    <ul class="navbar-nav">

                        @* Job Dashboard *@
                        <li class="nav-item">
                            <a class="nav-link @(isJobs ? "active" : "")" asp-controller="Jobs" asp-action="Index">
                                <i class="bi bi-kanban me-1"></i>Dashboard
                            </a>
                        </li>

                        @* Masters dropdown *@
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle @(globalMastersActive ? "active" : "")" href="#" role="button" data-bs-toggle="dropdown" data-bs-auto-close="outside">
                                <i class="bi bi-gear me-1"></i>Masters
                            </a>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item @(isRegions ? "active" : "")" asp-controller="Regions" asp-action="Index">Regions</a></li>
                                <li><a class="dropdown-item @(isCountries ? "active" : "")" asp-controller="Countries" asp-action="Index">Countries</a></li>
                                <li><a class="dropdown-item @(isPorts ? "active" : "")" asp-controller="Ports" asp-action="Index">Ports</a></li>
                                <li><a class="dropdown-item @(isTerminals ? "active" : "")" asp-controller="Terminals" asp-action="Index">Terminals</a></li>
                                <li><a class="dropdown-item @(isVendors ? "active" : "")" asp-controller="Vendors" asp-action="Index">Vendors</a></li>
                                <li><a class="dropdown-item @(isOperators ? "active" : "")" asp-controller="Operators" asp-action="Index">Operators</a></li>
                                <li><a class="dropdown-item @(isVessels ? "active" : "")" asp-controller="Vessels" asp-action="Index">Vessels</a></li>
                                <li><hr class="dropdown-divider" /></li>
                                <li><a class="dropdown-item @(isServices ? "active" : "")" asp-controller="ServiceMasters" asp-action="Index">Services</a></li>
                                <li><a class="dropdown-item @(isRoutes ? "active" : "")" asp-controller="RouteMasters" asp-action="Index">Routes</a></li>
                                <li><a class="dropdown-item @(isDistances ? "active" : "")" asp-controller="DistanceMasters" asp-action="Index">Distances</a></li>
                                <li><a class="dropdown-item @(isSlots ? "active" : "")" asp-controller="SlotMasters" asp-action="Index">Slots</a></li>
                            </ul>
                        </li>

                        @* Operations (placeholder) *@
                        <li class="nav-item">
                            <a class="nav-link" href="#"><i class="bi bi-box-seam me-1"></i>Operations</a>
                        </li>

                        @* Schedule dropdown *@
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle @(scheduleActive ? "active" : "")" href="#" role="button" data-bs-toggle="dropdown">
                                <i class="bi bi-calendar3 me-1"></i>Schedule
                            </a>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item @(isVoyages ? "active" : "")" asp-controller="Voyages" asp-action="Index">Voyages</a></li>
                                <li><a class="dropdown-item @(isSchedules && path.Contains("/viewer") ? "active" : "")" asp-controller="Schedules" asp-action="Viewer">Schedule Viewer</a></li>
                            </ul>
                        </li>

                        @* Placeholder menus *@
                        @{
                            var others = new[] {
                                ContainerManagement.Web.Models.Navigation.MainMenu.Commercial,
                                ContainerManagement.Web.Models.Navigation.MainMenu.CustomerService,
                                ContainerManagement.Web.Models.Navigation.MainMenu.Documentation,
                                ContainerManagement.Web.Models.Navigation.MainMenu.Contract,
                                ContainerManagement.Web.Models.Navigation.MainMenu.EMS,
                                ContainerManagement.Web.Models.Navigation.MainMenu.EDI
                            };
                            foreach (var m in others)
                            {
                                var url = Url.NavigateToMainMenu(m);
                                var active = path.StartsWith(url, StringComparison.OrdinalIgnoreCase) ? "active" : "";
                                <li class="nav-item">
                                    <a class="nav-link @active" href="@url">@m.GetDisplayName()</a>
                                </li>
                            }
                        }

                    </ul>
                </div>
            </div>
        </nav>
    }

    @* ── Open Tabs Bar ── *@
    @if (User.Identity?.IsAuthenticated == true)
    {
        <div class="app-tabbar" id="appTabBar"></div>
    }

    <div class="container-fluid app-container py-3 px-4">
        <main role="main">
            @await Html.PartialAsync("_Alerts")
            @RenderBody()
        </main>
    </div>

    <footer class="border-top app-footer text-muted py-3">
        <div class="container d-flex justify-content-between align-items-center">
            <div>&copy; @DateTime.UtcNow.Year - Container Processing & Customer Compliance System</div>
            <div class="small">Container Processing & Customer Compliance System</div>
        </div>
    </footer>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.7/signalr.min.js"></script>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
    <script>
        // ─── Global .date-dmy mask, validation, and editing handlers ───
        // Applies dd/mm/yyyy formatting + range clamps (dd ≤ 31, mm ≤ 12) to any
        // <input class="date-dmy"> across the entire app, including dynamically
        // added rows. Single source of truth — per-view duplication not needed.
        (function () {
            function clampDay(d)   { return (d.length === 2 && parseInt(d, 10) > 31) ? d[0] : d; }
            function clampMonth(m) { return (m.length === 2 && parseInt(m, 10) > 12) ? m[0] : m; }

            window.maskDateDmy = function (v) {
                if (v.indexOf('/') !== -1) {
                    var parts = v.split('/');
                    var d = clampDay((parts[0] || '').replace(/[^\d]/g, '').slice(0, 2));
                    var m = clampMonth((parts[1] || '').replace(/[^\d]/g, '').slice(0, 2));
                    var y = (parts.slice(2).join('') || '').replace(/[^\d]/g, '').slice(0, 4);
                    var out = d;
                    if (parts.length >= 2) {
                        out += '/' + m;
                        // No "//" — only show year segment when month has content
                        if (parts.length >= 3 && m !== '') out += '/' + y;
                    }
                    return out;
                }
                var digits = v.replace(/[^\d]/g, '');
                if (digits.length > 8) digits = digits.slice(0, 8);
                if (digits.length >= 2 && parseInt(digits.slice(0, 2), 10) > 31) digits = digits[0];
                if (digits.length >= 4 && parseInt(digits.slice(2, 4), 10) > 12) digits = digits.slice(0, 3);
                if (digits.length >= 5) return digits.slice(0, 2) + '/' + digits.slice(2, 4) + '/' + digits.slice(4);
                if (digits.length >= 3) return digits.slice(0, 2) + '/' + digits.slice(2);
                return digits;
            };

            // Input handler — masks value, preserves cursor, on delete keeps cursor in place
            document.addEventListener('input', function (ev) {
                var el = ev.target;
                if (!el || !el.classList || !el.classList.contains('date-dmy')) return;

                var oldVal = el.value, oldCursor = el.selectionStart || 0;
                var digitsBefore = 0;
                for (var i = 0; i < oldCursor; i++) {
                    if (/\d/.test(oldVal[i])) digitsBefore++;
                }
                var v = window.maskDateDmy(oldVal);
                if (v === oldVal) return; // no change, no need to touch cursor
                el.value = v;
                var newCursor = 0, digitCount = 0;
                while (newCursor < v.length && digitCount < digitsBefore) {
                    if (/\d/.test(v[newCursor])) digitCount++;
                    newCursor++;
                }
                var isDelete = ev && ev.inputType && ev.inputType.indexOf('delete') !== -1;
                if (!isDelete && v[newCursor] === '/') newCursor++;
                try { el.setSelectionRange(newCursor, newCursor); } catch (e) { }
            }, true);

            function setDateError(el, msg) {
                el.classList.add('is-invalid');
                // Show only on hover via native browser tooltip
                el.setAttribute('title', msg);
                el.setAttribute('data-date-error', msg);
            }
            function clearDateError(el) {
                el.classList.remove('is-invalid');
                el.removeAttribute('title');
                el.removeAttribute('data-date-error');
            }

            // Blur — validate dd/mm/yyyy and set a descriptive error message if invalid
            document.addEventListener('blur', function (ev) {
                var el = ev.target;
                if (!el || !el.classList || !el.classList.contains('date-dmy')) return;
                var v = (el.value || '').trim();
                if (!v) { clearDateError(el); return; }
                var m = v.match(/^(\d{2})\/(\d{2})\/(\d{4})$/);
                if (!m) {
                    setDateError(el, 'Invalid format — please enter date as dd/mm/yyyy');
                    return;
                }
                var dd = parseInt(m[1], 10), mm = parseInt(m[2], 10), yyyy = parseInt(m[3], 10);
                if (dd < 1 || dd > 31) {
                    setDateError(el, 'Day must be between 1 and 31'); return;
                }
                if (mm < 1 || mm > 12) {
                    setDateError(el, 'Month must be between 1 and 12'); return;
                }
                if (yyyy < 2000 || yyyy > 2099) {
                    setDateError(el, 'Year must be between 2000 and 2099'); return;
                }
                var test = new Date(yyyy, mm - 1, dd);
                if (test.getDate() !== dd || test.getMonth() !== mm - 1) {
                    var monthName = ['January','February','March','April','May','June','July','August','September','October','November','December'][mm - 1];
                    setDateError(el, 'Invalid date — ' + monthName + ' ' + yyyy + ' does not have day ' + dd);
                    return;
                }
                clearDateError(el);
            }, true);

            document.addEventListener('focus', function (ev) {
                var el = ev.target;
                if (el && el.classList && el.classList.contains('date-dmy')) {
                    clearDateError(el);
                }
            }, true);

            // Keydown — when field is full, digit keypress REPLACES instead of inserts
            // so editing month/day doesn't shift the year. Also enforces dd ≤ 31, mm ≤ 12.
            document.addEventListener('keydown', function (e) {
                var el = e.target;
                if (!el || !el.classList || !el.classList.contains('date-dmy')) return;
                if (!/^[0-9]$/.test(e.key) || e.ctrlKey || e.altKey || e.metaKey) return;

                var val = el.value || '';
                var start = el.selectionStart || 0;
                var end = el.selectionEnd || 0;
                if (start !== end) return; // selection — let default replace run

                var totalDigits = (val.match(/\d/g) || []).length;
                if (totalDigits < 8) return; // not full — allow insert

                e.preventDefault();
                var pos = start;
                while (pos < val.length && !/\d/.test(val[pos])) pos++;
                if (pos >= val.length) return;

                var newVal = val.substring(0, pos) + e.key + val.substring(pos + 1);

                // Reject keystrokes that would create dd > 31 or mm > 12
                var ddPart = newVal.substring(0, 2);
                var mmPart = newVal.substring(3, 5);
                if (ddPart.length === 2 && /^\d{2}$/.test(ddPart) && parseInt(ddPart, 10) > 31) return;
                if (mmPart.length === 2 && /^\d{2}$/.test(mmPart) && parseInt(mmPart, 10) > 12) return;

                el.value = newVal;
                var newPos = pos + 1;
                if (newVal[newPos] === '/') newPos++;
                try { el.setSelectionRange(newPos, newPos); } catch (ex) { }
            }, true);
        })();

        // ─── Global .time-24 mask (HH:MM, 0-23 / 0-59) ───
        (function () {
            window.maskTime24 = function (v) {
                var digits = v.replace(/[^\d]/g, '').slice(0, 4);
                // Clamp first 2 (hours) ≤ 23
                if (digits.length >= 2 && parseInt(digits.slice(0, 2), 10) > 23) digits = digits[0];
                // Clamp 3rd-4th (minutes) ≤ 59
                if (digits.length >= 4 && parseInt(digits.slice(2, 4), 10) > 59) digits = digits.slice(0, 3);
                if (digits.length >= 3) return digits.slice(0, 2) + ':' + digits.slice(2);
                return digits;
            };

            document.addEventListener('input', function (ev) {
                var el = ev.target;
                if (!el || !el.classList || !el.classList.contains('time-24')) return;
                var oldVal = el.value, oldCursor = el.selectionStart || 0;
                var digitsBefore = 0;
                for (var i = 0; i < oldCursor; i++) {
                    if (/\d/.test(oldVal[i])) digitsBefore++;
                }
                var v = window.maskTime24(oldVal);
                if (v === oldVal) return;
                el.value = v;
                var newCursor = 0, digitCount = 0;
                while (newCursor < v.length && digitCount < digitsBefore) {
                    if (/\d/.test(v[newCursor])) digitCount++;
                    newCursor++;
                }
                var isDelete = ev && ev.inputType && ev.inputType.indexOf('delete') !== -1;
                if (!isDelete && v[newCursor] === ':') newCursor++;
                try { el.setSelectionRange(newCursor, newCursor); } catch (e) { }
            }, true);

            function setTimeError(el, msg) {
                el.classList.add('is-invalid');
                // Show only on hover via native browser tooltip
                el.setAttribute('title', msg);
            }
            function clearTimeError(el) {
                el.classList.remove('is-invalid');
                el.removeAttribute('title');
            }

            document.addEventListener('blur', function (ev) {
                var el = ev.target;
                if (!el || !el.classList || !el.classList.contains('time-24')) return;
                var v = (el.value || '').trim();
                if (!v) { clearTimeError(el); return; }
                var m = v.match(/^(\d{1,2}):(\d{2})$/);
                if (!m) {
                    setTimeError(el, 'Invalid format — please enter time as hh:mm (24-hour)');
                    return;
                }
                var hh = parseInt(m[1], 10), mm = parseInt(m[2], 10);
                if (hh > 23) { setTimeError(el, 'Hours must be between 00 and 23'); return; }
                if (mm > 59) { setTimeError(el, 'Minutes must be between 00 and 59'); return; }
                clearTimeError(el);
            }, true);

            document.addEventListener('focus', function (ev) {
                var el = ev.target;
                if (el && el.classList && el.classList.contains('time-24')) {
                    clearTimeError(el);
                }
            }, true);
        })();

        // ─── focusFirstInvalid: scroll & focus first .is-invalid input ───
        // Call this from save handlers (Arrival/Departure/TOS) before submitting
        // so users are taken straight to the field that needs fixing.
        window.focusFirstInvalid = function (root) {
            var scope = root || document;
            var first = scope.querySelector('.is-invalid');
            if (!first) return false;
            try {
                first.scrollIntoView({ behavior: 'smooth', block: 'center' });
                setTimeout(function () { try { first.focus(); } catch (e) { } }, 150);
            } catch (e) { try { first.focus(); } catch (e2) { } }
            return true;
        };
    </script>

    <script src="~/js/site.js" asp-append-version="true"></script>

    @if (User.Identity?.IsAuthenticated == true)
    {
    <script>
    (function() {
        const STORAGE_KEY = 'cm_open_tabs';
        const currentPath = window.location.pathname.toLowerCase().replace(/\/+$/, '') || '/';

        // path → { label, icon }
        const tabMeta = {
            '/jobs':              { label: 'Dashboard',  icon: 'bi-kanban' },
            '/operators':         { label: 'Operators',  icon: 'bi-building' },
            '/regions':           { label: 'Regions',    icon: 'bi-globe2' },
            '/countries':         { label: 'Countries',  icon: 'bi-flag' },
            '/ports':             { label: 'Ports',      icon: 'bi-geo-alt' },
            '/terminals':         { label: 'Terminals',  icon: 'bi-pin-map' },
            '/vendors':           { label: 'Vendors',    icon: 'bi-shop' },
            '/servicemasters':    { label: 'Services',   icon: 'bi-truck' },
            '/routemasters':      { label: 'Routes',     icon: 'bi-signpost-2' },
            '/distancemasters':   { label: 'Distances',  icon: 'bi-rulers' },
            '/slotmasters':       { label: 'Slots',      icon: 'bi-grid-3x3' },
            '/vessels':           { label: 'Vessels',    icon: 'bi-water' },
            '/voyages/arrival':   { label: 'Arrival',    icon: 'bi-clipboard-data' },
            '/voyages/departure': { label: 'Departure',  icon: 'bi-box-arrow-right' },
            '/voyages/tos':       { label: 'TOS',        icon: 'bi-clipboard2-data' },
            '/voyages':           { label: 'Voyages',    icon: 'bi-compass' },
            '/schedules':         { label: 'Schedules',  icon: 'bi-calendar3' },
            '/users':             { label: 'Users',      icon: 'bi-people' }
        };

        function getTabs() {
            try { return JSON.parse(localStorage.getItem(STORAGE_KEY)) || []; }
            catch { return []; }
        }
        function saveTabs(tabs) { localStorage.setItem(STORAGE_KEY, JSON.stringify(tabs)); }

        function getBaseRoute(href) {
            const p = href.toLowerCase().replace(/\/+$/, '');
            // Match longer prefixes first so /voyages/arrival wins over /voyages
            const prefixes = Object.keys(tabMeta).sort((a, b) => b.length - a.length);
            for (const prefix of prefixes) {
                if (p === prefix || p.startsWith(prefix + '/')) return prefix;
            }
            return p;
        }

        function getMeta(href) {
            const base = getBaseRoute(href);
            if (tabMeta[base]) return tabMeta[base];
            const seg = base.split('/').filter(Boolean).pop() || 'Page';
            return { label: seg.charAt(0).toUpperCase() + seg.slice(1), icon: 'bi-file-earmark' };
        }

        const MAX_TABS = 10;

        function addTab(href, label) {
            let tabs = getTabs();
            const base = getBaseRoute(href);
            if (!tabs.find(t => getBaseRoute(t.href) === base)) {
                if (tabs.length >= MAX_TABS) {
                    // Remove the oldest non-active tab
                    const currentBase = getBaseRoute(currentPath);
                    const idx = tabs.findIndex(t => getBaseRoute(t.href) !== currentBase);
                    if (idx !== -1) tabs.splice(idx, 1);
                    else return; // all tabs are active somehow, don't add
                }
                const meta = getMeta(href);
                tabs.push({ href, label: label || meta.label, icon: meta.icon });
                saveTabs(tabs);
            }
        }

        function removeTab(href) {
            let tabs = getTabs();
            const base = getBaseRoute(href);
            tabs = tabs.filter(t => getBaseRoute(t.href) !== base);
            saveTabs(tabs);
            return tabs;
        }

        function renderTabs() {
            const bar = document.getElementById('appTabBar');
            if (!bar) return;
            bar.innerHTML = '';
            const tabs = getTabs();
            if (tabs.length === 0) { bar.style.display = 'none'; return; }
            bar.style.display = '';

            const currentBase = getBaseRoute(currentPath);

            tabs.forEach((tab, idx) => {
                const tabBase = getBaseRoute(tab.href);
                const isActive = tabBase === currentBase;
                const meta = getMeta(tab.href);

                // Use a div instead of <a> to avoid accidental navigation on close
                const el = document.createElement('div');
                el.className = 'app-tab' + (isActive ? ' active' : '');
                el.style.cursor = 'pointer';

                // Click the tab label/icon area → navigate
                el.addEventListener('click', function() {
                    if (!isActive) window.location.href = tab.href;
                });

                // Icon
                const icon = document.createElement('i');
                icon.className = 'app-tab-icon bi ' + (tab.icon || meta.icon);
                el.appendChild(icon);

                // Label
                const lbl = document.createElement('span');
                lbl.className = 'app-tab-label';
                lbl.textContent = tab.label || meta.label;
                el.appendChild(lbl);

                // Close button
                const closeBtn = document.createElement('button');
                closeBtn.className = 'app-tab-close';
                closeBtn.innerHTML = '<i class="bi bi-x"></i>';
                closeBtn.title = 'Close tab';
                closeBtn.addEventListener('click', function(e) {
                    e.stopPropagation(); // don't trigger tab navigate

                    const allTabs = getTabs();
                    const closingIdx = allTabs.findIndex(t => getBaseRoute(t.href) === tabBase);
                    const rightNeighbor = closingIdx < allTabs.length - 1 ? allTabs[closingIdx + 1] : null;
                    const leftNeighbor = closingIdx > 0 ? allTabs[closingIdx - 1] : null;

                    const remaining = removeTab(tab.href);

                    if (isActive && remaining.length > 0) {
                        const next = rightNeighbor || leftNeighbor || remaining[0];
                        window.location.href = next.href;
                    } else {
                        // Non-active tab closed, or last tab closed — just re-render, no navigation
                        renderTabs();
                    }
                });
                el.appendChild(closeBtn);
                bar.appendChild(el);
            });
        }

        // Auto-add current page as a tab
        if (tabMeta[getBaseRoute(currentPath)]) {
            addTab(currentPath);
        }

        // Intercept menu clicks
        document.querySelectorAll('.app-topmenu .dropdown-item, .app-topmenu .nav-link').forEach(link => {
            const href = link.getAttribute('href');
            if (!href || href === '#' || href.startsWith('javascript')) return;
            link.addEventListener('click', function() {
                addTab(href, link.textContent.trim());
            });
        });

        renderTabs();
    })();
    </script>
    }

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
