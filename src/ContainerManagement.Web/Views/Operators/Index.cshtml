@model IEnumerable<ContainerManagement.Application.Dtos.Operators.OperatorListItemDto>
@{
    ViewData["Title"] = "Operator";
    ViewData["ShowNew"] = false;
}
@section Styles{
    <link rel="stylesheet" href="~/css/ui-common.css" asp-append-version="true" />
    <style>
        .op-toast { position: fixed; right: 1rem; bottom: 1rem; background: #111827; color: #fff; padding: .5rem .75rem; border-radius: .375rem; opacity: 0; transition: opacity .2s ease; }
        .op-toast.show { opacity: .95; }
        .badge-yes { background: #dc3545; color: #fff; font-size: .7rem; padding: .15rem .4rem; border-radius: .25rem; }
        .badge-no  { background: #6c757d; color: #fff; font-size: .7rem; padding: .15rem .4rem; border-radius: .25rem; }
    </style>
}

<div class="operator-page">
    <div class="page-header">Operator</div>
    <div class="d-flex gap-2 toolbar align-items-center">
        <button type="button" class="btn btn-outline-secondary btn-sm" id="btn-new-operator" data-bs-toggle="tooltip" title="New">
            <i class="bi bi-plus-square"></i>
        </button>
        @await Html.PartialAsync("_GridToolbar")
    </div>

    <div class="content">
        <div class="left-grid">
            <div class="grid-card">
                <div class="grid-header">
                    <div>Operator Data</div>
                    <span class="badge badge-count" id="op-total">@(Model?.Count() ?? 0)</span>
                </div>
                <div class="table-wrapper">
                    <table class="table table-sm mb-0 sticky">
                        <thead>
                            <tr>
                                <th>Operator Name</th>
                                <th>Vendor</th>
                                <th style="width:100px">Competitor</th>
                                <th style="width:130px;">Actions</th>
                            </tr>
                            <tr class="filter-row">
                                <th><input id="cf-name" class="form-control form-control-sm" placeholder="Filter..." /></th>
                                <th><input id="cf-vendor" class="form-control form-control-sm" placeholder="Filter..." /></th>
                                <th></th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody id="op-grid-body">
                        @* ── Inline create row (hidden by default) ── *@
                        <tr id="new-row" class="table-info d-none">
                            <td class="col-name">
                                <input class="form-control form-control-sm" id="new-name" placeholder="Operator Name" />
                            </td>
                            <td class="col-vendor">
                                <select class="form-select form-select-sm" id="new-vendor">
                                    <option value="">-- Vendor --</option>
                                    @if (ViewBag.Vendors is IEnumerable<SelectListItem> newVendors)
                                    { foreach (var v in newVendors){ <option value="@v.Value">@v.Text</option> } }
                                </select>
                            </td>
                            <td class="col-competitor">
                                <select class="form-select form-select-sm" id="new-competitor">
                                    <option value="false">No</option>
                                    <option value="true">Yes</option>
                                </select>
                            </td>
                            <td>
                                <div class="d-flex gap-2 align-items-center">
                                    <button type="button" class="btn btn-sm btn-success" id="btn-save-new" data-bs-toggle="tooltip" title="Save"><i class="bi bi-check-lg"></i></button>
                                    <button type="button" class="btn btn-sm btn-secondary" id="btn-cancel-new" data-bs-toggle="tooltip" title="Cancel"><i class="bi bi-x-lg"></i></button>
                                </div>
                            </td>
                        </tr>
                        @if (Model != null)
                        {
                            foreach (var item in Model)
                            {
                                <tr data-id="@item.Id">
                                    <td class="col-name">
                                        <span class="disp">@item.OperatorName</span>
                                        <input class="form-control form-control-sm edit d-none" value="@item.OperatorName" />
                                    </td>
                                    <td class="col-vendor">
                                        <span class="disp">@item.VendorName</span>
                                        <select class="form-select form-select-sm edit d-none">
                                            @if (ViewBag.Vendors is IEnumerable<SelectListItem> vendorItems)
                                            {
                                                foreach (var v in vendorItems)
                                                {
                                                    if (item.VendorId.ToString() == v.Value)
                                                    {
                                                        <option value="@v.Value" selected="selected">@v.Text</option>
                                                    }
                                                    else
                                                    {
                                                        <option value="@v.Value">@v.Text</option>
                                                    }
                                                }
                                            }
                                        </select>
                                    </td>
                                    <td class="col-competitor">
                                        @if (item.IsCompetitor)
                                        {
                                            <span class="disp badge-yes">Yes</span>
                                        }
                                        else
                                        {
                                            <span class="disp badge-no">No</span>
                                        }
                                        <select class="form-select form-select-sm edit d-none">
                                            @if (item.IsCompetitor)
                                            {
                                                <option value="false">No</option>
                                                <option value="true" selected="selected">Yes</option>
                                            }
                                            else
                                            {
                                                <option value="false" selected="selected">No</option>
                                                <option value="true">Yes</option>
                                            }
                                        </select>
                                    </td>
                                    <td>
                                        <div class="d-flex gap-2 align-items-center">
                                            <button type="button" class="btn btn-sm btn-outline-primary btn-edit" data-bs-toggle="tooltip" title="Edit" aria-label="Edit">
                                                <i class="bi bi-pencil"></i>
                                            </button>
                                            <button type="button" class="btn btn-sm btn-success d-none btn-save" data-bs-toggle="tooltip" title="Save" aria-label="Save">
            										<i class="bi bi-check-lg"></i>
                                            </button>
                                            <button type="button" class="btn btn-sm btn-secondary d-none btn-cancel" data-bs-toggle="tooltip" title="Cancel" aria-label="Cancel">
                                                <i class="bi bi-x-lg"></i>
                                            </button>
                                            <form asp-controller="Operators" asp-action="Delete" method="post" class="d-inline m-0">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@item.Id" />
                                                <button type="submit" class="btn btn-sm btn-outline-danger" data-bs-toggle="tooltip" title="Delete" aria-label="Delete" onclick="return confirm('Delete this operator?');">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
        <div class="right-blank"></div>
    </div>

</div>

<div id="op-toast" class="op-toast" role="status" aria-live="polite"></div>

@section Scripts{
    <form id="op-af-form">@Html.AntiForgeryToken()</form>
    <script>
        (function(){
            const q = (s) => document.querySelector(s);
            const rows = Array.from(document.querySelectorAll('#op-grid-body tr[data-id]'));
            const total = q('#op-total');
            const refreshBtn = q('#grid-refresh');
            const toast = q('#op-toast');
            function showToast(msg){ if(!toast) return; toast.textContent = msg; toast.classList.add('show'); setTimeout(()=>toast.classList.remove('show'), 1500); }
            function applyFilter(){
                const fName = (q('#cf-name')?.value || '').toLowerCase();
                const fVendor = (q('#cf-vendor')?.value || '').toLowerCase();
                let count = 0;
                rows.forEach(r => {
                    const name = r.querySelector('.col-name .disp')?.textContent.trim().toLowerCase() || '';
                    const vendor = r.querySelector('.col-vendor .disp')?.textContent.trim().toLowerCase() || '';
                    const show = (!fName || name.includes(fName)) && (!fVendor || vendor.includes(fVendor));
                    r.style.display = show ? '' : 'none';
                    if (show) count++;
                });
                if (total) total.textContent = count;
            }
            ['#cf-name','#cf-vendor'].forEach(id => {
                const el = q(id);
                if (el) el.addEventListener('input', applyFilter);
            });
            applyFilter();

            function getToken(){
                const el = document.querySelector('#op-af-form input[name="__RequestVerificationToken"]');
                return el ? el.value : '';
            }
            rows.forEach(r => wireEditRow(r));
            refreshBtn?.addEventListener('click', ()=>{ applyFilter(); showToast('Grid refreshed'); });

            // ── Inline Create ──
            const newRow = q('#new-row');
            const btnNew = q('#btn-new-operator');
            const btnSaveNew = q('#btn-save-new');
            const btnCancelNew = q('#btn-cancel-new');

            function showNewRow(){ newRow.classList.remove('d-none'); q('#new-name')?.focus(); }
            function hideNewRow(){ newRow.classList.add('d-none'); q('#new-name').value=''; q('#new-vendor').value=''; q('#new-competitor').value='false'; }

            btnNew?.addEventListener('click', showNewRow);
            btnCancelNew?.addEventListener('click', hideNewRow);

            btnSaveNew?.addEventListener('click', async ()=>{
                const name = q('#new-name').value.trim();
                const vendorId = q('#new-vendor').value;
                const isCompetitor = q('#new-competitor').value === 'true';
                if(!name||!vendorId){ alert('Operator Name and Vendor are required.'); return; }
                const payload = { operatorName:name, vendorId, isCompetitor };
                const resp = await fetch('/Operators/InlineCreate',{ method:'POST', headers:{ 'Content-Type':'application/json','RequestVerificationToken': getToken() }, body: JSON.stringify(payload) });
                if(resp.ok){
                    const data = await resp.json();
                    const compBadge = data.isCompetitor ? '<span class="disp badge-yes">Yes</span>' : '<span class="disp badge-no">No</span>';
                    const compSelect = data.isCompetitor
                        ? '<select class="form-select form-select-sm edit d-none"><option value="false">No</option><option value="true" selected>Yes</option></select>'
                        : '<select class="form-select form-select-sm edit d-none"><option value="false" selected>No</option><option value="true">Yes</option></select>';
                    const tr = document.createElement('tr');
                    tr.setAttribute('data-id', data.id);
                    tr.innerHTML = `
                        <td class="col-name"><span class="disp">${data.operatorName||''}</span><input class="form-control form-control-sm edit d-none" value="${data.operatorName||''}" /></td>
                        <td class="col-vendor"><span class="disp">${data.vendorName||''}</span><select class="form-select form-select-sm edit d-none">${q('#new-vendor').innerHTML}</select></td>
                        <td class="col-competitor">${compBadge}${compSelect}</td>
                        <td><div class="d-flex gap-2 align-items-center">
                            <button type="button" class="btn btn-sm btn-outline-primary btn-edit" title="Edit"><i class="bi bi-pencil"></i></button>
                            <button type="button" class="btn btn-sm btn-success d-none btn-save" title="Save"><i class="bi bi-check-lg"></i></button>
                            <button type="button" class="btn btn-sm btn-secondary d-none btn-cancel" title="Cancel"><i class="bi bi-x-lg"></i></button>
                            <form action="/Operators/Delete" method="post" class="d-inline m-0">
                                <input type="hidden" name="__RequestVerificationToken" value="${getToken()}" />
                                <input type="hidden" name="id" value="${data.id}" />
                                <button type="submit" class="btn btn-sm btn-outline-danger" title="Delete" onclick="return confirm('Delete this operator?');"><i class="bi bi-trash"></i></button>
                            </form>
                        </div></td>`;
                    if(vendorId) tr.querySelector('.col-vendor select').value = vendorId;
                    newRow.after(tr);
                    wireEditRow(tr);
                    rows.push(tr);
                    hideNewRow();
                    if(total) total.textContent = parseInt(total.textContent||'0',10)+1;
                    showToast('Operator created');
                } else { const err = await resp.text(); alert('Failed to create: ' + err); }
            });

            function wireEditRow(r){
                const btnEdit = r.querySelector('.btn-edit');
                const btnSave = r.querySelector('.btn-save');
                const btnCancel = r.querySelector('.btn-cancel');
                const toggles = () => {
                    r.querySelectorAll('.disp').forEach(e=>e.classList.toggle('d-none'));
                    r.querySelectorAll('.edit').forEach(e=>e.classList.toggle('d-none'));
                    btnEdit.classList.toggle('d-none');
                    btnSave.classList.toggle('d-none');
                    btnCancel.classList.toggle('d-none');
                };
                let orig = null;
                btnEdit?.addEventListener('click', () => {
                    orig = {
                        name: r.querySelector('.col-name input').value,
                        vendor: r.querySelector('.col-vendor select').value,
                        competitor: r.querySelector('.col-competitor select').value
                    };
                    toggles();
                });
                btnCancel?.addEventListener('click', () => {
                    if (orig){
                        r.querySelector('.col-name input').value = orig.name;
                        r.querySelector('.col-vendor select').value = orig.vendor;
                        r.querySelector('.col-competitor select').value = orig.competitor;
                    }
                    toggles();
                });
                btnSave?.addEventListener('click', async () => {
                    const id = r.getAttribute('data-id');
                    const payload = {
                        id: id,
                        operatorName: r.querySelector('.col-name input').value,
                        vendorId: r.querySelector('.col-vendor select').value,
                        isCompetitor: r.querySelector('.col-competitor select').value === 'true'
                    };
                    const resp = await fetch('/Operators/InlineUpdate', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'RequestVerificationToken': getToken()
                        },
                        body: JSON.stringify(payload)
                    });
                    if (resp.ok){
                        const data = await resp.json();
                        r.querySelector('.col-name .disp').textContent = data.operatorName || payload.operatorName;
                        r.querySelector('.col-vendor .disp').textContent = data.vendorName || '';
                        // Update competitor badge
                        const compCell = r.querySelector('.col-competitor');
                        const badge = compCell.querySelector('.disp');
                        if (data.isCompetitor) {
                            badge.textContent = 'Yes';
                            badge.className = 'disp badge-yes';
                        } else {
                            badge.textContent = 'No';
                            badge.className = 'disp badge-no';
                        }
                        toggles();
                        showToast('Saved');
                    } else {
                        alert('Failed to save changes');
                    }
                });
            }
        })();
    </script>
}
