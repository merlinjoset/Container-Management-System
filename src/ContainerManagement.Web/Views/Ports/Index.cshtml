@model IEnumerable<ContainerManagement.Application.Dtos.Ports.PortListItemDto>

@{
    ViewData["Title"] = "Ports";
    ViewData["ShowNew"] = false;
}

@section Styles{
    <link rel="stylesheet" href="~/css/ui-common.css" asp-append-version="true" />
    <style>
        .op-toast { position: fixed; right: 1rem; bottom: 1rem; background: #111827; color: #fff; padding: .5rem .75rem; border-radius: .375rem; opacity: 0; transition: opacity .2s ease; }
        .op-toast.show { opacity: .95; }
    </style>
}

<div class="operator-page">
    <div class="page-header">Ports</div>
    <div class="d-flex gap-2 toolbar align-items-center">
        <button type="button" class="btn btn-outline-secondary btn-sm" id="btn-new-port" data-bs-toggle="tooltip" title="New">
            <i class="bi bi-plus-square"></i>
        </button>
        @await Html.PartialAsync("_GridToolbar")
    </div>

    <div class="content">
        <div class="left-grid">
            <div class="grid-card">
                <div class="grid-header">
                    <div>Port Data</div>
                    <span class="badge badge-count" id="pt-total">@Model?.Count() ?? 0</span>
                </div>

                <div class="table-wrapper">
                    <table class="table table-sm mb-0 sticky" id="portsTable">
                        <thead>
                            <tr>
                                <th>Port Code</th>
                                <th>Full Name</th>
                                <th>Country</th>
                                <th>Region</th>
                                <th style="width:130px;">Actions</th>
                            </tr>
                            <tr class="filter-row">
                                <th><input id="cf-code" class="form-control form-control-sm" placeholder="Filter..." /></th>
                                <th><input id="cf-name" class="form-control form-control-sm" placeholder="Filter..." /></th>
                                <th><input id="cf-country" class="form-control form-control-sm" placeholder="Filter..." /></th>
                                <th><input id="cf-region" class="form-control form-control-sm" placeholder="Filter..." /></th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody id="pt-grid-body">
                        @* ── Inline create row (hidden by default) ── *@
                        <tr id="new-row" class="table-info d-none">
                            <td class="col-code">
                                <input class="form-control form-control-sm" id="new-code" placeholder="Port Code" maxlength="5" />
                            </td>
                            <td class="col-name">
                                <input class="form-control form-control-sm" id="new-name" placeholder="Full Name" />
                            </td>
                            <td class="col-country">
                                <select class="form-select form-select-sm" id="new-country">
                                    <option value="">-- Country --</option>
                                    @if (ViewBag.Countries is IEnumerable<SelectListItem> newCountries)
                                    { foreach (var c in newCountries){ <option value="@c.Value">@c.Text</option> } }
                                </select>
                            </td>
                            <td class="col-region">
                                <select class="form-select form-select-sm" id="new-region">
                                    <option value="">-- Region --</option>
                                    @if (ViewBag.Regions is IEnumerable<SelectListItem> newRegions)
                                    { foreach (var r in newRegions){ <option value="@r.Value">@r.Text</option> } }
                                </select>
                            </td>
                            <td>
                                <div class="d-flex gap-2 align-items-center">
                                    <button type="button" class="btn btn-sm btn-success" id="btn-save-new" data-bs-toggle="tooltip" title="Save"><i class="bi bi-check-lg"></i></button>
                                    <button type="button" class="btn btn-sm btn-secondary" id="btn-cancel-new" data-bs-toggle="tooltip" title="Cancel"><i class="bi bi-x-lg"></i></button>
                                </div>
                            </td>
                        </tr>
                        @if (Model?.Any() == true)
                        {
                            foreach (var port in Model)
                            {
                                <tr data-id="@port.Id">
                                    <td class="col-code">
                                        <span class="disp">@port.PortCode</span>
                                        <input class="form-control form-control-sm edit d-none" value="@port.PortCode" maxlength="5" />
                                    </td>
                                    <td class="col-name">
                                        <span class="disp">@port.FullName</span>
                                        <input class="form-control form-control-sm edit d-none" value="@port.FullName" />
                                    </td>
                                    <td class="col-country">
                                        <span class="disp">@port.CountryName</span>
                                        <select class="form-select form-select-sm edit d-none">
                                            @if (ViewBag.Countries is IEnumerable<SelectListItem> countries)
                                            { foreach (var c in countries){ <option value="@c.Value" selected="@(port.CountryId.ToString()==c.Value)">@c.Text</option>; } }
                                        </select>
                                    </td>
                                    <td class="col-region">
                                        <span class="disp">@port.RegionName</span>
                                        <select class="form-select form-select-sm edit d-none">
                                            @if (ViewBag.Regions is IEnumerable<SelectListItem> regions)
                                            { foreach (var r in regions){ <option value="@r.Value" selected="@(port.RegionId.ToString()==r.Value)">@r.Text</option>; } }
                                        </select>
                                    </td>
                                    <td>
                                        <div class="d-flex gap-2 align-items-center">
                                            <button type="button" class="btn btn-sm btn-outline-primary btn-edit" data-bs-toggle="tooltip" title="Edit"><i class="bi bi-pencil"></i></button>
                                            <button type="button" class="btn btn-sm btn-success d-none btn-save" data-bs-toggle="tooltip" title="Save"><i class="bi bi-check-lg"></i></button>
                                            <button type="button" class="btn btn-sm btn-secondary d-none btn-cancel" data-bs-toggle="tooltip" title="Cancel"><i class="bi bi-x-lg"></i></button>
                                            <form asp-action="Delete" method="post" class="d-inline m-0">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@port.Id" />
                                                <button type="submit" class="btn btn-sm btn-outline-danger" data-bs-toggle="tooltip" title="Delete" onclick="return confirm('Delete this port?');"><i class="bi bi-trash"></i></button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
        <div class="right-blank"></div>
    </div>
</div>

<div id="pt-toast" class="op-toast" role="status" aria-live="polite"></div>
<form id="ports-af">@Html.AntiForgeryToken()</form>

@section Scripts {
    <script>
        (function(){
            const q=(s)=>document.querySelector(s);
            const rows = Array.from(document.querySelectorAll('#pt-grid-body tr[data-id]'));
            const total = q('#pt-total');
            const refreshBtn = q('#grid-refresh');
            const toast = q('#pt-toast');
            function showToast(msg){ if(!toast) return; toast.textContent = msg; toast.classList.add('show'); setTimeout(()=>toast.classList.remove('show'), 1500); }
            function filter(){
                const fcode=(q('#cf-code')?.value||'').toLowerCase();
                const fname=(q('#cf-name')?.value||'').toLowerCase();
                const fcountry=(q('#cf-country')?.value||'').toLowerCase();
                const fregion=(q('#cf-region')?.value||'').toLowerCase();
                let count=0;
                rows.forEach(r=>{
                    const code=r.querySelector('.col-code .disp').textContent.toLowerCase();
                    const name=r.querySelector('.col-name .disp').textContent.toLowerCase();
                    const country=r.querySelector('.col-country .disp').textContent.toLowerCase();
                    const region=r.querySelector('.col-region .disp').textContent.toLowerCase();
                    const show=(!fcode||code.includes(fcode))&&(!fname||name.includes(fname))&&(!fcountry||country.includes(fcountry))&&(!fregion||region.includes(fregion));
                    r.style.display = show? '':'none';
                    if (show) count++;
                });
                if (total) total.textContent = count;
            }
            ['#cf-code','#cf-name','#cf-country','#cf-region'].forEach(id=>{ const e=q(id); if(e) e.addEventListener('input', filter);}); filter();
            function token(){ const el=document.querySelector('#ports-af input[name="__RequestVerificationToken"]'); return el?el.value:''; }
            rows.forEach(r=> wireEditRow(r));
            refreshBtn?.addEventListener('click', ()=>{ filter(); showToast('Grid refreshed'); });

            // ── Inline Create ──
            const newRow = q('#new-row');
            const btnNew = q('#btn-new-port');
            const btnSaveNew = q('#btn-save-new');
            const btnCancelNew = q('#btn-cancel-new');

            function showNewRow(){ newRow.classList.remove('d-none'); q('#new-code')?.focus(); }
            function hideNewRow(){ newRow.classList.add('d-none'); q('#new-code').value=''; q('#new-name').value=''; q('#new-country').value=''; q('#new-region').value=''; }

            btnNew?.addEventListener('click', showNewRow);
            btnCancelNew?.addEventListener('click', hideNewRow);

            btnSaveNew?.addEventListener('click', async ()=>{
                const code = q('#new-code').value.trim();
                const name = q('#new-name').value.trim();
                const countryId = q('#new-country').value;
                const regionId = q('#new-region').value;
                if(!code||!name||!countryId||!regionId){ alert('All fields are required.'); return; }
                const payload = { portCode:code, fullName:name, countryId, regionId };
                const resp = await fetch('/Ports/InlineCreate',{ method:'POST', headers:{ 'Content-Type':'application/json','RequestVerificationToken': token() }, body: JSON.stringify(payload) });
                if(resp.ok){
                    const data = await resp.json();
                    // Build a new data row and insert after the new-row
                    const tr = document.createElement('tr');
                    tr.setAttribute('data-id', data.id);
                    tr.innerHTML = `
                        <td class="col-code"><span class="disp">${data.portCode||''}</span><input class="form-control form-control-sm edit d-none" value="${data.portCode||''}" maxlength="5" /></td>
                        <td class="col-name"><span class="disp">${data.fullName||''}</span><input class="form-control form-control-sm edit d-none" value="${data.fullName||''}" /></td>
                        <td class="col-country"><span class="disp">${data.countryName||''}</span><select class="form-select form-select-sm edit d-none">${q('#new-country').innerHTML}</select></td>
                        <td class="col-region"><span class="disp">${data.regionName||''}</span><select class="form-select form-select-sm edit d-none">${q('#new-region').innerHTML}</select></td>
                        <td><div class="d-flex gap-2 align-items-center">
                            <button type="button" class="btn btn-sm btn-outline-primary btn-edit" title="Edit"><i class="bi bi-pencil"></i></button>
                            <button type="button" class="btn btn-sm btn-success d-none btn-save" title="Save"><i class="bi bi-check-lg"></i></button>
                            <button type="button" class="btn btn-sm btn-secondary d-none btn-cancel" title="Cancel"><i class="bi bi-x-lg"></i></button>
                            <form action="/Ports/Delete" method="post" class="d-inline m-0">
                                <input type="hidden" name="__RequestVerificationToken" value="${token()}" />
                                <input type="hidden" name="id" value="${data.id}" />
                                <button type="submit" class="btn btn-sm btn-outline-danger" title="Delete" onclick="return confirm('Delete this port?');"><i class="bi bi-trash"></i></button>
                            </form>
                        </div></td>`;
                    if(countryId) tr.querySelector('.col-country select').value = countryId;
                    if(regionId) tr.querySelector('.col-region select').value = regionId;
                    newRow.after(tr);
                    wireEditRow(tr);
                    rows.push(tr);
                    hideNewRow();
                    if(total) total.textContent = parseInt(total.textContent||'0',10)+1;
                    showToast('Port created');
                } else { const err = await resp.text(); alert('Failed to create: ' + err); }
            });

            // Extracted so new rows can reuse the edit wiring
            function wireEditRow(r){
                const edit=r.querySelector('.btn-edit'); const save=r.querySelector('.btn-save'); const cancel=r.querySelector('.btn-cancel');
                const toggle=()=>{ r.querySelectorAll('.disp').forEach(e=>e.classList.toggle('d-none')); r.querySelectorAll('.edit').forEach(e=>e.classList.toggle('d-none')); edit.classList.toggle('d-none'); save.classList.toggle('d-none'); cancel.classList.toggle('d-none'); };
                let orig=null;
                edit?.addEventListener('click',()=>{ orig={ code:r.querySelector('.col-code input').value, name:r.querySelector('.col-name input').value, country:r.querySelector('.col-country select').value, region:r.querySelector('.col-region select').value}; toggle(); });
                cancel?.addEventListener('click',()=>{ if(orig){ r.querySelector('.col-code input').value=orig.code; r.querySelector('.col-name input').value=orig.name; r.querySelector('.col-country select').value=orig.country; r.querySelector('.col-region select').value=orig.region; } toggle();});
                save?.addEventListener('click', async ()=>{
                    const payload={ id:r.getAttribute('data-id'), portCode:r.querySelector('.col-code input').value, fullName:r.querySelector('.col-name input').value, countryId:r.querySelector('.col-country select').value, regionId:r.querySelector('.col-region select').value };
                    const resp=await fetch('/Ports/InlineUpdate',{ method:'POST', headers:{ 'Content-Type':'application/json','RequestVerificationToken': token() }, body: JSON.stringify(payload)});
                    if (resp.ok){ const data=await resp.json(); r.querySelector('.col-code .disp').textContent=data.portCode||payload.portCode; r.querySelector('.col-name .disp').textContent=data.fullName||payload.fullName; r.querySelector('.col-country .disp').textContent=data.countryName||''; r.querySelector('.col-region .disp').textContent=data.regionName||''; toggle(); showToast('Saved'); } else alert('Failed to save changes');
                });
            }
        })();
    </script>
}




