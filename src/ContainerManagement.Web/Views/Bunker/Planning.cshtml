@{
    ViewData["Title"] = "Bunker Planning";
}

@section Styles {
<style>
    .bp-page { background: #f8fafc; min-height: 100vh; padding: 1rem; }

    /* Page tabs */
    .bp-pagetabs { display: flex; gap: 0; border-bottom: 1px solid #e5e7eb; margin-bottom: 1.25rem; }
    .bp-pagetabs .tab { padding: .55rem 1.1rem; font-size: .82rem; color: #64748b; cursor: pointer; border-bottom: 2px solid transparent; }
    .bp-pagetabs .tab.active { color: #0f172a; border-bottom-color: #0f172a; font-weight: 600; }

    /* Step indicator */
    .bp-steps { display: flex; align-items: center; gap: .6rem; margin-bottom: .75rem; font-size: .8rem; }
    .bp-steps .step-dot { width: 22px; height: 22px; border-radius: 50%; display: inline-flex; align-items: center; justify-content: center; font-size: .7rem; font-weight: 600; background: #e2e8f0; color: #64748b; }
    .bp-steps .step.active .step-dot { background: #0f172a; color: #fff; }
    .bp-steps .step.active .step-label { color: #0f172a; font-weight: 600; }
    .bp-steps .step-label { color: #94a3b8; }
    .bp-steps .step-sep { color: #cbd5e1; }

    /* Heading */
    .bp-title { font-size: 1.6rem; font-weight: 800; color: #0f172a; margin-bottom: .15rem; }
    .bp-sub { color: #64748b; font-size: .82rem; margin-bottom: 1rem; }

    /* Filter row */
    .bp-filters { display: flex; flex-wrap: wrap; gap: .6rem; align-items: center; margin-bottom: 1rem; padding: .6rem .75rem; background: #fff; border: 1px solid #e5e7eb; border-radius: .5rem; }
    .bp-filters .search-wrap { position: relative; flex: 0 0 220px; }
    .bp-filters .search-wrap i { position: absolute; left: .55rem; top: 50%; transform: translateY(-50%); color: #94a3b8; font-size: .8rem; }
    .bp-filters .search-wrap input { width: 100%; padding: .35rem .6rem .35rem 1.7rem; border: 1px solid #e5e7eb; border-radius: .35rem; font-size: .8rem; }
    .bp-filters select, .bp-filters .date-range { padding: .35rem .6rem; border: 1px solid #e5e7eb; border-radius: .35rem; font-size: .8rem; background: #fff; cursor: pointer; min-width: 110px; }
    .bp-filters .date-range i { margin-right: .35rem; color: #64748b; }

    /* Layout — table left, contracts right */
    .bp-content { display: grid; grid-template-columns: 1fr 360px; gap: 1rem; align-items: start; }
    @@media (max-width: 1280px) { .bp-content { grid-template-columns: 1fr; } }

    /* Vessel table */
    .bp-table-card { background: #fff; border: 1px solid #e5e7eb; border-radius: .5rem; overflow: hidden; }
    .bp-table { width: 100%; font-size: .78rem; border-collapse: collapse; }
    .bp-table thead th { background: #fff; color: #475569; font-weight: 600; font-size: .72rem; padding: .65rem .65rem; border-bottom: 1px solid #e5e7eb; text-transform: none; }
    .bp-table tbody td { padding: .55rem .65rem; border-bottom: 1px solid #f1f5f9; vertical-align: middle; }
    .bp-table .vessel-cell { display: flex; flex-direction: column; }
    .bp-table .vessel-cell .v-name { font-weight: 600; color: #0f172a; }
    .bp-table .vessel-cell .v-svc { color: #64748b; font-size: .7rem; }
    .bp-table .chk { margin-right: .35rem; vertical-align: middle; }
    .bp-table .multi-row { display: flex; flex-direction: column; gap: .3rem; }
    .bp-table .multi-row .row-line { display: flex; align-items: center; gap: .35rem; }
    .bp-table select.bp-sel { font-size: .76rem; padding: .15rem .35rem; border: 1px solid #e5e7eb; border-radius: .25rem; background: #fff; min-width: 100px; }
    .bp-table .qty-cell { font-weight: 600; color: #0f172a; }
    .bp-table .actions-cell { display: flex; align-items: center; gap: .25rem; }
    .bp-table .actions-cell .icon-btn { background: transparent; border: 0; color: #64748b; padding: .15rem .25rem; border-radius: .2rem; cursor: pointer; font-size: .85rem; }
    .bp-table .actions-cell .icon-btn:hover { background: #f1f5f9; color: #0f172a; }

    /* Side panel - Contracts overview */
    .bp-side { background: #fff; border: 1px solid #e5e7eb; border-radius: .5rem; padding: 1rem; }
    .bp-side h3 { font-size: 1rem; font-weight: 700; color: #0f172a; margin-bottom: .5rem; }
    .bp-side .port-pick { display: flex; align-items: center; gap: .35rem; font-size: .78rem; color: #475569; margin-bottom: .85rem; cursor: pointer; }
    .bp-side .fuel-tabs { display: flex; gap: 0; margin-bottom: .8rem; border-bottom: 1px solid #e5e7eb; }
    .bp-side .fuel-tabs .ft { padding: .35rem .65rem; font-size: .76rem; color: #64748b; cursor: pointer; border-bottom: 2px solid transparent; }
    .bp-side .fuel-tabs .ft.active { color: #0f172a; border-bottom-color: #0f172a; font-weight: 600; }
    .bp-side .contract-block { margin-bottom: .9rem; }
    .bp-side .contract-block .vendor { font-weight: 600; color: #0f172a; font-size: .78rem; margin-bottom: .35rem; }
    .bp-side .contract-table { width: 100%; font-size: .72rem; }
    .bp-side .contract-table th { color: #94a3b8; font-weight: 500; text-align: left; padding: .15rem 0; }
    .bp-side .contract-table td { padding: .15rem 0; color: #334155; }
    .bp-side .contract-table td.balance-bold { font-weight: 700; color: #0f172a; text-align: right; }
    .bp-side .spot-row { display: flex; align-items: center; justify-content: space-between; margin-top: .5rem; }
    .bp-side .spot-label { font-weight: 700; color: #0f172a; font-size: .78rem; }
    .bp-side .spot-price { font-weight: 700; color: #0f172a; font-size: .78rem; }
    .bp-side .last90 { font-size: .72rem; color: #64748b; margin-top: .85rem; margin-bottom: .35rem; }
    .bp-side .legend { display: flex; gap: .6rem; font-size: .68rem; color: #64748b; flex-wrap: wrap; margin-bottom: .35rem; }
    .bp-side .legend .dot { display: inline-block; width: 10px; height: 2px; vertical-align: middle; margin-right: .2rem; }
    .bp-side .chart-box { background: #fafbfc; border-radius: .35rem; padding: .35rem; }
    .bp-side .info-callout { display: flex; gap: .5rem; align-items: flex-start; background: #f8fafc; padding: .55rem .65rem; border-radius: .35rem; margin-top: .85rem; font-size: .68rem; color: #475569; line-height: 1.4; }
    .bp-side .info-callout i { color: #f59e0b; font-size: .9rem; margin-top: .1rem; }

    /* Floating Review button */
    .bp-review-btn { position: fixed; right: 1.2rem; bottom: 1.2rem; background: #0d9488; color: #fff; padding: .6rem 1rem; border-radius: .4rem; font-size: .82rem; font-weight: 600; border: 0; box-shadow: 0 4px 14px rgba(13, 148, 136, .35); cursor: pointer; display: inline-flex; align-items: center; gap: .5rem; }
    .bp-review-btn:hover { background: #0f766e; }
    .bp-review-btn .review-count { background: rgba(255,255,255,.25); padding: .1rem .45rem; border-radius: .3rem; font-size: .7rem; }
</style>
}

<div class="bp-page">

    <!-- Page tabs -->
    <div class="bp-pagetabs">
        <div class="tab">Procurement</div>
        <div class="tab active">Bunker Planning</div>
    </div>

    <!-- Step indicator -->
    <div class="bp-steps">
        <span class="step active"><span class="step-dot">1</span> <span class="step-label">Planning</span></span>
        <span class="step-sep">›</span>
        <span class="step"><span class="step-dot">2</span> <span class="step-label">Review</span></span>
        <span class="step-sep">›</span>
        <span class="step"><span class="step-dot">3</span> <span class="step-label">Prenominations</span></span>
    </div>

    <h1 class="bp-title">Planning</h1>
    <p class="bp-sub">Please complete bunker port, quantities and contracts allocation. Use the filters to plan across ports, regions and services.</p>

    <!-- Filters -->
    <div class="bp-filters">
        <div class="search-wrap">
            <i class="bi bi-search"></i>
            <input type="text" placeholder="Search" />
        </div>
        <select><option>All services</option></select>
        <select><option>All regions</option></select>
        <select><option>All ports</option></select>
        <select><option>All fuel types</option></select>
        <select><option>Responsible buyer</option></select>
        <select><option>Unplanned</option></select>
        <span class="date-range"><i class="bi bi-calendar3"></i>Oct 1, 2024 - Oct 31, 2024 <i class="bi bi-chevron-down" style="margin-left:.4rem;"></i></span>
    </div>

    <div class="bp-content">
        <!-- LEFT: vessel table -->
        <div class="bp-table-card">
            <table class="bp-table">
                <thead>
                    <tr>
                        <th>Vessel</th>
                        <th>Bunker port</th>
                        <th>ETA</th>
                        <th>Bunker requirements</th>
                        <th>Spot / Contract</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody id="bp-vessel-body">
                    <!-- Sample rows rendered by JS -->
                </tbody>
            </table>
        </div>

        <!-- RIGHT: contracts overview -->
        <div class="bp-side">
            <h3>Contracts overview</h3>
            <div class="port-pick"><i class="bi bi-geo-alt"></i> <strong>Singapore</strong> <i class="bi bi-chevron-down"></i></div>

            <div class="fuel-tabs">
                <div class="ft active">VLSFO</div>
                <div class="ft">HSFO</div>
                <div class="ft">MGO</div>
            </div>

            <div class="contract-block">
                <div class="vendor">Vitol Bunkers PTE. LTD.</div>
                <table class="contract-table">
                    <thead>
                        <tr><th>Contract</th><th>Min volume</th><th>Max volume</th><th>Planned</th><th class="balance-bold">Balance</th></tr>
                    </thead>
                    <tbody>
                        <tr><td>1128729</td><td>12,000</td><td>24,000</td><td>0</td><td class="balance-bold">24,000</td></tr>
                        <tr><td>1298093</td><td>15,000</td><td>30,000</td><td>0</td><td class="balance-bold">30,000</td></tr>
                    </tbody>
                </table>
            </div>

            <div class="contract-block">
                <div class="vendor">Global Maritime Products LLC</div>
                <table class="contract-table">
                    <thead>
                        <tr><th>Contract</th><th>Min volume</th><th>Max volume</th><th>Planned</th><th class="balance-bold">Balance</th></tr>
                    </thead>
                    <tbody>
                        <tr><td>1682032</td><td>10,000</td><td>30,000</td><td>0</td><td class="balance-bold">30,000</td></tr>
                        <tr><td>1192814</td><td>8,000</td><td>12,000</td><td>0</td><td class="balance-bold">12,000</td></tr>
                    </tbody>
                </table>
            </div>

            <div class="spot-row">
                <span class="spot-label">Spot</span>
                <span class="spot-price">$ 567</span>
            </div>

            <div class="last90">Last 90 days</div>
            <div class="legend">
                <span><span class="dot" style="background:#22c55e"></span>Spot</span>
                <span><span class="dot" style="background:#ef4444"></span>Vitol</span>
                <span><span class="dot" style="background:#3b82f6"></span>Global Maritime Products</span>
            </div>
            <div class="chart-box">
                <svg viewBox="0 0 320 80" width="100%" height="80" preserveAspectRatio="none">
                    <polyline fill="none" stroke="#22c55e" stroke-width="1.5" points="0,55 30,50 60,60 90,40 120,55 150,30 180,45 210,38 240,50 270,28 300,42 320,35" />
                    <polyline fill="none" stroke="#ef4444" stroke-width="1.5" points="0,30 30,38 60,28 90,42 120,30 150,46 180,25 210,32 240,38 270,40 300,28 320,32" />
                    <polyline fill="none" stroke="#3b82f6" stroke-width="1.5" points="0,65 30,60 60,55 90,68 120,58 150,62 180,55 210,60 240,52 270,58 300,55 320,52" />
                </svg>
            </div>

            <div class="info-callout">
                <i class="bi bi-lightbulb-fill"></i>
                <span>You will get a chance to review your planning in the next step. Once confirmed, bunker orders will be automatically generated and a copy will be sent to the vessels.</span>
            </div>
        </div>
    </div>
</div>

<button type="button" class="bp-review-btn" onclick="alert('Review step is not implemented yet.');">
    Review <span class="review-count">8</span> <i class="bi bi-arrow-right"></i>
</button>

@section Scripts {
<script>
    // ─── Sample seed data — replace with API later ──────────────────────────────
    const BP_VESSELS = [
        { name: 'Tokyo Road', svc: 'ACB', selA: true, selB: true, ports: ['Shanghai','Hong Kong'], etas: [['Oct 25 - 16:00','Oct 25 - 17:00'],['Oct 25 - 16:00','Oct 30 - 17:00']], fuels: [['VLSFO','RMG380','2,500','103284029'],['MGO','DMA 0.1%','2,200','320839902']], showActions: true },
        { name: 'Seawise Giant', svc: 'ACB', selA: false, selB: false, ports: ['Shanghai','Hong Kong'], etas: [['Oct 25 - 16:00','Oct 25 - 17:00'],['Oct 25 - 16:00','Oct 30 - 17:00']], fuels: [['VLSFO','RMG380','2,500','Select'],['MGO','DMA 0.1%','2,200','Select']], showActions: false },
        { name: 'Belhawk', svc: 'CB9', selA: true, selB: true, ports: ['Shanghai','Hong Kong'], etas: [['Oct 25 - 16:00','Oct 25 - 17:00'],['Oct 25 - 16:00','Oct 30 - 17:00']], fuels: [['VLSFO','RMG380','2,500','103284029'],['MGO','DMA 0.1%','2,200','320839902']], showActions: true },
        { name: 'Atlantic', svc: 'AE2', selA: true, selB: true, ports: ['Shanghai','Hong Kong'], etas: [['Oct 25 - 16:00','Oct 25 - 17:00'],['Oct 25 - 16:00','Oct 30 - 17:00']], fuels: [['VLSFO','RMG380','2,500','103284029'],['MGO','DMA 0.1%','2,200','320839902']], showActions: true },
        { name: 'Marco Polo', svc: 'BA4', selA: true, selB: true, ports: ['Shanghai','Hong Kong'], etas: [['Oct 25 - 16:00','Oct 25 - 17:00'],['Oct 25 - 16:00','Oct 30 - 17:00']], fuels: [['VLSFO','RMG380','2,500','103284029'],['MGO','DMA 0.1%','2,500','320839902']], showActions: true },
        { name: 'Colombus', svc: 'AE2', selA: false, selB: false, ports: ['Shanghai','Hong Kong'], etas: [['Oct 25 - 16:00','Oct 25 - 17:00'],['Oct 25 - 16:00','Oct 30 - 17:00']], fuels: [['VLSFO','RMG380','2,500','Select'],['MGO','DMA 0.1%','2,200','Select']], showActions: false },
        { name: 'Pacific', svc: 'CS3', selA: false, selB: false, ports: ['Shanghai','Hong Kong'], etas: [['Oct 25 - 16:00','Oct 25 - 17:00'],['Oct 25 - 16:00','Oct 30 - 17:00']], fuels: [['VLSFO','RMG380','2,500','Select'],['MGO','DMA 0.1%','2,200','Select']], showActions: false }
    ];

    function renderVessels() {
        const body = document.getElementById('bp-vessel-body');
        body.innerHTML = '';
        BP_VESSELS.forEach(function(v, idx) {
            const tr = document.createElement('tr');
            const portChks = [
                '<div class="row-line"><input type="checkbox" class="chk" ' + (v.selA ? 'checked' : '') + '/></div>',
                '<div class="row-line"><input type="checkbox" class="chk" ' + (v.selB ? 'checked' : '') + '/></div>'
            ];
            const portCol = `
                <div class="multi-row">
                    <div class="row-line">${portChks[0]}<select class="bp-sel"><option>${v.ports[0]}</option></select></div>
                    <div class="row-line">${portChks[1]}<select class="bp-sel"><option>${v.ports[1]}</option></select></div>
                </div>`;

            const etaCol = `
                <div class="multi-row">
                    <div class="row-line"><span>${v.etas[0][0]}</span><span style="color:#cbd5e1">·</span><span>${v.etas[0][1]}</span></div>
                    <div class="row-line"><span>${v.etas[1][0]}</span><span style="color:#cbd5e1">·</span><span>${v.etas[1][1]}</span></div>
                </div>`;

            const reqCol = `
                <div class="multi-row">
                    <div class="row-line"><select class="bp-sel"><option>${v.fuels[0][0]}</option></select><select class="bp-sel"><option>${v.fuels[0][1]}</option></select><span class="qty-cell">${v.fuels[0][2]}</span></div>
                    <div class="row-line"><select class="bp-sel"><option>${v.fuels[1][0]}</option></select><select class="bp-sel"><option>${v.fuels[1][1]}</option></select><span class="qty-cell">${v.fuels[1][2]}</span></div>
                </div>`;

            const spotCol = `
                <div class="multi-row">
                    <div class="row-line"><select class="bp-sel" style="min-width:120px"><option>${v.fuels[0][3]}</option></select></div>
                    <div class="row-line"><select class="bp-sel" style="min-width:120px"><option>${v.fuels[1][3]}</option></select></div>
                </div>`;

            const actionCol = v.showActions
                ? `<div class="actions-cell"><button class="icon-btn" title="Sync"><i class="bi bi-arrow-repeat"></i></button><button class="icon-btn" title="More"><i class="bi bi-three-dots"></i></button></div>`
                : `<div class="actions-cell"><button class="icon-btn" title="More"><i class="bi bi-three-dots"></i></button></div>`;

            tr.innerHTML = `
                <td>
                    <div class="vessel-cell">
                        <span class="v-name">${v.name}</span>
                        <span class="v-svc">${v.svc}</span>
                    </div>
                </td>
                <td>${portCol}</td>
                <td>${etaCol}</td>
                <td>${reqCol}</td>
                <td>${spotCol}</td>
                <td>${actionCol}</td>`;
            body.appendChild(tr);
        });
    }
    renderVessels();

    // Page tab toggling
    document.querySelectorAll('.bp-pagetabs .tab').forEach(function(t){
        t.addEventListener('click', function(){
            document.querySelectorAll('.bp-pagetabs .tab').forEach(x => x.classList.remove('active'));
            t.classList.add('active');
        });
    });

    // Fuel tab toggling
    document.querySelectorAll('.bp-side .fuel-tabs .ft').forEach(function(t){
        t.addEventListener('click', function(){
            document.querySelectorAll('.bp-side .fuel-tabs .ft').forEach(x => x.classList.remove('active'));
            t.classList.add('active');
        });
    });
</script>
}
